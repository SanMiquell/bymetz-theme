    "section_custom_liquid_GEheEy": {
      "type": "section-custom-liquid",
      "settings": {
        "custom_liquid": "{%- comment -%}\nByMetz breadcrumb (product) — 1 regel\n- Productnaam: ellipsis (puntjes)\n- Home + categorie: géén puntjes\n- Back-pijl: zelfde kleur als Home-link (thema linkkleur) + dezelfde hoogte/uitlijning\n- Kruimelpad iets omhoog (dichter bij zoekbalk)\n- Iets meer ruimte onder het kruimelpad\n- Geen JSON-LD (Custom Liquid editor blijft stabiel)\n{%- endcomment -%}\n\n{%- assign vendor_handle = product.vendor | handle -%}\n{%- assign category = nil -%}\n\n{%- if collection and collection.handle != vendor_handle -%}\n  {%- assign category = collection -%}\n{%- else -%}\n  {%- for col in product.collections reversed -%}\n    {%- if col.handle != vendor_handle -%}\n      {%- assign category = col -%}\n      {%- break -%}\n    {%- endif -%}\n  {%- endfor -%}\n{%- endif -%}\n\n{%- if category == nil and product.collections.size > 0 -%}\n  {%- assign category = product.collections.first -%}\n{%- endif -%}\n\n{%- assign back_fallback = routes.root_url -%}\n{%- if category -%}{%- assign back_fallback = category.url -%}{%- endif -%}\n\n<nav class=\"bymetz-bc\" aria-label=\"Kruimelpad\">\n  <a class=\"bymetz-bc__back\"\n     href=\"{{ back_fallback }}\"\n     aria-label=\"Vorige pagina\"\n     title=\"Terug\"\n     onclick=\"\n       try{\n         var r=document.referrer;\n         if(r && r.indexOf(location.origin)===0 && r!==location.href){location.href=r;return false;}\n         if(history.length>1){history.back();return false;}\n       }catch(e){}\n       return true;\">\n    <svg class=\"bymetz-bc__backicon\" viewBox=\"0 0 24 24\" aria-hidden=\"true\" focusable=\"false\">\n      <path d=\"M15 18l-6-6 6-6\" />\n    </svg>\n  </a>\n\n  <ol class=\"bymetz-bc__list\">\n    <li class=\"bymetz-bc__item\">\n      <a class=\"bymetz-bc__link bymetz-bc__link--home\" href=\"{{ routes.root_url }}\">Home</a>\n    </li>\n\n    {%- if category -%}\n      <li class=\"bymetz-bc__item\">\n        <a class=\"bymetz-bc__link bymetz-bc__link--cat\" href=\"{{ category.url }}\" title=\"{{ category.title }}\">\n          {{ category.title }}\n        </a>\n      </li>\n    {%- endif -%}\n\n    <li class=\"bymetz-bc__item bymetz-bc__item--current\" aria-current=\"page\">\n      <span class=\"bymetz-bc__current\" title=\"{{ product.title }}\">{{ product.title }}</span>\n    </li>\n  </ol>\n</nav>\n\n<style>\n  .bymetz-bc{\n    display:flex;\n    align-items:center;\n    gap:10px;\n    width:100%;\n    min-width:0;\n    white-space:nowrap;\n    overflow:hidden;\n    font-size:12px;\n    line-height:1.2;\n    margin-top:-10px;   /* dichter bij zoekbalk */\n    padding-bottom:6px; /* iets meer ruimte naar product */\n    margin-bottom:6px;  /* iets meer ruimte naar product */\n  }\n\n  .bymetz-bc__back{\n    flex:0 0 auto;\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    text-decoration:none;\n    line-height:1.2;\n    padding:0;\n    margin:0;\n  }\n\n  .bymetz-bc__backicon{\n    width:1em;\n    height:1em;\n    display:block;\n    stroke:currentColor;\n    stroke-width:2.8;\n    fill:none;\n    stroke-linecap:round;\n    stroke-linejoin:round;\n  }\n\n  .bymetz-bc__list{\n    flex:1 1 auto;\n    min-width:0;\n    display:flex;\n    align-items:center;\n    list-style:none;\n    margin:0;\n    padding:0;\n    overflow:hidden;\n    white-space:nowrap;\n  }\n\n  .bymetz-bc__item{\n    display:flex;\n    align-items:center;\n    min-width:0;\n    flex:0 0 auto;\n  }\n\n  .bymetz-bc__item + .bymetz-bc__item::before{\n    content:\"›\";\n    padding:0 8px;\n    opacity:.65;\n  }\n\n  .bymetz-bc__link{\n    display:inline-block;\n    white-space:nowrap;\n    overflow:visible;\n    text-overflow:clip;\n    text-decoration:none;\n  }\n\n  .bymetz-bc__link--cat{\n    max-width:260px;\n    overflow:hidden;\n    text-overflow:clip;\n  }\n\n  .bymetz-bc__item--current{\n    flex:1 1 auto;\n    min-width:0;\n    overflow:hidden;\n  }\n\n  .bymetz-bc__current{\n    display:block;\n    width:100%;\n    overflow:hidden;\n    text-overflow:ellipsis;\n    white-space:nowrap;\n    font-weight:700;\n  }\n\n  @media (max-width: 640px){\n    .bymetz-bc{\n      margin-top:-20px;\n      padding-bottom:4px;\n      margin-bottom:4px;\n    }\n\n    .bymetz-bc__link--cat{\n      max-width:180px;\n    }\n  }\n</style>",
        "spacing_desktop": 10,
