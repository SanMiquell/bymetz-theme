=\"bm-reviewbar__star-fill\" data-bm-star-fill></span>\n          <span class=\"bm-reviewbar__star-icon\">\n            <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\" focusable=\"false\">\n              <path d=\"M12 2.2l3.09 6.26 6.91 1-5 4.87 1.18 6.89L12 17.98 5.82 21.22 7 14.33 2 9.46l6.91-1L12 2.2z\" fill=\"currentColor\"></path>\n            </svg>\n          </span>\n        </span>\n      {%- endfor -%}\n    </div>\n\n    <p class=\"bm-reviewbar__text\" data-bm-review-text>\n      {{ bm_review_text }}\n    </p>\n  </div>\n\n  <span class=\"bm-reviewbar__logo-wrap\">\n    <img\n      class=\"bm-reviewbar__logo\"\n      src=\"https://dashboard.webwinkelkeur.nl/img/badges/icon_member.svg?m=1774934019\"\n      alt=\"WebwinkelKeur\"\n      loading=\"lazy\"\n    >\n  </span>\n</a>\n\n<style>\n  .bm-reviewbar {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    flex-wrap: nowrap;\n    gap: 12px;\n    width: 100%;\n    padding: 14px 18px;\n    border: 1px solid #e6e6e6;\n    border-radius: 8px;\n    background: #fff;\n    color: #1f1f1f;\n    text-decoration: none;\n    box-sizing: border-box;\n    overflow: hidden;\n  }\n\n  .bm-reviewbar__main {\n    display: flex;\n    align-items: center;\n    flex-direction: row;\n    flex-wrap: nowrap;\n    gap: 12px;\n    min-width: 0;\n    flex: 1 1 auto;\n  }\n\n  .bm-reviewbar__stars {\n    display: flex;\n    align-items: center;\n    gap: 2px;\n    flex: 0 0 auto;\n  }\n\n  .bm-reviewbar__star-box {\n    position: relative;\n    width: 20px;\n    height: 20px;\n    background: #dcdce6;\n    overflow: hidden;\n    border-radius: 1px;\n    flex: 0 0 auto;\n  }\n\n  .bm-reviewbar__star-fill {\n    position: absolute;\n    top: 0;\n    left: 0;\n    bottom: 0;\n    width: 0%;\n    background: #00b67a;\n    z-index: 1;\n  }\n\n  .bm-reviewbar__star-icon {\n    position: absolute;\n    inset: 0;\n    z-index: 2;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: #ffffff;\n  }\n\n  .bm-reviewbar__star-icon svg {\n    width: 13px;\n    height: 13px;\n    display: block;\n  }\n\n  .bm-reviewbar__text {\n    margin: 0;\n    min-width: 0;\n    font-size: clamp(13px, 1.6vw, 16px);\n    line-height: 1.2;\n    color: #1f1f1f;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n  }\n\n  .bm-reviewbar__text strong {\n    font-weight: 700;\n  }\n\n  .bm-reviewbar__logo-wrap {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    flex: 0 0 auto;\n  }\n\n  .bm-reviewbar__logo {\n    display: block;\n    width: clamp(34px, 4vw, 44px);\n    height: clamp(34px, 4vw, 44px);\n    min-width: clamp(34px, 4vw, 44px);\n    object-fit: contain;\n  }\n\n  @media screen and (max-width: 749px) {\n    .bm-reviewbar {\n      padding: 12px 14px;\n      gap: 10px;\n    }\n\n    .bm-reviewbar__main {\n      flex-direction: row !important;\n      align-items: center;\n      gap: 10px;\n    }\n\n    .bm-reviewbar__stars {\n      gap: 2px;\n    }\n\n    .bm-reviewbar__star-box {\n      width: 17px;\n      height: 17px;\n    }\n\n    .bm-reviewbar__star-icon svg {\n      width: 11px;\n      height: 11px;\n    }\n\n    .bm-reviewbar__text {\n      font-size: 13px;\n      line-height: 1.15;\n      white-space: nowrap;\n    }\n\n    .bm-reviewbar__logo {\n      width: 34px;\n      height: 34px;\n      min-width: 34px;\n    }\n  }\n</style>\n\n<script>\n  (function () {\n    var shopId = '1205113';\n    var publicCode = '03e5774fc5bbb511f818d7058ac6f114faf0b8f071780e637442ece7f3958bbd';\n    var themeLang = {{ bm_lang | json }};\n\n    var locale = (themeLang || document.documentElement.lang || navigator.language || 'nl')\n      .toLowerCase()\n      .replace('_', '-')\n      .split('-')[0];\n\n    var config = {\n      nl: {\n        url: 'https://www.webwinkelkeur.nl/webshop/ByMetz-Tassen-Koffers_1205113/reviews?page=1',\n        intl: 'nl-NL',\n        fallbackScore: 9.6,\n        fallbackCount: 1768,\n        text: function (score, count) {\n          return 'Beoordeeld als <strong>' + score + '</strong> door <strong>' + count + '</strong> klanten.';\n        }\n      },\n      en: {\n        url: 'https://www.valuedshops.com/webshop/ByMetz-Tassen-Koffers_1205113/reviews',\n        intl: 'en-US',\n        fallbackScore: 9.6,\n        fallbackCount: 1768,\n        text: function (score, count) {\n          return 'Rated <strong>' + score + '</strong> by <strong>' + count + '</strong> customers.';\n        }\n      },\n      de: {\n        url: 'https://www.valuedshops.de/webshop/ByMetz-Tassen-Koffers_1205113/bewertungen',\n        intl: 'de-DE',\n        fallbackScore: 9.6,\n        fallbackCount: 1768,\n        text: function (score, count) {\n          return 'Bewertet mit <strong>' + score + '</strong> von <strong>' + count + '</strong> Kunden.';\n        }\n      },\n      fr: {\n        url: 'https://www.valuedshops.fr/boutique/ByMetz-Tassen-Koffers_1205113/avis',\n        intl: 'fr-FR',\n        fallbackScore: 9.6,\n        fallbackCount: 1768,\n        text: function (score, count) {\n          return 'Noté <strong>' + score + '</strong> par <strong>' + count + '</strong> clients.';\n        }\n      },\n      es: {\n        url: 'https://www.valuedshops.com/spa/webshop/ByMetz-Tassen-Koffers_1205113/reviews',\n        intl: 'es-ES',\n        fallbackScore: 9.6,\n        fallbackCount: 1768,\n        text: function (score, count) {\n          return 'Calificado con <strong>' + score + '</strong> por <strong>' + count + '</strong> clientes.';\n        }\n      },\n      it: {\n        url: 'https://www.valuedshops.com/ita/webshop/ByMetz-Tassen-Koffers_1205113/reviews',\n        intl: 'it-IT',\n        fallbackScore: 9.6,\n        fallbackCount: 1768,\n        text: function (score, count) {\n          return 'Valutato <strong>' + score + '</strong> da <strong>' + count + '</strong> clienti.';\n        }\n      }\n    };\n\n    var active = config[locale] || config.nl;\n    var bar = document.querySelector('[data-bm-reviewbar]');\n    if (!bar) return;\n\n    function clamp(num, min, max) {\n      return Math.min(Math.max(num, min), max);\n    }\n\n    function formatScore(score, localeCode) {\n      return new Intl.NumberFormat(localeCode, {\n        minimumFractionDigits: 1,\n        maximumFractionDigits: 1\n      }).format(score);\n    }\n\n    function formatCount(count, localeCode) {\n      return new Intl.NumberFormat(localeCode).format(count);\n    }\n\n    function normalizeTo10Scale(rawValue) {\n      var raw = Number(rawValue);\n      if (!isFinite(raw)) return null;\n      if (raw <= 5.05) return raw * 2;\n      return raw;\n    }\n\n    function setTrustpilotStars(scoreOutOf10) {\n      var fills = bar.querySelectorAll('[data-bm-star-fill]');\n      var scoreOutOf5 = clamp((Number(scoreOutOf10) || 0) / 2, 0, 5);\n\n      fills.forEach(function (fillEl, index) {\n        var fillAmount = clamp(scoreOutOf5 - index, 0, 1);\n        fillEl.style.width = (fillAmount * 100) + '%';\n      });\n    }\n\n    function render(scoreOutOf10, reviewCount) {\n      var textEl = bar.querySelector('[data-bm-review-text]');\n      var safeScore = clamp(Number(scoreOutOf10) || 0, 0, 10);\n      var safeCount = Math.max(0, Number(reviewCount) || 0);\n\n      bar.href = active.url;\n      textEl.innerHTML = active.text(\n        formatScore(safeScore, active.intl),\n        formatCount(safeCount, active.intl)\n      );\n      setTrustpilotStars(safeScore);\n      bar.setAttribute('aria-label', textEl.textContent.replace(/\\s+/g, ' ').trim());\n    }\n\n    render(active.fallbackScore, active.fallbackCount);\n\n    if (!publicCode) return;\n\n    var endpoint =\n      'https://dashboard.webwinkelkeur.nl/api/1.0/ratings_summary.json?id=' +\n      encodeURIComponent(shopId) +\n      '&public_code=' +\n      encodeURIComponent(publicCode);\n\n    fetch(endpoint, { method: 'GET' })\n      .then(function (response) {\n        if (!response.ok) throw new Error('HTTP ' + response.status);\n        return response.json();\n      })\n      .then(function (payload) {\n        var rawAverage = Number(payload && payload.data && payload.data.rating_average);\n        var amount = Number(payload && payload.data && payload.data.amount);\n        var liveScore = normalizeTo10Scale(rawAverage);\n\n        if (!isFinite(liveScore) || !isFinite(amount)) {\n          throw new Error('Invalid API response');\n        }\n\n        render(liveScore, amount);\n      })\n      .catch(function (error) {\n        console.warn('ByMetz review bar fallback actief:', error);\n      });\n  })();\n</script>"
