    "section_custom_liquid_6xyzG4": {
      "type": "section-custom-liquid",
      "name": "t:sections.custom_liquid.presets.name",
      "settings": {
        "custom_liquid": "{%- comment -%}\nByMetz SEO Intro Block (zonder FAQ)\n- Assortiment knop -> https://bymetz.nl/collections/all?sort_by=created-descending\n- Route knop -> Google Maps routebeschrijving met bestemming vooraf ingevuld (api=1)\n- Subtiele highlight alleen op \"ByMetz\" (#EA6C44)\n- Collectie-links met sort_by=created-descending (nieuwste eerst)\n- Chip volgorde: Handtassen & schoudertassen, Koffers, Reistassen, Rugzakken, Schooltassen, Laptoptassen\n{%- endcomment -%}\n\n{%- assign base_url = shop.url | default: request.origin -%}\n\n{%- assign url_all_sorted   = 'https://bymetz.nl/collections/all?sort_by=created-descending' -%}\n{%- assign url_tassen       = 'https://bymetz.nl/collections/tassen?sort_by=created-descending' -%}\n{%- assign url_koffers      = 'https://bymetz.nl/collections/koffers?sort_by=created-descending' -%}\n{%- assign url_reistassen   = 'https://bymetz.nl/collections/reistassen?sort_by=created-descending' -%}\n{%- assign url_rugzakken    = 'https://bymetz.nl/collections/rugzakken?sort_by=created-descending' -%}\n{%- assign url_schooltassen = 'https://bymetz.nl/collections/schooltassen?sort_by=created-descending' -%}\n{%- assign url_laptoptassen = 'https://bymetz.nl/collections/laptoptassen?sort_by=created-descending' -%}\n\n{%- comment -%}\nGoogle Maps Directions URL (api=1) – opent routebeschrijving met bestemming ingevuld.\n{%- endcomment -%}\n{%- assign maps_directions_url = 'https://www.google.com/maps/dir/?api=1&destination=ByMetz.nl%20-%20Tassen%20%26%20Koffers%2C%20Winkelcentrum%20Woensel%2059%2C%205625%20AD%20Eindhoven&travelmode=driving' -%}\n\n{%- comment -%} Fix voor SearchAction (curly braces apart) {%- endcomment -%}\n{%- assign search_target = base_url | append: '/search?q=' | append: '{search_term_string}' -%}\n{%- assign store_name = shop.name | default: 'ByMetz' -%}\n{%- assign store_description = 'Tassenwinkel in Eindhoven (Winkelcentrum Woensel 59, 5625 AD) met tassen, koffers en reistassen. Familiebedrijf met persoonlijk advies en online bestellen.' -%}\n\n<section class=\"bymetz-seo\" aria-labelledby=\"bymetz-seo-title\">\n  <header class=\"bymetz-seo__header\">\n    <h2 id=\"bymetz-seo-title\" class=\"bymetz-seo__title\">\n      Tassen kopen in Eindhoven? Ontdek <span class=\"bymetz-seo__hl\">ByMetz</span> in Winkelcentrum Woensel\n    </h2>\n\n    <p class=\"bymetz-seo__lead\">\n      <strong>ByMetz</strong> is dé <strong>tassenwinkel in Eindhoven</strong> voor <strong>tassen</strong>, <strong>koffers</strong> en <strong>reistassen</strong>.\n      Al meer dan <strong>50 jaar</strong> helpen we je met <strong>persoonlijk advies</strong> en een assortiment voor werk, school en reizen.\n    </p>\n  </header>\n\n  <nav class=\"bymetz-seo__quicklinks\" aria-label=\"Snelle links naar categorieën\">\n    <a class=\"bymetz-seo__chip\" href=\"{{ url_tassen }}\">Handtassen & schoudertassen</a>\n    <a class=\"bymetz-seo__chip\" href=\"{{ url_koffers }}\">Koffers</a>\n    <a class=\"bymetz-seo__chip\" href=\"{{ url_reistassen }}\">Reistassen</a>\n    <a class=\"bymetz-seo__chip\" href=\"{{ url_rugzakken }}\">Rugzakken</a>\n    <a class=\"bymetz-seo__chip\" href=\"{{ url_schooltassen }}\">Schooltassen</a>\n    <a class=\"bymetz-seo__chip\" href=\"{{ url_laptoptassen }}\">Laptoptassen</a>\n  </nav>\n\n  <div class=\"bymetz-seo__grid\">\n    <div class=\"bymetz-seo__col\">\n      <h3 class=\"bymetz-seo__h3\">Shoppen in Eindhoven (Woensel)</h3>\n      <p class=\"bymetz-seo__text\">\n        Kom je liever in het echt vergelijken? In onze winkel in <strong>Winkelcentrum Woensel</strong> kun je rustig passen, voelen en kiezen.\n        Of je nu een <strong>handtas</strong>, <strong>koffer</strong>, <strong>reistas</strong>, <strong>rugzak</strong>, <strong>schooltas</strong> of <strong>laptoptas</strong> zoekt:\n        je krijgt eerlijk advies en je ziet direct wat het beste bij je past.\n      </p>\n      <p class=\"bymetz-seo__text\">\n        Je shopt bij ons overzichtelijk en comfortabel — met veel keuze, snelle vergelijking en hulp als je twijfelt.\n      </p>\n\n      <h3 class=\"bymetz-seo__h3\">Voor werk, school en reizen</h3>\n      <ul class=\"bymetz-seo__list\">\n        <li><strong>Handtassen</strong> & <strong>schoudertassen</strong> voor elke stijl</li>\n        <li><strong>Koffers</strong>: van handbagage tot grote reiskoffers</li>\n        <li><strong>Reistassen</strong> voor weekendjes weg en vakantie</li>\n        <li><strong>Rugzakken</strong> & <strong>schooltassen</strong> voor dagelijks gebruik</li>\n        <li><strong>Laptoptassen</strong> & werktassen voor bescherming en comfort</li>\n      </ul>\n    </div>\n\n    <div class=\"bymetz-seo__col\">\n      <h3 class=\"bymetz-seo__h3\">24/7 online bestellen</h3>\n      <p class=\"bymetz-seo__text\">\n        Liever direct shoppen? Online kun je snel en eenvoudig <strong>tassen, koffers en reistassen bestellen</strong>.\n        Bekijk het assortiment en ontdek wat er net binnen is gekomen.\n      </p>\n\n      <h3 class=\"bymetz-seo__h3\">Waarom ByMetz?</h3>\n      <p class=\"bymetz-seo__text\">\n        Je krijgt service zoals je die van een echt <strong>familiebedrijf</strong> mag verwachten.\n        We helpen je met maat, indeling, materiaal en gebruik — zodat je met een keuze naar huis gaat waar je lang plezier van hebt.\n      </p>\n\n      <div class=\"bymetz-seo__cta\">\n        <a class=\"bymetz-seo__btn bymetz-seo__btn--primary\" href=\"{{ url_all_sorted }}\">\n          Bekijk het assortiment\n        </a>\n        <a class=\"bymetz-seo__btn bymetz-seo__btn--ghost\" href=\"{{ maps_directions_url | escape }}\" target=\"_blank\" rel=\"noopener\">\n          Route naar de winkel (Google Maps)\n        </a>\n      </div>\n    </div>\n  </div>\n</section>\n\n<style>\n  .bymetz-seo{ max-width:1100px; margin:0 auto; padding:26px 16px; }\n  .bymetz-seo__title{ text-align:center; font-weight:950; line-height:1.12; margin:0 0 14px; font-size:clamp(24px,3vw,40px); letter-spacing:-0.015em; }\n\n  /* subtiele highlight alleen op \"ByMetz\" */\n  .bymetz-seo__hl{ position:relative; display:inline-block; font-weight:950; padding:0 .08em; }\n  .bymetz-seo__hl::after{ content:\"\"; position:absolute; left:-.08em; right:-.08em; bottom:.10em; height:.42em; background:rgba(234,108,68,.22); border-radius:.45em; z-index:-1; }\n  .bymetz-seo__hl::before{ content:\"\"; position:absolute; left:-.05em; right:-.05em; bottom:.04em; height:2px; background:#EA6C44; border-radius:99px; opacity:.65; z-index:-1; }\n\n  .bymetz-seo__lead{ text-align:center; margin:0 auto 10px; max-width:920px; line-height:1.7; font-size:1.06em; }\n\n  .bymetz-seo__quicklinks{ display:flex; flex-wrap:wrap; gap:10px; justify-content:center; margin:14px 0 22px; }\n  .bymetz-seo__chip{ display:inline-block; padding:10px 14px; border:1px solid rgba(0,0,0,.15); border-radius:999px; text-decoration:none; line-height:1; white-space:nowrap; }\n\n  .bymetz-seo__grid{ display:grid; gap:22px; grid-template-columns:1fr 1fr; align-items:start; }\n\n  .bymetz-seo__h3{ margin:0 0 10px; font-weight:900; line-height:1.25; font-size:1.15em; }\n  .bymetz-seo__text{ margin:0 0 14px; line-height:1.75; }\n  .bymetz-seo__list{ margin:0; padding-left:18px; line-height:1.8; }\n\n  .bymetz-seo__cta{ display:flex; flex-wrap:wrap; gap:10px; margin-top:16px; }\n\n  .bymetz-seo__btn{\n    display:inline-block;\n    padding:12px 16px;\n    border-radius:12px;\n    text-decoration:none !important;\n    font-weight:850;\n    border:1px solid rgba(0,0,0,.18);\n    line-height:1.2;\n  }\n\n  /* Fix: tekst mag NIET verdwijnen bij hover/visited/focus */\n  .bymetz-seo__btn--primary,\n  .bymetz-seo__btn--primary:visited,\n  .bymetz-seo__btn--primary:hover,\n  .bymetz-seo__btn--primary:focus,\n  .bymetz-seo__btn--primary:active{\n    background:#C4512B;\n    border-color:#C4512B;\n    color:#fff !important;\n    opacity:1 !important;\n  }\n\n  .bymetz-seo__btn--ghost{ background:transparent; }\n  .bymetz-seo__btn--ghost:hover,\n  .bymetz-seo__btn--ghost:focus{\n    opacity:1 !important;\n  }\n\n  @media (max-width: 900px){\n    .bymetz-seo__grid{ grid-template-columns: 1fr; }\n  }\n</style>\n\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@graph\": [\n    {\n      \"@type\": \"WebSite\",\n      \"@id\": {{ base_url | append: \"#website\" | json }},\n      \"url\": {{ base_url | json }},\n      \"name\": {{ store_name | json }},\n      \"inLanguage\": \"nl-NL\",\n      \"potentialAction\": {\n        \"@type\": \"SearchAction\",\n        \"target\": {{ search_target | json }},\n        \"query-input\": \"required name=search_term_string\"\n      }\n    },\n    {\n      \"@type\": \"Store\",\n      \"@id\": {{ base_url | append: \"#store\" | json }},\n      \"name\": {{ store_name | json }},\n      \"url\": {{ base_url | json }},\n      \"inLanguage\": \"nl-NL\",\n      \"areaServed\": \"NL\",\n      \"description\": {{ store_description | json }},\n      \"hasMap\": {{ maps_directions_url | json }},\n      \"telephone\": {{ shop.phone | default: \"\" | json }},\n      \"email\": {{ shop.email | default: \"\" | json }},\n      \"address\": {\n        \"@type\": \"PostalAddress\",\n        \"streetAddress\": \"Winkelcentrum Woensel 59\",\n        \"postalCode\": \"5625 AD\",\n        \"addressLocality\": \"Eindhoven\",\n        \"addressRegion\": \"Noord-Brabant\",\n        \"addressCountry\": \"NL\"\n      }\n    }\n  ]\n}\n</script>",
        "spacing_desktop": 50,
        "spacing_mobile": 30,
        "fix_zindex": 0
      }
