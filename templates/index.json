      "settings": {
        "custom_liquid": "<div class=\"bymetz-hours\">\n  <h3 class=\"bymetz-hours__title\">Openingstijden winkel ByMetz Eindhoven</h3>\n\n  <div class=\"bymetz-hours__center\">\n    <table class=\"bymetz-hours__table\" aria-label=\"Openingstijden winkel\">\n      <thead>\n        <tr>\n          <th scope=\"col\">Dag</th>\n          <th scope=\"col\">Openingstijden</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr><td>Maandag</td><td>12:00 – 17:30</td></tr>\n        <tr><td>Dinsdag</td><td>10:00 – 17:30</td></tr>\n        <tr><td>Woensdag</td><td>10:00 – 17:30</td></tr>\n        <tr><td>Donderdag</td><td>10:00 – 17:30</td></tr>\n        <tr><td>Vrijdag</td><td>10:00 – 20:00</td></tr>\n        <tr><td>Zaterdag</td><td>10:00 – 17:00</td></tr>\n        <tr>\n          <td>Zondag</td>\n          <td>\n            12:00 – 17:00\n            <div class=\"bymetz-hours__note\">Let op: eerste en laatste zondag van de maand.</div>\n          </td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n</div>\n\n<style>\n  .bymetz-hours{\n    width: 100%;\n    padding: 0 16px;           /* altijd ruimte links/rechts zodat rand zichtbaar blijft */\n    box-sizing: border-box;\n  }\n\n  .bymetz-hours__title{\n    margin: 0 0 12px 0;\n    text-align: center;\n    font-weight: 700;\n    font-size: 22px;\n    line-height: 1.2;\n  }\n\n  /* Center wrapper: altijd perfect midden */\n  .bymetz-hours__center{\n    display: flex;\n    justify-content: center;\n    width: 100%;\n  }\n\n  /* BELANGRIJK: override theme table styles die scrollbars veroorzaken */\n  .bymetz-hours__table{\n    display: table !important;     /* voorkomt display:block + overflow scroll */\n    overflow: visible !important;\n    width: fit-content;            /* blok zo breed als inhoud */\n    max-width: 100%;\n    border-collapse: collapse;\n    background: #fff;\n    border: 1px solid rgba(0,0,0,.18); /* duidelijke rechthoek */\n    box-sizing: border-box;\n  }\n\n  .bymetz-hours__table thead th{\n    text-align: left;\n    font-weight: 700;\n    padding: 12px 16px;\n    background: #f4f4f4;\n    border-bottom: 1px solid rgba(0,0,0,.12);\n  }\n\n  .bymetz-hours__table tbody td{\n    padding: 12px 16px;\n    border-bottom: 1px solid rgba(0,0,0,.08);\n    vertical-align: top;\n  }\n\n  .bymetz-hours__table tbody tr:last-child td{\n    border-bottom: 0;\n  }\n\n  /* tijden mogen niet afbreken */\n  .bymetz-hours__table td:nth-child(2){\n    white-space: nowrap;\n  }\n\n  .bymetz-hours__note{\n    margin-top: 6px;\n    font-weight: 700;\n    font-size: 0.95em;\n    white-space: normal;\n  }\n\n  @media (max-width: 600px){\n    .bymetz-hours{ padding: 0 14px; }\n    .bymetz-hours__title{ font-size: 20px; }\n\n    .bymetz-hours__table thead th,\n    .bymetz-hours__table tbody td{\n      padding: 10px 12px;\n      font-size: 14px;\n    }\n  }\n</style>",
