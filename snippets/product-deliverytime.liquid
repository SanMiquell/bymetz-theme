{%- liquid
  assign current_variant = current_variant | default: product.selected_or_first_available_variant
  assign no_margin = no_margin | default: false
  assign extra_class = extra_class | default: false
  assign container = container | default: "p"
  assign shopify_attributes = shopify_attributes | default: false
  assign stock = settings.product_stock
  assign show_stock = true
  if stock == 'none'
    assign show_stock = false
  endif
  assign hide_deliverytime = hide_deliverytime | default: false
  assign total_stock = 0
  assign bold = true
  if origin == 'productpage'

    if stock == false
      assign list_layout = true
    endif
  elsif origin == 'productitem'
    for variant in product.variants
      if variant.matched and variant.inventory_quantity > 0
        assign total_stock = total_stock | plus: variant.inventory_quantity
      endif
    endfor
  endif
  if total_stock == 0
    assign total_stock = current_variant.inventory_quantity
  endif
-%}
{%- if settings.product_deliverytime_in_stock or settings.product_deliverytime_not_in_stock -%}
  {%- liquid
    if hide_deliverytime
      assign deliverytime_in_stock = empty
      assign deliverytime_not_in_stock = empty
    else
      assign deliverytime_in_stock_metafields_namespace = settings.product_deliverytime_in_stock | split: '.' | first
      assign deliverytime_in_stock_metafields_key = settings.product_deliverytime_in_stock | split: '.' | last
      assign deliverytime_not_in_stock_metafields_namespace = settings.product_deliverytime_not_in_stock | split: '.' | first
      assign deliverytime_not_in_stock_metafields_key = settings.product_deliverytime_not_in_stock | split: '.' | last
      assign deliverytime_in_stock = product.metafields[deliverytime_in_stock_metafields_namespace][deliverytime_in_stock_metafields_key]
      assign deliverytime_not_in_stock = product.metafields[deliverytime_not_in_stock_metafields_namespace][deliverytime_not_in_stock_metafields_key]
      unless deliverytime_in_stock
        assign deliverytime_in_stock = settings.default_product_deliverytime_in_stock
      endunless
      unless deliverytime_not_in_stock
        assign deliverytime_not_in_stock = settings.default_product_deliverytime_not_in_stock
      endunless

      assign deliverytime_info_metafields_namespace = settings.product_deliverytime_info | split: '.' | first
      assign deliverytime_info_metafields_key = settings.product_deliverytime_info | split: '.' | last
      assign deliverytime_info = product.metafields[deliverytime_info_metafields_namespace][deliverytime_info_metafields_key]
      unless deliverytime_info
        assign deliverytime_info = settings.default_product_deliverytime_info
      endunless
    endif

    if current_variant.inventory_management == 'shopify'
      assign inventory_tracking = true
      if show_stock
        assign show = true
      elsif total_stock > 0 and deliverytime_in_stock != empty
        assign show = true
      elsif total_stock <= 0 and deliverytime_not_in_stock != empty
        assign show = true
      endif
    elsif deliverytime_in_stock != empty and settings.show_deliverytime_always
      assign show = true
      assign inventory_tracking = false
      assign show_stock = false
    endif
    if total_stock > settings.show_product_stock_qty and settings.show_product_stock_always == false and stock == 'available_stock'
      assign show_stock = false
    endif
  -%}
{%- endif -%}
{%- if show -%}
  {%- if extra_element -%}{{ extra_element }}{%- endif -%}
  {%- if origin == 'productitem' -%}
    {%- comment -%} Product card: two-line delivery matching bm-delivery-status {%- endcomment -%}
    {%- liquid
      assign bm_lang = request.locale.iso_code | default: localization.language.iso_code | default: shop.locale | default: 'nl'
      assign bm_lang = bm_lang | downcase | split: '-' | first
      if bm_lang == 'en'
        assign bm_stock_label = 'In stock in the webshop & store'
        assign bm_nostock_label = 'Out of stock'
      elsif bm_lang == 'de'
        assign bm_stock_label = 'Auf Lager'
        assign bm_nostock_label = 'Nicht auf Lager'
      elsif bm_lang == 'fr'
        assign bm_stock_label = 'En stock'
        assign bm_nostock_label = 'Rupture de stock'
      elsif bm_lang == 'es'
        assign bm_stock_label = 'En stock'
        assign bm_nostock_label = 'Agotado'
      elsif bm_lang == 'it'
        assign bm_stock_label = 'Disponibile'
        assign bm_nostock_label = 'Non disponibile'
      else
        assign bm_stock_label = 'Beschikbaar in webshop & winkel'
        assign bm_nostock_label = 'Niet op voorraad'
      endif
    -%}
    {%- if total_stock > 0 or inventory_tracking == false -%}
      <div class="bm-delivery-card {{ extra_class }}">
        <svg class="bm-delivery-card__icon bm-delivery-card__icon--ok" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
          <path d="M10 2a8 8 0 1 1 0 16 8 8 0 0 1 0-16zm3.36 5.22a.75.75 0 0 0-1.06.04L9.4 10.6 7.7 8.9a.75.75 0 1 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.08-.02l3.43-3.91a.75.75 0 0 0-.04-1.06z" fill="currentColor"/>
        </svg>
        <div class="bm-delivery-card__text">
          <span class="bm-delivery-card__label bm-delivery-card__label--ok">{{ bm_stock_label }}</span>
          {%- if deliverytime_in_stock != empty -%}
            <span class="bm-delivery-card__detail">{{ deliverytime_in_stock }}</span>
          {%- endif -%}
        </div>
      </div>
    {%- elsif inventory_tracking -%}
      <div class="bm-delivery-card {{ extra_class }}">
        <svg class="bm-delivery-card__icon bm-delivery-card__icon--warn" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
          <circle cx="10" cy="10" r="8" fill="currentColor"/>
          <path d="M10 6v5M10 13v1" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <div class="bm-delivery-card__text">
          <span class="bm-delivery-card__label bm-delivery-card__label--warn">{{ bm_nostock_label }}</span>
          {%- if deliverytime_not_in_stock != empty -%}
            <span class="bm-delivery-card__detail">{{ deliverytime_not_in_stock }}</span>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  {%- else -%}
    {%- comment -%} Non-card contexts: keep original rendering {%- endcomment -%}
    {%- if total_stock > 0 or inventory_tracking == false -%}
      <{{ container }} class="stock {% if list_layout %}l4ch{% endif %} {{ extra_class }} {% if no_margin %}m0{% endif %}" {% if shopify_attributes %}{{ shopify_attributes }}{% endif %}>
        <span class="{% if show_stock and deliverytime_in_stock == empty and bold %}overlay-valid{% endif %}">
          {% if show_stock %}
            {% if stock == 'available_stock' %}
              {{ 'product.form.in_stock_amount' | t: amount: total_stock }}
            {% elsif stock == 'stock' %}
              {{ 'product.form.in_stock' | t }}
            {% endif %}
          {% endif %}
          {%- if deliverytime_in_stock != empty -%}
            <span class="overlay-valid{% if bold %}{% endif %}">
              {{ deliverytime_in_stock }}
            </span>
          {%- endif -%}
        </span>
        {%- if deliverytime_in_stock != empty and deliverytime_info != empty -%}&nbsp;<span class="s1tt"><span>{{ deliverytime_info | replace: '</p><p>', '<br>' | remove: '<p>' | remove: '</p>' | remove: '<h1>' | remove: '</h1>' | remove: '<h2>' | remove: '</h2>' | remove: '<h3>' | remove: '</h3>' | remove: '<h4>' | remove: '</h4>' | remove: '<h5>' | remove: '</h5>' | remove: '<h6>' | remove: '</h6>' }}</span></span>{%- endif -%}
      </{{ container }}>
    {%- elsif inventory_tracking -%}
      <{{ container }} class="stock {{ extra_class }} {% if no_margin %}m0{% endif %}" {% if shopify_attributes %}{{ shopify_attributes }}{% endif %}>
        <span class="{% if show_stock and deliverytime_not_in_stock == empty and bold %}overlay-error{% endif %}">
          {% if show_stock %}{{ 'product.form.not_in_stock' | t }} {% endif %}
          {%- if deliverytime_not_in_stock != empty -%}
            <span class="overlay-error{% if bold %}{% endif %}">
              {{ deliverytime_not_in_stock }}
            </span>
          {%- endif -%}
        </span>
        {%- if deliverytime_not_in_stock != empty and deliverytime_info != empty -%}&nbsp;<span class="s1tt"><span>{{ deliverytime_info | replace: '</p><p>', '<br>' | remove: '<p>' | remove: '</p>' | remove: '<h1>' | remove: '</h1>' | remove: '<h2>' | remove: '</h2>' | remove: '<h3>' | remove: '</h3>' | remove: '<h4>' | remove: '</h4>' | remove: '<h5>' | remove: '</h5>' | remove: '<h6>' | remove: '</h6>' }}</span></span>{%- endif -%}
      </{{ container }}>
    {%- endif -%}
  {%- endif -%}
{%- endif -%}

{%- if origin == 'productitem' and show -%}
<style>
  .bm-delivery-card {
    display: flex;
    align-items: flex-start;
    gap: 5px;
    margin: 4px 0 6px;
    line-height: 1.3;
  }
  .bm-delivery-card__icon {
    width: 17px;
    height: 17px;
    min-width: 17px;
    flex: 0 0 auto;
    margin-top: 1px;
  }
  .bm-delivery-card__icon--ok {
    color: #008000;
  }
  .bm-delivery-card__icon--warn {
    color: #ea6c44;
  }
  .bm-delivery-card__text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .bm-delivery-card__label {
    font-size: 14px;
    font-weight: 600;
  }
  .bm-delivery-card__label--ok {
    color: #008000;
  }
  .bm-delivery-card__label--warn {
    color: #ea6c44;
  }
  .bm-delivery-card__detail {
    font-size: 12px;
    color: #1f1f1f;
  }
</style>
{%- endif -%}