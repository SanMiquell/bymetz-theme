{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{%- liquid
  assign container = 'li'
  assign placeholder_int = placeholder_int | default: 1
  assign width_class = width_class | default: ''
  assign sizes = sizes | default: false
  assign slider = slider | default: false
  assign type = type | default: 'grid'
  assign no_lazyload = no_lazyload | default: false
  assign enable_bulk = enable_bulk | default: false
  assign popup = popup | default: false
  assign extra_style = extra_style | default: ''
  assign shopify_attributes = shopify_attributes | default: ''
  assign next_to_products = next_to_products | default: false
  assign animate = animate | default: false
  assign index = index | default: 0

  if fill_images == nil
    assign fill_images = settings.fill_product_images
  endif
  if fill_first_image == nil
    assign fill_first_image = fill_images
    if fill_images and settings.fill_not_first
      assign fill_first_image = false
    endif
  endif
  if quick_buy_compact == nil
    assign quick_buy_compact = false
  endif
  if enable_quick_buy_drawer == nil
    if settings.layout_productcard == 'quickshop'
      assign enable_quick_buy_drawer = true
    else
      assign enable_quick_buy_drawer = false
    endif
  endif
  if enable_quick_buy_desktop == nil
    assign enable_quick_buy_desktop = true
  endif
  if enable_quick_buy_mobile == nil
    assign enable_quick_buy_mobile = true
  endif
  if enable_quick_buy_qty_selector == nil
    assign enable_quick_buy_qty_selector = false
  endif
  if enable_variant_picker == nil
    assign enable_variant_picker = true
  endif
  if enable_color_picker == nil
    assign enable_color_picker = settings.show_color_swatches
  endif
  if show_image == nil
    assign show_image = true
    assign show_labels = true
    assign show_title = true
    assign show_price = true
    assign show_stock = true
    assign show_vendor = settings.show_vendor
    assign show_delivery_time = settings.show_delivery_time
    assign show_rating = settings.show_product_rating
  endif
  assign require_login = false
  if settings.login_for_prices and customer == nil
    assign require_login = true
    assign show_price = false
  endif
  if layout == 'list-compact' and origin != 'complementary'
    assign show_labels = false
    assign show_stock = false
    assign show_vendor = false
    assign show_rating = false
  endif
  if layout == 'hotspot'
    assign show_image = true
    assign container = 'li'
    if product.variants.size > 1 or product.available == false
      assign enable_quick_buy_drawer = true
    endif
  endif
  assign inline_variantpicker = false
  assign current_variant = product.selected_or_first_available_variant
  if custom_height_ratio == nil
    assign custom_height_ratio = settings.custom_product_image_ratio
  endif
  assign custom_height_ratio = custom_height_ratio | divided_by: 100.0
  assign image_width = 430
  assign image_height = image_width | times: custom_height_ratio | round
  assign image_width_2 = image_width | times: 1.5
  assign image_height_2 = image_height | times: 1.5
  assign image_width_small = image_width | divided_by: 3
  assign image_height_small = image_height | divided_by: 3
  if product == blank
    assign vendor = "Vendor name"
    assign title =  "Product title"
    assign price =  0 | money
    assign short_description = 'This is the short product description. Highlight key features and benefits here briefly.'
  else
    assign vendor = product.vendor
    assign title = product.title
    if layout == 'list-compact'
      assign price = current_variant.price
    else
      assign price = product.price
    endif
  endif
  assign total_stock = 0
  for variant in product.variants
    if variant.matched and variant.inventory_quantity > 0
      assign total_stock = total_stock | plus: variant.inventory_quantity
    endif
  endfor
  if total_stock <= 0
    assign total_stock = current_variant.inventory_quantity
  endif
  if total_stock <= 0 and current_variant.inventory_management != nil and current_variant.inventory_policy == 'continue' and current_variant.available and current_variant.inventory_quantity <= 0 and settings.preorder
    assign preorder = true
    unless settings.show_preorder_inventory
      assign show_stock = false
    endunless
  endif
  assign static_color_picker = false
  if settings.layout_productcard == 'variant_picker' or settings.layout_productcard == 'quickshop' or settings.layout_productcard contains 'add_to_cart'
    assign static_color_picker = true
  elsif settings.color_swatch_behavior == 'static' and settings.layout_productcard == 'standard'
    assign static_color_picker = true
  endif
  assign overlay_static = false
  if settings.quickshop_behavior == 'static'
    if settings.layout_productcard == 'quickshop' or settings.layout_productcard contains 'add_to_cart'
      assign overlay_static = true
    endif
  elsif settings.color_swatch_behavior == 'static' and settings.layout_productcard == 'standard'
    assign overlay_static = true
  endif
  assign collection_page = false
  if origin == 'collection' or origin == 'search'
    assign collection_page = true
  endif
  assign quickshop = false
  if settings.layout_productcard == 'quickshop'
    assign quickshop = true
  elsif settings.layout_productcard != 'standard'
    if layout == 'list' or layout == 'grid'
      assign quickshop = true
    endif
  endif
  assign fixed_text_alignment_left = false
  if layout == 'list'
    assign fixed_text_alignment_left = true
  endif
  if settings.enable_compare and settings.compare_checkboxes_productcards != 'none'
    if settings.compare_checkboxes_productcards == 'collection' and collection_page == false
      assign show_compare_checkbox = false
    elsif show_compare_checkbox != false
      assign show_compare_checkbox = true
    endif
  endif

  assign color_triggers = settings.color_swatch_name | newline_to_br | strip_newlines | replace: '<br />', '|' | split: '|'
  assign color_option = false
  if enable_color_picker
    if settings.enable_color_swatches
      for option in product.options_with_values
        if color_triggers contains option.name
          assign color_option = option
          break
        endif
      endfor
    endif
    assign colors_size = color_option.values | size
    if settings.color_swatches_single and colors_size < 2
      assign color_option = false
    endif
  endif

  assign size_triggers = settings.variant_picker_name | newline_to_br | strip_newlines | replace: '<br />', '|' | split: '|'
  assign size_option = false
  if settings.layout_productcard == 'variant_picker'
    for option in product.options_with_values
      if size_triggers contains option.name
        assign size_option = option
        assign size_option_index = forloop.index0
        break
      endif
    endfor
  endif

  if settings.productcard_show_unavailable_variants
    assign available_variants = product.variants
  else
    assign available_variants = product.variants | where: "available"
  endif

  assign rating_value = false
  assign rating_count = false
  if product.metafields.syncer.reviews
    assign locale_ratings = product.metafields.syncer.reviews.value.reviews[localization.language.iso_code]
    if locale_ratings
      assign rating_value = locale_ratings.rating
      assign rating_count = locale_ratings.count
    else
      assign rating_value = product.metafields.syncer.reviews.value.cumulative_rating
      assign rating_count = product.metafields.syncer.reviews.value.total_reviews
    endif
  elsif product.metafields.reviews.rating
    assign rating_value = product.metafields.reviews.rating.value
    assign rating_count = product.metafields.reviews.rating_count
  endif
-%}

{%- capture quickshop_circle_button -%}
  {%- if product.available and product.variants.size == 1 and require_login == false -%}
    {%- liquid
      assign form_shown = false
      if enable_quick_buy_desktop or enable_quick_buy_mobile
        if layout != 'hotspot' and layout != 'list-compact' and layout != 'list' and layout != 'grid' and settings.layout_productcard == 'add_to_cart' and product.id
          if available_variants.size > 1 or preorder
            assign form_shown = true
          elsif available_variants.size == 1 and current_variant.available
            assign form_shown = true
          endif
        elsif settings.layout_productcard == 'variant_picker' and size_option
          assign form_shown = true
        endif
      endif
      assign product_form_id = 'quick-add-one-click-' | append: section.id | append: product.id
      assign product_form_class = 'list-hide visible form-card align-stretch quick-add-one-click-form'
      if form_shown and layout != 'grid'
        assign product_form_class = product_form_class | append: ' mobile-only'
      endif
    -%}
    {%- form 'product', product, id: product_form_id, class: product_form_class, novalidate: 'novalidate' -%}
      <fieldset>
        <input type="hidden" name="id" value="{{ current_variant.id }}">
        {% liquid
          assign visible = false
          if settings.quickshop_behavior == 'static' and layout != 'list'
            assign visible = true
          endif
          if settings.layout_productcard contains 'add_to_cart' and settings.quickshop_position == 'above' and settings.quickshop_behavior != 'static'
            assign visible = true
          endif
        %}
        <p class="link-btn {% if visible %}visible{% endif %}{% unless layout == 'list' %} {% if layout == 'grid' %}mobile-{% endif %}text-end{% endunless %} quickshop">
          <button type="submit" class="circle {% if preorder %}overlay-preorder{% else %}overlay-buy_button{% endif %}{% if settings.buy_button_style == 'inv' %} inv{% endif %}" aria-label="{% if preorder %}{{ settings.preorder_button_text }}{% else %}{{ 'product.form.add_to_cart' | t }}{% endif %}" style="--size: 32px;">
            <i aria-hidden="true" class="icon-{% if settings.plus_icon_no_cart %}plus{% else %}cart{% endif %}" aria-label="{{ 'product.form.add_to_cart' | t }}"></i> <span class="hidden">{{ 'product.form.add_to_cart' | t }}</span>
          </button>
        </p>
      </fieldset>
    {%- endform -%}
  {%- else -%}
    <p class="link-btn quickshop {% unless product.available %}mobile-hide{% endunless %} list-hide class-x">
      {%- if require_login -%}
        <a href="{{ routes.account_login_url }}" class="circle m0 overlay-buy_button{% if settings.buy_button_style == 'inv' %} inv{% endif %}"  aria-label="{{ 'customer.login.login_for_prices_html' | t | strip_html }}" style="--size: 32px;"><i aria-hidden="true" class="icon-user"></i> <span class="hidden">{{ 'customer.login.login_for_prices_html' | t | strip_html }}</span></a>
      {%- else -%}
        <a href="{{ product.url }}" class="circle m0 overlay-buy_button{% if settings.buy_button_style == 'inv' %} inv{% endif %}" data-quickshop data-product="{{ product.id }}" aria-label="{{ 'product.form.add_to_cart' | t }}" style="--size: 32px;"><i aria-hidden="true" class="icon-{% if settings.plus_icon_no_cart %}plus{% else %}cart{% endif %}"></i> <span class="hidden">{{ 'product.form.add_to_cart' | t }}</span></a>
      {%- endif -%}
    </p>
  {%- endif -%}
{%- endcapture -%}

{%- if enable_quick_buy_desktop or enable_quick_buy_mobile -%}
  {%- liquid
    assign product_form_class = 'f8pr form-card list-hide ' | append: settings.productcards_text_alignment
    if settings.layout_productcard == 'variant_picker' and layout != 'list-compact'
      assign product_form_class = product_form_class | append: ' no-border'
    endif
    if layout == 'list-compact'
      assign product_form_class = product_form_class | append: ' list-compact'
    endif
    assign product_form_id = 'quick-add-' | append: section.id | append: product.id | append: '-quick-add-form_x'
  -%}
  {%- capture quick_buy -%}
    {%- liquid
      if layout == 'list-compact'
        assign inline_variantpicker = true
      elsif layout == 'list' and origin == 'complementary' and enable_variant_picker
        assign inline_variantpicker = true
      endif
    %}
    {%- if inline_variantpicker -%}
      {%- form 'product', product, id: product_form_id, class: product_form_class, novalidate: 'novalidate' -%}
        {%- assign available_variants = product.variants | where: "available" -%}
        {%- if enable_variant_picker and available_variants.size > 1 -%}
          <p>
            <label for="{{ product_form_id }}-id" class="mobile-only"></label>
            {%- render 'variant-picker',
                product: product,
                fill_images: fill_images,
                form_id: product_form_id,
                show_unavailable_variants: settings.productcard_show_unavailable_variants
            -%}
          </p>
        {%- else -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
        {%- endif -%}
        <p class="submit">
          <button type="submit" class="circle {% if preorder %}overlay-preorder m0{% elsif current_variant.available %}overlay-buy_button{% else %}overlay-unavailable_buy_button{% endif %}{% if settings.buy_button_style == 'inv' %} inv{% endif %}" aria-label="{% if preorder %}{{ settings.preorder_button_text }}{% else %}{{ 'product.form.add_to_cart' | t }}{% endif %}" style="--size: 32px;">
            {% if preorder %}<i aria-hidden="true" class="icon-{% if settings.plus_icon_no_cart %}plus{% else %}cart{% endif %}" aria-label="{{ settings.preorder_button_text }}"></i>{% else %}<i aria-hidden="true" class="icon-{% if settings.plus_icon_no_cart %}plus{% else %}cart{% endif %}" aria-label="{{ 'product.form.add_to_cart' | t }}"></i> {{ 'product.form.add_to_cart' | t }}{% endif %}
          </button>
        </p>
      {%- endform -%}
    {%- elsif layout == 'hotspot' -%}
      {% if product.variants.size > 1 %}
        <p class="link-btn list-hide"><a href="{{ product.url }}" aria-label="choose options" class="wide overlay-buy_button{% if settings.buy_button_style == 'inv' %} inv{% endif %}" aria-label="{{ 'product.form.choose_options' | t }}">{{ 'product.form.choose_options' | t }}</a></p>
      {% else %}
        {% if current_variant.available %}
          {%- form 'product', product, id: product_form_id, class: product_form_class, novalidate: 'novalidate' -%}
            <p class="submit m0">
              <input type="hidden" name="id" value="{{ current_variant.id }}">
              <button type="submit" class="m0{% if preorder %} overlay-preorder{% else %} overlay-buy_button{% endif %}{% if settings.buy_button_style == 'inv' %} inv{% endif %}" aria-label="{% if preorder %}{{ settings.preorder_button_text }}{% else %}{{ 'product.form.add_to_cart' | t }}{% endif %}">
                <span>{% if preorder %}{{ settings.preorder_button_text }}{% else %}{{ 'product.form.add_to_cart' | t }}{% endif %}</span>
              </button>
            </p>
          {%- endform -%}
        {% else %}
          <p class="link-btn{% unless collection_page %} mobile-hide{% endunless %}"><a href="{{ product.url }}" aria-label="{{ 'product.form.not_in_stock' | t }}" class="overlay-unavailable_buy_button{% if settings.buy_button_style == 'inv' %} inv{% endif %}">{{ 'product.form.not_in_stock' | t }}</a></p>
        {% endif %}
      {% endif %}
    {% else %}
      {% if quickshop %}
        {% capture quickshop_circle_button_class %}
          {% unless layout == 'list' or origin == 'complementary' %}text-end{% endunless %}
          {% if layout == 'list' or layout == 'hotspot' or layout == 'grid' %}
            {% if layout == 'grid' %}visible mobile-text-end{% endif %}
          {% else %}
            {% if settings.quickshop_behavior == 'static' %}visible{% endif %}
          {% endif %}
        {% endcapture %}
        {{ quickshop_circle_button | replace: 'class-x', quickshop_circle_button_class }}
      {% elsif settings.layout_productcard contains 'add_to_cart' and product.id %}
        {% assign quickshop_circle_button_class = 'text-end visible' %}
        {{ quickshop_circle_button | replace: 'class-x', quickshop_circle_button_class }}
        {%- if require_login -%}
          <p class="link-btn{% unless collection_page %} mobile-hide{% endunless %}">
            <a href="{{ routes.account_login_url }}" aria-label="{{ 'customer.login.login_for_prices_html' | t | strip_html }}" class="overlay-buy_button{% if settings.buy_button_style == 'inv' %} inv{% endif %}">{{ 'customer.login.login_for_prices_html' | t }}</a>
          </p>
        {%- else -%}
          {%- liquid
            assign show_form = false
            if available_variants.size > 1 or preorder
                assign show_form = true
            elsif available_variants.size == 1 and current_variant.available
                assign show_form = true
            endif
          %}
          {% if show_form %}
            {% unless collection_page %}
              {% assign product_form_class = product_form_class | append: ' mobile-hide' %}
            {% endunless %}
            {%- form 'product', product, id: product_form_id, class: product_form_class, novalidate: 'novalidate' -%}
              {%- if available_variants.size > 1 and settings.layout_productcard contains 'add_to_cart' and settings.quickshop_position == 'above' -%}
                <fieldset>
                  <p class="submit{% if settings.productcard_form_layout == 'rows' and settings.layout_productcard == 'add_to_cart' %} wide{% endif %}">
                    {% if settings.layout_productcard == 'add_to_cart' %}
                    <span class="has-select" style="--main_fz: {{ settings.product_button_fontsize }}; font-size: {{ settings.product_button_fontsize }};">
                      <label for="{{ product_form_id }}-id" class="mobile-only"></label>
                      {%- render 'variant-picker',
                          product: product,
                          fill_images: fill_images,
                          form_id: product_form_id,
                          show_unavailable_variants: settings.productcard_show_unavailable_variants
                      -%}
                    </span>
                    <button type="submit" class="no-paddings{% if preorder %} overlay-preorder m0{% elsif current_variant.available %} overlay-buy_button{% else %} overlay-unavailable_buy_button{% endif %}{% if settings.buy_button_style == 'inv' %} inv{% endif %}{% unless current_variant.available %} disabled-style{% endunless %}" aria-label="{% if preorder %}{{ settings.preorder_button_text }}{% else %}{{ 'product.form.add_to_cart' | t }}{% endif %}"{% unless current_variant.available %} disabled{% endunless %}>
                      <span>{% if settings.cart_icon_no_text == false or settings.productcard_form_layout == 'columns' %}<i aria-hidden="true" class="icon-cart"></i>{% elsif preorder %}{{ settings.preorder_button_text }}{% elsif current_variant.available %}{{ 'product.form.add_to_cart' | t }}{% else %}{{ 'product.form.not_in_stock' | t }}{% endif %}</span>
                    </button>
                    {% else %}
                      <input type="hidden" name="id" value="{{ current_variant.id }}">
                      <span style="margin-block: 0;" class="input-amount {% if settings.qty_input_controls == 'enable' %}strong{% else %}no-arrows{% endif %}">
                        <label for="quantity-{{ product_form_id }}-id" class="hidden">{{ 'cart.product.qty' | t }}</label>
                        <input type="number" id="quantity-{{ product_form_id }}-id" name="quantity" value="{{ current_variant.quantity_rule.min }}"
                               min="{{ current_variant.quantity_rule.min }}"
                          {% if current_variant.inventory_management == 'shopify' and current_variant.inventory_policy == 'deny' -%}
                            max="{{ current_variant.inventory_quantity }}"
                          {% elsif current_variant.quantity_rule.max %}
                            max="{{ current_variant.quantity_rule.max }}"
                          {% endif %}
                          {% if current_variant.quantity_rule.increment %}step="{{ current_variant.quantity_rule.increment }}"{% endif %}
                          required
                        >
                      </span>
                      <button type="submit" class="no-paddings{% if preorder %} overlay-preorder m0{% elsif current_variant.available %} overlay-buy_button{% else %} overlay-unavailable_buy_button{% endif %}{% if settings.buy_button_style == 'inv' %} inv{% endif %}{% unless current_variant.available %} disabled-style{% endunless %}" aria-label="{% if preorder %}{{ settings.preorder_button_text }}{% else %}{{ 'product.form.add_to_cart' | t }}{% endif %}"{% unless current_variant.available %} disabled{% endunless %}>
                        <span>{% if settings.cart_icon_no_text == false or next_to_products %}<i aria-hidden="true" class="icon-cart"></i>{% elsif preorder %}{{ settings.preorder_button_text }}{% elsif current_variant.available %}{{ 'product.form.add_to_cart' | t }}{% else %}{{ 'product.form.not_in_stock' | t }}{% endif %}</span>
                      </button>
                    {% endif %}
                  </p>
                </fieldset>
              {%- else -%}
                <p class="submit m0">
                  <input type="hidden" name="id" value="{{ current_variant.id }}">
                {% if settings.layout_productcard == 'add_to_cart_qty' %}
                  <span style="margin-block: 0;" class="input-amount {% if settings.qty_input_controls == 'enable' %}strong{% else %}no-arrows{% endif %}">
                        <label for="quantity-{{ product_form_id }}-id" class="hidden">{{ 'cart.product.qty' | t }}</label>
                        <input type="number" id="quantity-{{ product_form_id }}-id" name="quantity" value="{{ current_variant.quantity_rule.min }}"
                               min="{{ current_variant.quantity_rule.min }}"
                          {% if current_variant.inventory_management == 'shopify' and current_variant.inventory_policy == 'deny' -%}
                            max="{{ current_variant.inventory_quantity }}"
                          {% elsif current_variant.quantity_rule.max %}
                            max="{{ current_variant.quantity_rule.max }}"
                          {% endif %}
                          {% if current_variant.quantity_rule.increment %}step="{{ current_variant.quantity_rule.increment }}"{% endif %}
                          required
                        >
                    </span>
                  {% endif %}
                  <button type="submit" class="m0 {% if preorder %}overlay-preorder {% else %}overlay-buy_button{% endif %}{% if settings.buy_button_style == 'inv' %} inv{% endif %}" aria-label="{% if preorder %}{{ settings.preorder_button_text }}{% else %}{{ 'product.form.add_to_cart' | t }}{% endif %}">
                    <span>{% if preorder %}{{ settings.preorder_button_text }}{% else %}{% if settings.cart_icon_no_text == false or next_to_products %}<i aria-hidden="true" class="icon-cart"></i>{% else %}{{ 'product.form.add_to_cart' | t }}{% endif %}{% endif %}</span>
                  </button>
                </p>
              {%- endif -%}
            {%- endform -%}
          {% else %}
            <p class="link-btn{% unless collection_page %} mobile-hide{% endunless %}"><a href="{{ product.url }}" aria-label="{{ 'product.form.not_in_stock' | t }}" class="overlay-unavailable_buy_button disabled{% if settings.buy_button_style == 'inv' %} inv{% endif %}">{{ 'product.form.not_in_stock' | t }}</a></p>
          {% endif %}
        {% endif %}
      {% elsif settings.layout_productcard == 'variant_picker' %}
        {% assign quickshop_circle_button_class = 'text-end visible' %}
        {{ quickshop_circle_button | replace: 'class-x', quickshop_circle_button_class }}

        {% if size_option %}
          {%- assign product_form_class = product_form_class | append: ' hidden list-hide variant-picker' -%}
          {% if size_option.values %}
            {% comment %}Redirect to product if it has a third option or color swatch is disabled and there is a second option{% endcomment %}
            {%- liquid
              assign go_to_product = false
              if color_option and product.options.size < 3
                assign go_to_product = true
              elsif color_option == false and product.options.size < 2
                assign go_to_product = true
              endif
              if enable_color_picker
                if settings.color_swatches_single and colors_size < 2
                  assign go_to_product = false
                endif
              endif
              if go_to_product
                assign product_form_class = product_form_class | append: ' product-options'
              endif
            %}
            {% assign product_form_class = product_form_class | append: ' mobile-hide' %}
            {%- form 'product', product, id: product_form_id, class: product_form_class, novalidate: 'novalidate' -%}
              <select name="id" id="id-{{ section.id }}-{{ product.id }}" data-url="{{ product.url }}" data-template="{{ section.id }}" required form="{{ product_form_id }}">
                {%- for variant in product.variants -%}
                  {%- liquid
                    assign featured_media_position = variant.featured_media.position
                    unless featured_media_position
                      assign featured_media_position = 1
                    endunless

                    if variant.featured_image
                      assign product_image = variant.featured_image
                    else
                      assign product_image = product.featured_image
                    endif
                  -%}
                  {% if block.settings.show_unavailable_variants == false and variant.available == false %}{% continue %}{% endif %}
                    <option
                      value="{{ variant.id }}"
                      data-variantinfo='{ {% if product_image %}"image":"{%- if fill_images -%}{{ product_image | image_url: width: image_width_2, height: image_height_2, crop: 'center' }}{%- else -%}{{ product_image | image_url: height: image_height_2 }}{%- endif -%}",{% endif %}{%- render 'price', product: product, variant: variant, origin: 'productitem', source: 'variant-selection' -%}}' data-options='{"id":{{ variant.id }},"options":{{ variant.options | json | escape }}}'
                          {% unless variant.available %}disabled data-class="disabled"{% endunless %}
                      data-slide-to="{{ featured_media_position | minus: 1 }}"
                    >{{ variant.title }}</option>
                {%- endfor -%}
              </select>
              <p class="submit m10 {% unless current_variant.available %}unavailable{% endunless %}">
                {%- if current_variant.available -%}
                  <button type="submit" class="overlay-buy_button{% if block.settings.button_style == 'inv' %} inv{% endif %}" aria-label="{{ 'product.form.add_to_cart' | t }}">{{ 'product.form.add_to_cart' | t }}</button>
                {%- else -%}
                  <button type="submit" class="disabled overlay-unavailable_buy_button{% if block.settings.button_style == 'inv' %} inv{% endif %}">{{ 'product.form.not_in_stock' | t }}</button>
                {%- endif -%}
              </p>
            {%- endform -%}

            <ul class="check inline plain text-center variant-picker mobile-hide list-hide" name="id" id="{{ product_form_id }}-id">
              {% if settings.button_label %}
                {%- if require_login -%}
                  <li class="wide strong"><a href="{{ routes.account_login_url }}">{{ 'customer.login.login_for_prices_html' | t | strip_html }}</a></li>
                {%- else -%}
                  {% unless product.has_only_default_variant %}<li class="wide strong">{{ settings.button_label }}</li>{% endunless %}
                {%- endif -%}
              {% endif %}
              {%- for value in size_option.values -%}
                <li>
                  <input type="radio"
                         id="option-{{ product.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}"
                         value="{{ value.name | escape }}"
                         name="options[{{ section.id }}-{{ option.name | escape }}]"
                         title="{{ value.name }}"
                         data-url="{{ product.url }}"
                         data-template="{{ section.id }}"
                         form="{{ form_id }}"
                         autocomplete="off"
                         {% if require_login %}ignore{% endif %}
                  >
                  <label{% unless value.variant.available %} class="disabled-style"{% endunless %} for="option-{{ product.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}">
                    {% if product.has_only_default_variant and settings.button_label %}{{ settings.button_label }}{% else %}{{ value.name }}{% endif %}
                  </label>
                </li>
              {%- endfor -%}
            </ul>
          {%  endif %}
        {% endif %}
      {% endif %}
    {%- endif -%}
  {%- endcapture %}
{%- endif -%}

{%- capture color_picker -%}
  {%- if enable_color_picker -%}
    {% if color_option %}
      <ul class="check color list-hide class-x{% if settings.color_swatch_shape == 'rectangle' %} rect{% endif %}" data-limit="6">
        {% for color in color_option.values %}
          {%- liquid
            for variant in product.variants
              assign options = variant.options | map: 'name'
              if options contains color
                assign color_variant = variant
                break
              endif
            endfor
          -%}
          {% capture swatch %}
            {% if color_variant and color_variant.featured_media and settings.color_swatches_variant_image %}
              <img src="{{ color_variant.featured_media | image_url: width: 48, height: 48, crop: 'center' }}" alt="{{ color }}" width="30" height="23" loading="lazy" class="color-variant-img filled">
            {% elsif color.swatch.image %}
              <i aria-hidden="true" class="icon-circle" style="background-image: url('{{ color.swatch.image | image_url }}');"></i>
            {% elsif color.swatch.color %}
              <i aria-hidden="true" class="icon-circle" style="background-color: {{ color.swatch.color }};"></i>
            {% else %}
              <i aria-hidden="true"
                 class="icon-circle swatch-custom-color-{{ color | handleize }}"
                 style="background-color:{{ color | split: ' ' | last }}"
              ></i>
            {% endif %}
          {% endcapture %}

          <li {% if color_variant and color_variant.featured_media %}
            data-img="
                  {%- if fill_images -%}
                    {{ color_variant.featured_media | image_url: width: image_width_2, height: image_height_2, crop: 'center' }}
                  {%- else -%}
                    {{ color_variant.featured_media | image_url: height: image_height_2 }}
                  {%- endif -%}
                  "
          {% endif %}
          >
            {% if settings.layout_productcard == 'variant_picker' and size_option %}
                {% comment %}Find match between color and size / add available sizes as data attribute{% endcomment %}
                {%- liquid
                  if size_option.values
                    assign data_sizes = ''
                    assign data_sizes_availability = ''

                    for variant in product.variants
                      assign options = variant.options | map: 'name'
                      if options contains color
                        assign found_size = false

                        for size in data_sizes
                          if options contains size
                            assign found_size = true
                          endif
                        endfor

                        unless found_size
                          assign data_sizes = data_sizes | append: variant.options[size_option_index] | append: '/'
                          assign data_sizes_availability = data_sizes_availability | append: variant.available | append: '/'
                        endunless
                      endif
                    endfor
                  endif
                -%}
                <input type="radio"
                     id="color-{{ section.id }}-{{ product.id }}-{{ variant.id }}-{{ forloop.index0 }}"
                     value="{{ color }}"
                     name="options[{{ section.id }}-{{ product.id }}]"
                     title="{{ value }}"
                     {% if forloop.index0 == 0 %}checked{% endif %}
                     data-url="{{ product.url }}"
                     data-template="{{ section.id }}"
                     form="{{ form_id }}"
                     data-sizes="{{ data_sizes | remove_last: '/' }}"
                     data-sizes-availability="{{ data_sizes_availability | remove_last: '/' }}"
                >
                <label for="color-{{ section.id }}-{{ product.id }}-{{ variant.id }}-{{ forloop.index0 }}">
                  {{ swatch }}
                </label>
            {% else %}
              <input type="radio" id="color-{{ section.id }}-{{ product.id }}-{{ variant.id }}-{{ forloop.index }}" name="color-{{ product.id }}-{{ variant.id }}-{{ forloop.index }}"{% if forloop.index0 == 0 %} checked{% endif %}>
              <label for="color-{{ section.id }}-{{ product.id }}-{{ variant.id }}-{{ forloop.index }}">
                <a href="{% if color_variant %}{{ color_variant.url }}{% else %}{{ product.url }}{% endif %}" aria-label="{{ color }} - {{ product.title }}">
                  {{ swatch }}
                </a>
              </label>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  {%- endif -%}
{%- endcapture %}

{%- capture variant_bulk -%}
  {%- if enable_bulk -%}
  {%- liquid
    assign product_form_class = 'l4ml-form list-only'
    assign actual_available_variants = product.variants | where: "available"
    if section.settings.bulk_show_unavailable_variants
      assign available_variants = product.variants
      if available_variants.size == 1
        assign available_variants = actual_available_variants
      endif
    else
      assign available_variants = actual_available_variants
    endif
    if available_variants.size == 1
      assign product_form_class = product_form_class | append: ' form-card'
    endif
    assign product_form_id = 'bulk-add-' | append: section.id | append: product.id
    assign deliverytime_extra_class = 'size-' | append: settings.product_delivery_size | append: ' mobile-size-' | append: settings.product_delivery_size_mobile
  -%}
  {%- form 'product', product, id: product_form_id, class: product_form_class, autocomplete: "off" -%}
      <fieldset>
        <legend>{{ section.settings.bulk_title }}</legend>
        {%- if available_variants.size == 0 -%}
          <p class="submit m5">
            <button type="submit" class="overlay-unavailable_buy_button{% if settings.button_style == 'inv' %} inv{% endif %} disabled visible">{{ 'product.form.not_in_stock' | t }}</button>
          </p>
        {%- else -%}
          {%- if available_variants.size == 1 -%}

              {%- render 'product-deliverytime',
                  product: product,
                  current_variant: current_variant,
                  container: "p",
                  origin: 'productitem',
                  no_margin: true,
                  extra_class: deliverytime_extra_class
              -%}

          {%- else -%}
            <p class="strong m15">{{ section.settings.bulk_title }}</p>
            <ul class="l4ml">
              {%- for variant in available_variants -%}
                <li class="{% unless show_price %}disabled{% endunless %}{% if forloop.index > 3 %} hidden{% endif %}">
                  {%- if variant.image and section.settings.bulk_show_variant_images -%}
                    <figure>
                      <picture {% if img_padding and img_vertical_position %}style="--img_padding:{{ img_padding }}%;--img_vertical_position:{{ img_vertical_position }}%;"{% endif %}><img src="{% if fill_images %}{{ variant.image | image_url: width: image_width_small, height: image_height_small, crop: 'center' }}{% else %}{{ variant.image | image_url: height: image_height_small }}{% endif %}" alt="{{ variant.title }}" width="50" height="55" loading="lazy" {% if fill_images %}class="filled"{% endif %}></picture>
                    </figure>
                  {%- endif -%}
                  <span>
                      <span{% if section.settings.bulk_shorten_title %} class="s1nw"{% endif %}><a href="{{ variant.url }}">{{ variant.title }}</a></span>
                      {%- liquid
                        if section.settings.bulk_show_deliverytime
                          assign hide_deliverytime = false
                        else
                          assign hide_deliverytime = true
                        endif
                      -%}
                      {%- render 'product-deliverytime',
                        product: variant,
                        current_variant: variant,
                        container: "span",
                        no_margin: no_margin,
                        extra_class: deliverytime_extra_class,
                        hide_deliverytime: hide_deliverytime,
                        extra_element: '<br>'
                      -%}
                      <br class="mobile-only">
                      {% comment %} <span class="s1pr mobile-only">{% if variant.compare_at_price > variant.price and show_price %}<span class="old-price">{{ variant.compare_at_price | money }}</span> {% endif %}{% if show_price %}{{ variant.price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}</span> {% endcomment %}
                      {% render 'price', product: product, variant: variant, price: variant.compare_at_price, origin: 'bulk', extraClass: 'mobile-only' %}
                  </span>
                  {% comment %} <span class="s1pr mobile-hide">{% if variant.compare_at_price > variant.price and show_price %}<span class="old-price">{{ variant.compare_at_price | money }}</span> {% endif %}{% if show_price %}{{ variant.price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}</span> {% endcomment %}
                  {% render 'price', product: product, variant: variant, price: variant.compare_at_price, origin: 'bulk', break: true, extraClass: 'mobile-hide' %}
                  <span class="input-amount {% if settings.qty_input_controls == 'enable' %}strong{% else %}no-arrows{% endif %}">
                      <label for="ml-{{ variant.id }}" class="hidden">{{ 'cart.product.qty' | t }}</label>
                      <input type="number" id="ml-{{ variant.id }}" name="ml-{{ variant.id }}" value="0" placeholder="0" min="{% if variant.quantity_rule.min > 1 %}{{ variant.quantity_rule.min }}{% else %}0{% endif %}"{% if variant.quantity_rule.max %} max="{{ variant.quantity_rule.max }}"{% endif %} step="{{ variant.quantity_rule.increment }}" required{% if variant.available == false %} disabled{% endif %} data-id="{{ variant.id }}" {% render 'price', product: variant.product, variant: variant, price: variant.price, origin: 'bulk-input' %} data-price="{{ variant.price }}">
                  </span>
                </li>
              {%- endfor -%}
              {%- if available_variants.size > 3 -%}
                <li class="link-more"><a href="./" class="link-more strong inline"><span class="link-underline">{{ 'general.read_more.show' | t }} <span>{{ 'general.read_more.all_2' | t }}</span> <span class="hidden">{{ 'general.read_more.less' | t }}</span> {{ 'general.read_more.variants' | t }}</span></a></li>
              {%- endif -%}
            </ul>
          {%- endif -%}
          {%- if show_price -%}
            {%- if available_variants.size == 1 -%}
              <p class="submit margin-0">
                {% comment %} <span class="margin-5">{% render 'price', product: current_variant.product, variant: current_variant, price: current_variant.compare_at_price, origin: 'bulk' %}</span> {% endcomment %}
                {% comment %} <span class="margin-5"><span class="s1pr bulk-price">{% if current_variant.compare_at_price > current_variant.price and show_price %}<span class="old-price">{{ current_variant.compare_at_price | money }}</span> {% endif %}{% if show_price %}{{ current_variant.price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}</span></span> {% endcomment %}
                <span>
                  {% render 'price', product: current_variant.product, variant: current_variant, price: current_variant.compare_at_price, origin: 'bulk' %}
                  {% if settings.productcards_show_tax -%}<span data-syncer-vat-incl class="size-small font-regular"> {{ 'product.including_tax' | t }}</span><span data-syncer-vat-excl class="size-12 font-regular"> {{ 'product.excluding_tax' | t }}</span>{%- endif -%}
                </span>
              </p>
            {%- endif -%}
            <p class="submit m5">
              {%- if available_variants.size == 1 -%}
                <input name="id" value="{{ current_variant.id }}" type="hidden">
                {% comment %} {% if available_variants.size > 1 %}<span><span class="s1pr bulk-price">{% if current_variant.compare_at_price > current_variant.price and show_price %}<span class="old-price">{{ current_variant.compare_at_price | money }}</span> {% endif %}{% if show_price %}{{ current_variant.price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}</span></span>{% endif %} {% endcomment %}
                {% if available_variants.size > 1 %}<span>{% render 'price', product: current_variant.product, variant: current_variant, price: current_variant.compare_at_price, origin: 'bulk' %}</span>{% endif %}
                <span class="input-amount {% if settings.qty_input_controls == 'enable' %}strong{% else %}no-arrows{% endif %}">
                    <label for="quantity-{{ product_form_id }}-id" class="hidden">{{ 'cart.product.qty' | t }}</label>
                    <input type="number" id="quantity-{{ product_form_id }}-id" name="quantity" value="{{ current_variant.quantity_rule.min }}"
                      min="{{ current_variant.quantity_rule.min }}"
                      {% if current_variant.inventory_management == 'shopify' and current_variant.inventory_policy == 'deny' -%}
                        max="{{ current_variant.inventory_quantity }}"
                      {% elsif current_variant.quantity_rule.max %}
                        max="{{ current_variant.quantity_rule.max }}"
                      {% endif %}
                      {% if current_variant.quantity_rule.increment %}step="{{ current_variant.quantity_rule.increment }}"{% endif %}
                      required
                    >
                </span>
              {%- else -%}
                {% comment %} <span>{{ 'cart.subtotal' | t }} <span class="s1bx rounded inline font-regular bulk-qty">0</span><br> <span class="s1pr bulk-price">{{ '0' | money }}</span></span> {% endcomment %}
                {% comment %} <span>{% render 'price', product: product, variant: variant, origin: 'bulk-subtotal' %}</span> {% endcomment %}
                <span>
                  {% render 'price', product: product, variant: variant, origin: 'bulk-subtotal' %}
                  {% if settings.productcards_show_tax -%}<span data-syncer-vat-incl class="size-small font-regular"> {{ 'product.including_tax' | t }}</span><span data-syncer-vat-excl class="size-12 font-regular"> {{ 'product.excluding_tax' | t }}</span>{%- endif -%}
                </span>
              {%- endif -%}
              <button type="submit" class="overlay-buy_button{% if settings.button_style == 'inv' %} inv{% endif %}{% if available_variants.size > 1 %} disabled{% endif %}" aria-label="{{ 'product.form.add_to_cart' | t }}">{{ 'product.form.add_to_cart' | t }}</button>
            </p>
          {%- else -%}
            <p class="link-btn m10" {{ block.shopify_attributes }}>
              <a href="{{ routes.account_login_url }}" class="wide overlay-buy_button{% if settings.buy_button_style == 'inv' %} inv{% endif %}" aria-label="{{ 'customer.login.login_for_prices_html' | t }}">{{ 'customer.login.login_for_prices_html' | t }}</a>
            </p>
          {%- endif -%}
        {%- endif -%}
        {%- if show_compare_checkbox -%}
          <p class="check list-only desktop-hide">
            <input type="checkbox" id="compare-{{ section.id }}-{{ product.id }}-1" name="product-compare" data-product-url="{{ product.url }}" data-product-id="{{ product.id }}" disabled>
            <label for="compare-{{ section.id }}-{{ product.id }}-1"><span data-checked-hide>{{ 'product.compare.add_to_compare' | t }}</span> <span data-checked-show>{{ 'product.compare.added_to_compare' | t }}</span></label>
          </p>
        {%- endif -%}
      </fieldset>
    {%- endform -%}
  {%- endif -%}
{%- endcapture %}

<{{ container }} class="{% if extra_class %}{% unless extra_style contains '--vertical' %}{{ extra_class }}{% endunless %}{% endif %} {% unless layout == 'list-compact' %}product-card{% endunless %} {{ width_class }}{% if quick_buy %} has-form{% endif %}
  {% unless current_variant.available %}unavailable{% endunless %}
  {% unless layout contains 'list' or layout == 'hotspot' %}{% if settings.productcards_text_alignment == 'left' or fixed_text_alignment_left %}text-start{% elsif settings.productcards_text_alignment == 'center' %}text-center{% elsif settings.productcards_text_alignment == 'right' %}text-end{% endif %}{% endunless %}
  {% if settings.image_behaviour != 'slider' and product.media[1] != nil and settings.image_behaviour != 'none' %}second-img-hover{% endif %}
  {% if settings.layout_productcard contains 'add_to_cart' or settings.layout_productcard == 'variant_picker' %}update-variants dynamic-quickshop{% endif %}
  {% if settings.layout_productcard == 'variant_picker' %}has-variant-picker{% endif %}
  {% if settings.layout_productcard contains 'add_to_cart' and settings.quickshop_position == 'below' %}has-below-picker{% endif %}
  {% if product == blank %}placeholder-product{% endif %}
  dont-move
  "
  {% if layout == 'list-compact' %}data-product-id="{{ product.id }}"{% endif %}
  style="--ratio:{{ custom_height_ratio }};{% if inline_variantpicker %} --btn_size: 32px;{% endif %}{% if settings.layout_productcard == 'variant_picker' %} --check_plain_bg: var(--{{ settings.variant_color_palette }}_bg); --check_plain_fg: var(--{{ settings.variant_color_palette }}_fg); --check_plain_o: {{ settings.background_opacity | divided_by: 100.0 }};{% endif %} {{ extra_style }}"
  {% unless extra_style contains '--vertical' %}{{ shopify_attributes }}{% endunless %}
  {% if animate %}data-sal="fade" data-sal-duration="500" data-sal-delay="{{ index | times: 50 }}"{% endif %}
>
  {% if extra_style contains '--vertical' %}<div {{ shopify_attributes }} class="extra-wrapper {% if extra_class %}{{ extra_class }}{% endif %}">{% endif %}
  {%- if show_image -%}
    <figure class="margin-15{% if overlay_static %} overlay-static{% endif %}{% if settings.multiply_product_images == 'multiply-bg' %} has-img-multiply-bg{% endif %}" {% if img_padding and img_vertical_position %}style="--img_padding:{{ img_padding }}%;--img_vertical_position:{{ img_vertical_position }}%;"{% endif %}>
      {% if show_labels %}{%- render 'product-labels', product: product, origin: 'productitem' -%}{% endif %}
      {%- liquid
        if layout == 'list-compact' and current_variant.featured_image
          assign product_image = current_variant.featured_image
        else
          assign product_image = product.featured_media
        endif
        assign first_image = product_image
        if product.media.size > 1
          assign second_image = product.media[1]
          if settings.image_behaviour == 'last_image'
            assign second_image = product.media | last
          endif
        endif
        if second_image != nil and settings.image_behaviour != 'slider' and layout != 'list-compact' and settings.image_behaviour != 'none' and inline_variantpicker == false
          assign show_secondary_image = true
        endif
      -%}
      {%- if product != blank and first_image -%}
        {%- if collection_page and settings.image_behaviour == 'slider' -%}
          <picture class="{% if product.images.size > 1 and settings.image_behaviour == 'slider' %}slider{% endif %}{% if settings.multiply_product_images == 'multiply' %} img-multiply{% elsif settings.multiply_product_images == 'multiply-bg' %} img-multiply-bg{% endif %}">
            {%- for image in product.images -%}
              {%- liquid
                if forloop.first
                  assign fill = fill_first_image
                else
                  assign fill = fill_images
                endif
              -%}
              {% unless layout == 'list-compact' %}<a href="{{ product.url }}">{% endunless %}
                <img
                        src="{%- if fill -%}{{ image | image_url: width: image_width_2, height: image_height_2, crop: 'center' }}{%- else -%}{{ image | image_url: height: image_height_2 }}{%- endif -%}"
                        {%- if sizes -%}
                          srcset="
                    {%- if fill -%}
                      {%- render 'image-srcset', image: image, format: 'custom', image_height: custom_height_ratio, max_width: 640, crop: 'center' -%}
                    {%- else -%}
                      {%- render 'image-srcset', image: image, max_width: 640 -%}
                    {%- endif -%}
                  "
                          sizes="{{ sizes }}"
                        {%- else -%}
                          srcset="
                    {%- if fill -%}
                      {{ first_image | image_url: width: image_width, height: image_height, crop: 'center' }} 1x, {{ image | image_url: width: image_width_2, height: image_height_2, crop: 'center' }} 2x
                    {%- else -%}
                      {{ first_image | image_url: height: image_height }} 1x, {{ image | image_url: height: image_height_2 }} 2x
                    {%- endif -%}
                  "
                        {%- endif -%}
                        width="{{ image_width }}"
                        height="{{ image_height }}"
                        alt="{{ image.alt | default: product.title | escape }}"
                        loading="{% if section.index > 2 or no_lazyload == false or forloop.first == false or section.location == 'footer' %}lazy{% else %}eager{% endif %}"
                        data-index="{{ forloop.index }}"
                  {% if fill %}class="filled"{% endif %}
                >
              {% unless layout == 'list-compact' %}</a>{% endunless %}
            {%- endfor -%}
          </picture>
        {%- else -%}
          {% unless layout == 'list-compact' %}<a href="{{ product.url }}">{% endunless %}
            <picture class="{% if settings.multiply_product_images == 'multiply' %}img-multiply{% elsif settings.multiply_product_images == 'multiply-bg' %}img-multiply-bg{% endif %}">
              <img
                src="{%- if fill_first_image -%}{{ first_image | image_url: width: image_width_2, height: image_height_2, crop: 'center' }}{%- else -%}{{ first_image | image_url: height: image_height_2 }}{%- endif -%}"
                {%- if sizes -%}
                  srcset="
                    {%- if fill_first_image -%}
                      {%- render 'image-srcset', image: first_image, format: 'custom', image_height: custom_height_ratio, max_width: 640, crop: 'center' -%}
                    {%- else -%}
                      {%- render 'image-srcset', image: first_image, max_width: 640 -%}
                    {%- endif -%}
                  "
                  sizes="{{ sizes }}"
                {%- else -%}
                  srcset="
                  {%- if fill_first_image -%}
                    {{ first_image | image_url: width: image_width, height: image_height, crop: 'center' }} 1x, {{ first_image | image_url: width: image_width_2, height: image_height_2, crop: 'center' }} 2x
                  {%- else -%}
                    {{ first_image | image_url: height: image_height }} 1x, {{ first_image | image_url: height: image_height_2 }} 2x
                  {%- endif -%}
                  "
                {%- endif -%}
                width="{{ image_width }}"
                height="{{ image_height }}"
                alt="{{ first_image.alt | default: product.title | escape }}"
                loading="{% if section.index > 2 or no_lazyload == false or forloop.first == false or section.location == 'footer' %}lazy{% else %}eager{% endif %}"
                {% if fill_first_image %}class="filled"{% endif %}
              >
            </picture>
            {% if show_secondary_image and second_image and settings.image_behaviour != 'slider' %}
              <picture class="{% if settings.multiply_product_images == 'multiply' %}img-multiply{% elsif settings.multiply_product_images == 'multiply-bg' %}img-multiply-bg{% endif %}">
                <img
                  src="{%- if fill_images -%}{{ second_image | image_url: width: image_width_2, height: image_height_2, crop: 'center' }}{%- else -%}{{ second_image | image_url: height: image_height_2 }}{%- endif -%}"
                  {%- if sizes -%}
                    srcset="
                      {%- if fill_images -%}
                        {%- render 'image-srcset', image: second_image, format: 'custom', image_height: custom_height_ratio, max_width: 640, crop: 'center' -%}
                      {%- else -%}
                        {%- render 'image-srcset', image: second_image, max_width: 640 -%}
                       {%- endif -%}
                    "
                    sizes="{{ sizes }}"
                  {%- else -%}
                    srcset="
                      {%- if fill_images -%}
                        {{ second_image | image_url: width: image_width, height: image_height, crop: 'center' }} 1x, {{ second_image | image_url: width: image_width_2, height: image_height_2, crop: 'center' }} 2x
                      {%- else -%}
                        {{ second_image | image_url: height: image_height }} 1x, {{ second_image | image_url: height: image_height_2 }} 2x
                      {%- endif -%}
                    "
                  {%- endif -%}
                  width="{{ image_width }}"
                  height="{{ image_height }}"
                  alt="{{ second_image.alt | default: product.title | escape }}"
                  loading="lazy"
                  {% if fill_images %}class="filled"{% endif %}
                >
              </picture>
            {% endif %}
          {% unless layout == 'list-compact' %}</a>{% endunless %}
        {%- endif -%}
      {%- elsif product.media[0].media_type == 'video' or product.media[0].media_type == 'external_video' -%}
        {% unless layout == 'list-compact' %}<a href="{{ product.url }}">{% endunless %}
        <picture class="{% if settings.multiply_product_images == 'multiply' %}img-multiply{% elsif settings.multiply_product_images == 'multiply-bg' %}img-multiply-bg{% endif %}">
          <img
            src="{{ product.media[0].preview_image | image_url: width: image_width_2, height: image_height_2 }}"
            srcset="
              {%- if fill_images -%}
                {{ product.media[0].preview_image | image_url: width: image_width, height: image_height, crop: 'center' }} 1x, {{ product.media[0].preview_image | image_url: width: image_width_2, height: image_height_2, crop: 'center' }} 2x
              {%- else -%}
                {{ product.media[0].preview_image | image_url: height: image_height }} 1x, {{ product.media[0].preview_image | image_url: height: image_height_2 }} 2x
              {%- endif -%}
            "
            width="{{ image_width }}"
            height="{{ image_height }}"
            alt="{{ product.title }}"
            loading="lazy"
            {% if fill_images %}class="filled"{% endif %}
          >
        </picture>
        {% unless layout == 'list-compact' %}</a>{% endunless %}
      {% else %}
        <picture class="{% if settings.multiply_product_images == 'multiply' %}img-multiply{% elsif settings.multiply_product_images == 'multiply-bg' %}img-multiply-bg{% endif %}"><a href="{{ product.url }}">{{ 'product-' | append: placeholder_int | placeholder_svg_tag: 'placeholder-svg' }}</a></picture>
      {%- endif -%}
      {%- if product != blank -%}
        <button class="wishlist-productcard hidden" title="Wishlist" data-product-id="{{ product.id }}" data-variant-id="{{ current_variant.id }}"><i class="icon-heart-outline"></i></button>
      {%- endif -%}
      {%- if static_color_picker == false and layout != 'hotspot' and layout != 'list' -%}
        {{ color_picker | replace: 'class-x', 'mobile-hide' }}
      {%- endif -%}
      {%- if quick_buy and layout != 'list-compact' and settings.layout_productcard != 'standard' and layout != 'list' and layout != 'hotspot' -%}
        {{ quick_buy | replace: '-quick-add-form_x', '1' }}
      {%- endif -%}
    </figure>
  {%- endif -%}
  {% if inline_variantpicker %}<section>{% else %}<div>{% endif %}
    {%- if show_title or show_vendor -%}
      <h3 class="m0 m0-mobile{% unless show_vendor %} p0{% endunless %}">
        {%- if show_vendor and vendor != "vendor-unknown" and vendor != shop.name -%}
          {%- liquid
            assign vendor_handle =vendor | handleize
            assign vendor_collection = collections[vendor_handle]
          -%}
          <span class="small margin-5">
            {%- if vendor_collection != blank -%}<a href="{{ vendor_collection.url }}">{{ vendor }}</a>{%- elsif vendor != 'Vendor name' -%}{{ vendor | link_to_vendor }}{% else %}{{ vendor }}{%- endif -%}
          </span>
        {%- endif -%}
        {%- if show_title -%}
          <a href="{{ product.url }}" class="fw-{{ settings.product_heading_font_weight }} ff-{{ settings.product_heading_font }} text-{{ settings.product_heading_case }}{% unless layout == 'list-compact' %} fz-heading-productcard{% endunless %} margin-5">{{ title }}</a>
        {%- endif -%}
        {%- liquid
          assign show_variant_title = false
          assign show_text = false
          if layout == 'list-compact'
            if product.has_only_default_variant == false
              if enable_variant_picker == false or enable_variant_picker and available_variants.size == 1
                assign show_variant_title = true
                assign show_text = true
              endif
            endif
            if preorder
              assign show_text = true
            endif
          endif
        -%}
        {%- if show_text -%}
          <span class="small size-12">
            {% if show_variant_title %}{{ current_variant.title }}{% if preorder %} / {% endif %}{% endif %}{% if preorder %}{{ settings.preorder_button_text }}{% endif %}
          </span>
        {%- endif -%}
      </h3>
    {%- endif -%}
    {%- if rating_value and show_rating -%}
      {% capture rating_label %}
        {%- if rating_count -%}{{ rating_count }} <span>{{ 'product.reviews.count' | t: count: rating_count }}</span>{%- endif -%}
      {% endcapture %}
      {% render 'rating-stars', value: rating_value, label: rating_label, style: '--main_fz: var(--main_fz_small)' %}
    {%- endif -%}
    {%- if show_stock and show_delivery_time -%}
      {%- liquid
        if inline_variantpicker
          assign deliverytime_extra_class = ''
        else
          assign deliverytime_extra_class = 'list-hide'
        endif
        assign deliverytime_size = 'size-' | append: settings.product_delivery_size | append: ' mobile-size-' | append: settings.product_delivery_size_mobile
        assign deliverytime_extra_class = deliverytime_extra_class | append: ' ' | append: deliverytime_size
      -%}
      {%- render 'product-deliverytime',
              product: product,
              show_stock: false,
              current_variant: current_variant,
              container: "p",
              extra_class: deliverytime_extra_class,
              origin: 'productitem'
      -%}
    {%- endif -%}
    {%- if show_price -%}
      <p class="price s1pr list-hide margin-10">
        {%- if product.price_varies and settings.show_price_varies and inline_variantpicker == false -%}
          {% render 'price', product: product, price: product.price_min %}<span class="price-varies">&nbsp;- {% render 'price', product: product, price: product.price_max %}</span>
        {%- else -%}
          {%- if current_variant.compare_at_price > current_variant.price -%}
            {%- liquid
              if settings.sale_label_price == 'percentage'
                assign discount = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price
                if discount > 1
                  assign discount = discount | round
                else
                  assign discount = discount | round: 1
                endif
                if discount == 100 and product.price != 0
                  assign discount = discount | minus: 0.1
                endif
              elsif settings.sale_label_price == 'amount'
                assign discount = current_variant.compare_at_price | minus: current_variant.price | money
              endif
            %}
            <span class="old-price font-regular" style="--main_fz: {{ settings.product_compare_prices_fontsize }}px">{%- render 'price', product: product, price: current_variant.compare_at_price -%}</span>{% if settings.sale_label_price != 'none' and layout != 'list-compact' %} <span class="discount s1bx inline overlay-sale" style="--main_fz: {{ settings.product_compare_prices_fontsize | minus: 2 }}px">{% render 'price', product: product, variant: current_variant, price: current_variant.price, origin: 'productitem', source: 'discount' %}</span>{%- endif -%}{% if layout != 'list-compact' and settings.sale_label_price != 'none' %}<br>{%- endif -%}
            {% comment %} <span class="old-price font-regular">{%- render 'price', product: product, price: current_variant.compare_at_price -%}</span>{%- unless layout == 'list-compact' -%}<span class="discount s1bx rounded inline strong size-12 overlay-sale">{% render 'price', product: product, variant: current_variant, price: current_variant.price, origin: 'productitem', source: 'discount' %}</span><br {% unless current_variant.compare_at_price > current_variant.price and settings.sale_label_price != 'none' %}class="hidden"{% endunless %}>{%- endunless -%} {% endcomment %}
          {%- endif -%}
          <span class="curr-price size-{{ settings.product_prices_fontsize }}">{%- render 'price', product: product, price: current_variant.price -%}</span>
        {%- endif -%}
        {%- if settings.productcards_show_tax -%}<span data-syncer-vat-incl class="size-{{ settings.product_prices_fontsize | minus: 2  }} font-regular"> {{ 'product.including_tax' | t }}</span><span data-syncer-vat-excl class="size-{{ settings.product_prices_fontsize | minus: 2 }} font-regular"> {{ 'product.excluding_tax' | t }}</span>{%- endif -%}
        {%- if current_variant.unit_price_measurement -%}
          {%- capture unit_price_base_unit -%}
            {%- if current_variant.available and current_variant.unit_price_measurement -%}
              {%- if current_variant.unit_price_measurement.reference_value != 1 -%}
                {{- current_variant.unit_price_measurement.reference_value -}}
              {%- endif -%}
              {{ current_variant.unit_price_measurement.reference_unit }}
            {%- endif -%}
          {%- endcapture -%}
          <span class="size-12 font-regular">{{ 'product.unit_price_label' | t }}{{ current_variant.unit_price | money }}&nbsp;{{ 'product.unit_price_separator' | t }} {{ unit_price_base_unit }}</span>
        {%- endif -%}
      </p>
    {%- endif -%}
    {%- if settings.product_short_description != 'none' and section.settings.show_product_description != false and settings.show_short_description and layout != 'list-compact' and origin != 'complementary' %}
      {%- liquid
        if settings.product_short_description == 'custom'
          assign product_short_description_namespace = settings.product_short_description_text | split: '.' | first
          assign product_short_description_key = settings.product_short_description_text | split: '.' | last
          assign short_description = product.metafields[product_short_description_namespace][product_short_description_key] | metafield_tag
        elsif product.description != blank
          assign short_description = product.description | strip_html | truncatewords: 40
        endif
      -%}
      {% if short_description != empty and short_description != blank -%}
        <div class="info m0">
          <p>{{ short_description | strip_html }}</p>
        </div>
      {%- endif -%}
    {%- endif -%}
    {%- if color_picker and static_color_picker -%}
      {{ color_picker }}
    {%- elsif color_picker and static_color_picker == false and settings.layout_productcard == 'standard' and layout != 'list-compact' and layout != 'hotspot' -%}
      {{ color_picker | replace: 'class-x', 'mobile-only' | replace: 'data-limit="6"', 'data-limit="3"' }}
    {% elsif color_picker and layout == 'list' %}
      {{ color_picker }}
    {%- endif -%}
    {%- if show_compare_checkbox -%}
      <p class="check list-hide">
        <input type="checkbox" id="compare-{{ section.id }}-{{ product.id }}-2" name="product-compare" data-product-url="{{ product.url }}" data-product-id="{{ product.id }}" disabled>
        <label for="compare-{{ section.id }}-{{ product.id }}-2"><span data-checked-hide>{{ 'product.compare.add_to_compare' | t }}</span> <span data-checked-show>{{ 'product.compare.added_to_compare' | t }}</span></label>
      </p>
      <p class="check list-only desktop-only" style="--main_fz: {{ settings.product_vendor_size }}px">
        <input type="checkbox" id="compare-{{ section.id }}-{{ product.id }}-3" name="product-compare" data-product-url="{{ product.url }}" data-product-id="{{ product.id }}" disabled>
        <label for="compare-{{ section.id }}-{{ product.id }}-3"><span data-checked-hide>{{ 'product.compare.add_to_compare' | t }}</span> <span data-checked-show>{{ 'product.compare.added_to_compare' | t }}</span></label>
      </p>
    {%- endif -%}

    {%- liquid
      assign show_section = false
      assign show_div_static = false
      assign show_quickbuy = false
      if quick_buy
        if layout == 'hotspot' or layout == 'list' or layout == 'grid'
          unless layout == 'grid' and settings.layout_productcard == 'variant_picker'
            unless inline_variantpicker
              assign show_quickbuy = true
            endunless
          endunless
        endif
        if show_quickbuy or quick_buy and inline_variantpicker
          if inline_variantpicker
            assign show_section = true
          elsif settings.layout_productcard != 'variant_picker' and layout != 'hotspot'
            assign show_div_static = true
          endif
        endif
      endif
    -%}
    {%- if show_section -%}<section>{%- elsif show_div_static -%}<div class="static">{%- endif -%}
    {%- if show_quickbuy -%}
      {{- quick_buy | replace: '-quick-add-form_x', '1' -}}
    {%- endif -%}
    {%- if quick_buy and inline_variantpicker -%}
      <footer>
        {{- quick_buy | replace: '-quick-add-form_x', '2' -}}
      </footer>
    {%- endif -%}
  {%- if show_section -%}</section>{%- elsif show_div_static -%}</div>{%- endif -%}
  {%- if inline_variantpicker -%}</section>{%- else -%}</div>{%- endif -%}
  {%- if type == 'both' and enable_bulk and layout != 'hotspot' -%}
    {{ variant_bulk }}
  {%- endif -%}

{% if settings.quickshop_position == 'below' and settings.layout_productcard contains 'add_to_cart' and layout != 'list-compact' and layout != 'list' and origin != 'complementary' and layout != 'hotspot'  %}
  {%- if require_login -%}
    <p class="link-btn{% unless collection_page %} mobile-hide{% endunless %}">
      <a href="{{ routes.account_login_url }}" aria-label="{{ 'customer.login.login_for_prices_html' | t | strip_html }}" class="overlay-buy_button{% if settings.buy_button_style == 'inv' %} inv{% endif %}">{{ 'customer.login.login_for_prices_html' | t }}</a>
    </p>
  {%- else -%}
    {%- liquid
      if settings.productcard_show_unavailable_variants
        assign available_variants = product.variants
      else
        assign available_variants = product.variants | where: "available"
      endif
      assign show_form = false
      if available_variants.size > 1 or preorder
        assign show_form = true
      elsif available_variants.size == 1 and current_variant.available
        assign show_form = true
      endif
    %}

    {% if show_form %}
      {% unless collection_page %}
        {% assign product_form_class = product_form_class | append: ' mobile-hide' %}
      {% endunless %}
      {%- liquid
        assign product_form_class = 'f8pr list-hide left'
        if available_variants.size == 1
          assign product_form_class = product_form_class | append: ' form-card'
        endif
        assign product_form_id = 'add-to-cart-' | append: section.id | append: product.id
      -%}
      {%- form 'product', product, id: product_form_id, class: product_form_class, novalidate: 'novalidate' -%}
        {%- if available_variants.size > 1 -%}
          <fieldset>
            <p class="submit{% if settings.productcard_form_layout == 'rows' and settings.layout_productcard == 'add_to_cart' %} wide{% endif %}">
              {% if settings.layout_productcard == 'add_to_cart' %}
                <span class="has-select" style="--main_fz: {{ settings.product_button_fontsize }}; font-size: {{ settings.product_button_fontsize }};">
                  <label for="{{ product_form_id }}-id" class="mobile-only"></label>
                    {%- render 'variant-picker',
                      product: product,
                      fill_images: fill_images,
                      form_id: product_form_id,
                      show_unavailable_variants: settings.productcard_show_unavailable_variants
                    -%}
                  </span>
                <button type="submit" class="no-paddings{% if preorder %} overlay-preorder m0{% elsif current_variant.available %} overlay-buy_button{% else %} overlay-unavailable_buy_button{% endif %}{% if settings.buy_button_style == 'inv' %} inv{% endif %}{% unless current_variant.available %} disabled-style{% endunless %}" aria-label="{% if preorder %}{{ settings.preorder_button_text }}{% else %}{{ 'product.form.add_to_cart' | t }}{% endif %}"{% unless current_variant.available %} disabled{% endunless %}>
                  <span>{% if settings.cart_icon_no_text == false or settings.productcard_form_layout == 'columns' %}<i aria-hidden="true" class="icon-cart"></i>{% elsif preorder %}{{ settings.preorder_button_text }}{% elsif current_variant.available %}{{ 'product.form.add_to_cart' | t }}{% else %}{{ 'product.form.not_in_stock' | t }}{% endif %}</span>
                </button>
              {% else %}
                <input type="hidden" name="id" value="{{ current_variant.id }}">
                <span style="margin-block: 0;" class="input-amount {% if settings.qty_input_controls == 'enable' %}strong{% else %}no-arrows{% endif %}">
                        <label for="quantity-{{ product_form_id }}-id" class="hidden">{{ 'cart.product.qty' | t }}</label>
                        <input type="number" id="quantity-{{ product_form_id }}-id" name="quantity" value="{{ current_variant.quantity_rule.min }}"
                               min="{{ current_variant.quantity_rule.min }}"
                          {% if current_variant.inventory_management == 'shopify' and current_variant.inventory_policy == 'deny' -%}
                            max="{{ current_variant.inventory_quantity }}"
                          {% elsif current_variant.quantity_rule.max %}
                            max="{{ current_variant.quantity_rule.max }}"
                          {% endif %}
                          {% if current_variant.quantity_rule.increment %}step="{{ current_variant.quantity_rule.increment }}"{% endif %}
                          required
                        >
                      </span>
                <button type="submit" class="no-paddings{% if preorder %} overlay-preorder m0{% elsif current_variant.available %} overlay-buy_button{% else %} overlay-unavailable_buy_button{% endif %}{% if settings.buy_button_style == 'inv' %} inv{% endif %}{% unless current_variant.available %} disabled-style{% endunless %}" aria-label="{% if preorder %}{{ settings.preorder_button_text }}{% else %}{{ 'product.form.add_to_cart' | t }}{% endif %}"{% unless current_variant.available %} disabled{% endunless %}>
                  <span>{% if settings.cart_icon_no_text == false or next_to_products %}<i aria-hidden="true" class="icon-cart"></i>{% elsif preorder %}{{ settings.preorder_button_text }}{% elsif current_variant.available %}{{ 'product.form.add_to_cart' | t }}{% else %}{{ 'product.form.not_in_stock' | t }}{% endif %}</span>
                </button>
              {% endif %}
            </p>
          </fieldset>
        {%- else -%}
          <p class="submit m0">
            <input type="hidden" name="id" value="{{ current_variant.id }}">
            {% if settings.layout_productcard == 'add_to_cart_qty' %}
              <span style="margin-block: 0;" class="input-amount {% if settings.qty_input_controls == 'enable' %}strong{% else %}no-arrows{% endif %}">
                        <label for="quantity-{{ product_form_id }}-id" class="hidden">{{ 'cart.product.qty' | t }}</label>
                        <input type="number" id="quantity-{{ product_form_id }}-id" name="quantity" value="{{ current_variant.quantity_rule.min }}"
                               min="{{ current_variant.quantity_rule.min }}"
                          {% if current_variant.inventory_management == 'shopify' and current_variant.inventory_policy == 'deny' -%}
                            max="{{ current_variant.inventory_quantity }}"
                          {% elsif current_variant.quantity_rule.max %}
                            max="{{ current_variant.quantity_rule.max }}"
                          {% endif %}
                          {% if current_variant.quantity_rule.increment %}step="{{ current_variant.quantity_rule.increment }}"{% endif %}
                          required
                        >
                    </span>
            {% endif %}
            <button type="submit" class="m0 {% if preorder %}overlay-preorder {% else %}overlay-buy_button{% endif %}{% if settings.buy_button_style == 'inv' %} inv{% endif %}" aria-label="{% if preorder %}{{ settings.preorder_button_text }}{% else %}{{ 'product.form.add_to_cart' | t }}{% endif %}">
              <span>{% if preorder %}{{ settings.preorder_button_text }}{% else %}{% if settings.cart_icon_no_text == false or next_to_products %}<i aria-hidden="true" class="icon-cart"></i>{% else %}{{ 'product.form.add_to_cart' | t }}{% endif %}{% endif %}</span>
            </button>
          </p>
        {%- endif -%}
      {%- endform -%}
    {% else %}
      <p class="link-btn{% unless collection_page %} mobile-hide{% endunless %}"><a href="{{ product.url }}" aria-label="{{ 'product.form.not_in_stock' | t }}" class="overlay-unavailable_buy_button disabled{% if settings.buy_button_style == 'inv' %} inv{% endif %}">{{ 'product.form.not_in_stock' | t }}</a></p>
    {% endif %}
  {% endif %}
{% endif %}
{% if extra_style contains '--vertical' %}</div>{% endif %}


</{{ container }}>
