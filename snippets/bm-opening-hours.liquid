{%- comment -%}
  ByMetz Opening Hours — shows current week with dates, fetches live
  data from Google Places API, highlights today, marks holidays.
{%- endcomment -%}

{%- liquid
  assign bm_places_api_key = settings.bm_google_places_api_key
  assign bm_place_id       = settings.bm_google_place_id

  assign bm_lang = request.locale.iso_code | default: localization.language.iso_code | default: shop.locale | default: 'nl' | downcase | split: '-' | first
-%}

<span id="bm-hours-anchor" style="display:block;position:relative;top:-120px;visibility:hidden;"></span>
<div class="bymetz-hours" data-bm-hours>
  {%- case bm_lang -%}
    {%- when 'en' -%}<h3 class="bymetz-hours__title">Store Opening Hours</h3>
    {%- when 'de' -%}<h3 class="bymetz-hours__title">&Ouml;ffnungszeiten Gesch&auml;ft</h3>
    {%- when 'fr' -%}<h3 class="bymetz-hours__title">Horaires du Magasin</h3>
    {%- when 'es' -%}<h3 class="bymetz-hours__title">Horario de la Tienda</h3>
    {%- when 'it' -%}<h3 class="bymetz-hours__title">Orari del Negozio</h3>
    {%- else -%}<h3 class="bymetz-hours__title">Openingstijden Winkel</h3>
  {%- endcase -%}

  <div class="bymetz-hours__center">
    <table class="bymetz-hours__table" aria-label="Opening hours" data-bm-hours-table>
      <thead>
        <tr>
          {%- case bm_lang -%}
            {%- when 'en' -%}<th scope="col">Day</th><th scope="col">Hours</th>
            {%- when 'de' -%}<th scope="col">Tag</th><th scope="col">&Ouml;ffnungszeiten</th>
            {%- when 'fr' -%}<th scope="col">Jour</th><th scope="col">Horaires</th>
            {%- when 'es' -%}<th scope="col">D&iacute;a</th><th scope="col">Horario</th>
            {%- when 'it' -%}<th scope="col">Giorno</th><th scope="col">Orario</th>
            {%- else -%}<th scope="col">Dag</th><th scope="col">Openingstijden</th>
          {%- endcase -%}
        </tr>
      </thead>
      <tbody data-bm-hours-body>
        {%- comment -%} JS replaces this immediately with dated rows {%- endcomment -%}
        {%- case bm_lang -%}
          {%- when 'en' -%}
            <tr><td>Monday</td><td>12:00 – 17:30</td></tr>
            <tr><td>Tuesday</td><td>10:00 – 17:30</td></tr>
            <tr><td>Wednesday</td><td>10:00 – 17:30</td></tr>
            <tr><td>Thursday</td><td>10:00 – 17:30</td></tr>
            <tr><td>Friday</td><td>10:00 – 20:00</td></tr>
            <tr><td>Saturday</td><td>10:00 – 17:00</td></tr>
            <tr><td>Sunday</td><td>12:00 – 17:00</td></tr>
          {%- when 'de' -%}
            <tr><td>Montag</td><td>12:00 – 17:30</td></tr>
            <tr><td>Dienstag</td><td>10:00 – 17:30</td></tr>
            <tr><td>Mittwoch</td><td>10:00 – 17:30</td></tr>
            <tr><td>Donnerstag</td><td>10:00 – 17:30</td></tr>
            <tr><td>Freitag</td><td>10:00 – 20:00</td></tr>
            <tr><td>Samstag</td><td>10:00 – 17:00</td></tr>
            <tr><td>Sonntag</td><td>12:00 – 17:00</td></tr>
          {%- when 'fr' -%}
            <tr><td>Lundi</td><td>12:00 – 17:30</td></tr>
            <tr><td>Mardi</td><td>10:00 – 17:30</td></tr>
            <tr><td>Mercredi</td><td>10:00 – 17:30</td></tr>
            <tr><td>Jeudi</td><td>10:00 – 17:30</td></tr>
            <tr><td>Vendredi</td><td>10:00 – 20:00</td></tr>
            <tr><td>Samedi</td><td>10:00 – 17:00</td></tr>
            <tr><td>Dimanche</td><td>12:00 – 17:00</td></tr>
          {%- when 'es' -%}
            <tr><td>Lunes</td><td>12:00 – 17:30</td></tr>
            <tr><td>Martes</td><td>10:00 – 17:30</td></tr>
            <tr><td>Mi&eacute;rcoles</td><td>10:00 – 17:30</td></tr>
            <tr><td>Jueves</td><td>10:00 – 17:30</td></tr>
            <tr><td>Viernes</td><td>10:00 – 20:00</td></tr>
            <tr><td>S&aacute;bado</td><td>10:00 – 17:00</td></tr>
            <tr><td>Domingo</td><td>12:00 – 17:00</td></tr>
          {%- when 'it' -%}
            <tr><td>Luned&igrave;</td><td>12:00 – 17:30</td></tr>
            <tr><td>Marted&igrave;</td><td>10:00 – 17:30</td></tr>
            <tr><td>Mercoled&igrave;</td><td>10:00 – 17:30</td></tr>
            <tr><td>Gioved&igrave;</td><td>10:00 – 17:30</td></tr>
            <tr><td>Venerd&igrave;</td><td>10:00 – 20:00</td></tr>
            <tr><td>Sabato</td><td>10:00 – 17:00</td></tr>
            <tr><td>Domenica</td><td>12:00 – 17:00</td></tr>
          {%- else -%}
            <tr><td>Maandag</td><td>12:00 – 17:30</td></tr>
            <tr><td>Dinsdag</td><td>10:00 – 17:30</td></tr>
            <tr><td>Woensdag</td><td>10:00 – 17:30</td></tr>
            <tr><td>Donderdag</td><td>10:00 – 17:30</td></tr>
            <tr><td>Vrijdag</td><td>10:00 – 20:00</td></tr>
            <tr><td>Zaterdag</td><td>10:00 – 17:00</td></tr>
            <tr><td>Zondag</td><td>12:00 – 17:00</td></tr>
        {%- endcase -%}
      </tbody>
    </table>
  </div>
</div>

<style>
  .bymetz-hours {
    width: 100%;
    padding: 0 16px;
    box-sizing: border-box;
  }
  .bymetz-hours__title {
    margin: 0 0 12px 0;
    text-align: center;
    font-weight: 700;
    font-size: 22px;
    line-height: 1.2;
  }
  .bymetz-hours__center {
    display: flex;
    justify-content: center;
    width: 100%;
  }
  .bymetz-hours__table {
    display: table !important;
    overflow: visible !important;
    width: fit-content;
    max-width: 100%;
    border-collapse: collapse;
    background: #fff;
    border: 1px solid rgba(0,0,0,.18);
    box-sizing: border-box;
  }
  .bymetz-hours__table thead th {
    text-align: left;
    font-weight: 700;
    padding: 12px 16px;
    background: #f4f4f4;
    border-bottom: 1px solid rgba(0,0,0,.12);
  }
  .bymetz-hours__table tbody td {
    padding: 12px 16px;
    border-bottom: 1px solid rgba(0,0,0,.08);
    vertical-align: top;
  }
  .bymetz-hours__table tbody tr:last-child td {
    border-bottom: 0;
  }
  .bymetz-hours__table td:nth-child(2) {
    white-space: nowrap;
  }
  .bymetz-hours__today td {
    font-weight: 700;
    background: rgba(0,128,0,.06);
  }
  .bymetz-hours__holiday {
    display: block;
    font-size: 0.85em;
    color: #b45309;
    font-weight: 600;
    margin-top: 2px;
  }
  @media (max-width: 600px) {
    .bymetz-hours { padding: 0 14px; }
    .bymetz-hours__title { font-size: 20px; }
    .bymetz-hours__table thead th,
    .bymetz-hours__table tbody td {
      padding: 10px 12px;
      font-size: 14px;
    }
  }
  /* Compact styling inside hamburger menu */
  .bm-nav-hours .bymetz-hours {
    padding: 12px 16px !important;
    margin: 0 !important;
  }
  .bm-nav-hours .bymetz-hours__title {
    font-size: 16px !important;
    margin-bottom: 8px !important;
    text-align: left !important;
  }
  .bm-nav-hours .bymetz-hours__center {
    justify-content: flex-start !important;
  }
  .bm-nav-hours .bymetz-hours__table {
    width: 100% !important;
  }
  .bm-nav-hours .bymetz-hours__table thead th,
  .bm-nav-hours .bymetz-hours__table tbody td {
    padding: 6px 8px !important;
    font-size: 12px !important;
  }
</style>

<script>
(function() {
  var API_KEY  = {{ bm_places_api_key | json }};
  var PLACE_ID = {{ bm_place_id | json }};
  var LANG     = {{ bm_lang | json }};

  var dayNames = {
    nl: ['zondag','maandag','dinsdag','woensdag','donderdag','vrijdag','zaterdag'],
    en: ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'],
    de: ['Sonntag','Montag','Dienstag','Mittwoch','Donnerstag','Freitag','Samstag'],
    fr: ['dimanche','lundi','mardi','mercredi','jeudi','vendredi','samedi'],
    es: ['domingo','lunes','martes','mi\u00e9rcoles','jueves','viernes','s\u00e1bado'],
    it: ['domenica','luned\u00ec','marted\u00ec','mercoled\u00ec','gioved\u00ec','venerd\u00ec','sabato']
  };
  var monthNames = {
    nl: ['januari','februari','maart','april','mei','juni','juli','augustus','september','oktober','november','december'],
    en: ['January','February','March','April','May','June','July','August','September','October','November','December'],
    de: ['Januar','Februar','M\u00e4rz','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'],
    fr: ['janvier','f\u00e9vrier','mars','avril','mai','juin','juillet','ao\u00fbt','septembre','octobre','novembre','d\u00e9cembre'],
    es: ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'],
    it: ['gennaio','febbraio','marzo','aprile','maggio','giugno','luglio','agosto','settembre','ottobre','novembre','dicembre']
  };
  var closedText = {nl:'Gesloten',en:'Closed',de:'Geschlossen',fr:'Ferm\u00e9',es:'Cerrado',it:'Chiuso'};

  var holidays = {
    '2025-01-01':{nl:'Nieuwjaarsdag',en:'New Year',de:'Neujahr',fr:'Nouvel An',es:'A\u00f1o Nuevo',it:'Capodanno'},
    '2025-04-18':{nl:'Goede Vrijdag',en:'Good Friday',de:'Karfreitag',fr:'Vendredi Saint',es:'Viernes Santo',it:'Venerd\u00ec Santo'},
    '2025-04-20':{nl:'Eerste Paasdag',en:'Easter Sunday',de:'Ostersonntag',fr:'P\u00e2ques',es:'Pascua',it:'Pasqua'},
    '2025-04-21':{nl:'Tweede Paasdag',en:'Easter Monday',de:'Ostermontag',fr:'Lundi de P\u00e2ques',es:'Lunes de Pascua',it:'Luned\u00ec di Pasqua'},
    '2025-04-27':{nl:'Koningsdag',en:"King's Day",de:'K\u00f6nigstag',fr:'F\u00eate du Roi',es:'D\u00eda del Rey',it:'Giorno del Re'},
    '2025-05-05':{nl:'Bevrijdingsdag',en:'Liberation Day',de:'Befreiungstag',fr:'Jour de la Lib\u00e9ration',es:'D\u00eda de la Liberaci\u00f3n',it:'Giorno della Liberazione'},
    '2025-05-29':{nl:'Hemelvaartsdag',en:'Ascension Day',de:'Christi Himmelfahrt',fr:'Ascension',es:'Ascensi\u00f3n',it:'Ascensione'},
    '2025-06-08':{nl:'Eerste Pinksterdag',en:'Whit Sunday',de:'Pfingstsonntag',fr:'Pentec\u00f4te',es:'Pentecost\u00e9s',it:'Pentecoste'},
    '2025-06-09':{nl:'Tweede Pinksterdag',en:'Whit Monday',de:'Pfingstmontag',fr:'Lundi de Pentec\u00f4te',es:'Lunes de Pentecost\u00e9s',it:'Luned\u00ec di Pentecoste'},
    '2025-12-25':{nl:'Eerste Kerstdag',en:'Christmas Day',de:'1. Weihnachtstag',fr:'No\u00ebl',es:'Navidad',it:'Natale'},
    '2025-12-26':{nl:'Tweede Kerstdag',en:'Boxing Day',de:'2. Weihnachtstag',fr:'Lendemain de No\u00ebl',es:'San Esteban',it:'Santo Stefano'},
    '2026-01-01':{nl:'Nieuwjaarsdag',en:'New Year',de:'Neujahr',fr:'Nouvel An',es:'A\u00f1o Nuevo',it:'Capodanno'},
    '2026-04-03':{nl:'Goede Vrijdag',en:'Good Friday',de:'Karfreitag',fr:'Vendredi Saint',es:'Viernes Santo',it:'Venerd\u00ec Santo'},
    '2026-04-05':{nl:'Eerste Paasdag',en:'Easter Sunday',de:'Ostersonntag',fr:'P\u00e2ques',es:'Pascua',it:'Pasqua'},
    '2026-04-06':{nl:'Tweede Paasdag',en:'Easter Monday',de:'Ostermontag',fr:'Lundi de P\u00e2ques',es:'Lunes de Pascua',it:'Luned\u00ec di Pasqua'},
    '2026-04-27':{nl:'Koningsdag',en:"King's Day",de:'K\u00f6nigstag',fr:'F\u00eate du Roi',es:'D\u00eda del Rey',it:'Giorno del Re'},
    '2026-05-05':{nl:'Bevrijdingsdag',en:'Liberation Day',de:'Befreiungstag',fr:'Jour de la Lib\u00e9ration',es:'D\u00eda de la Liberaci\u00f3n',it:'Giorno della Liberazione'},
    '2026-05-14':{nl:'Hemelvaartsdag',en:'Ascension Day',de:'Christi Himmelfahrt',fr:'Ascension',es:'Ascensi\u00f3n',it:'Ascensione'},
    '2026-05-24':{nl:'Eerste Pinksterdag',en:'Whit Sunday',de:'Pfingstsonntag',fr:'Pentec\u00f4te',es:'Pentecost\u00e9s',it:'Pentecoste'},
    '2026-05-25':{nl:'Tweede Pinksterdag',en:'Whit Monday',de:'Pfingstmontag',fr:'Lundi de Pentec\u00f4te',es:'Lunes de Pentecost\u00e9s',it:'Luned\u00ec di Pentecoste'},
    '2026-12-25':{nl:'Eerste Kerstdag',en:'Christmas Day',de:'1. Weihnachtstag',fr:'No\u00ebl',es:'Navidad',it:'Natale'},
    '2026-12-26':{nl:'Tweede Kerstdag',en:'Boxing Day',de:'2. Weihnachtstag',fr:'Lendemain de No\u00ebl',es:'San Esteban',it:'Santo Stefano'}
  };

  var names = dayNames[LANG] || dayNames.nl;
  var months = monthNames[LANG] || monthNames.nl;
  var closed = closedText[LANG] || closedText.nl;

  /* Get Monday of current week */
  var now = new Date();
  var todayStr = toKey(now);
  var day = now.getDay(); /* 0=Sun */
  var diff = day === 0 ? -6 : 1 - day;
  var monday = new Date(now);
  monday.setDate(now.getDate() + diff);
  monday.setHours(0,0,0,0);

  /* Build 7 dates Mon–Sun */
  var weekDates = [];
  for (var i = 0; i < 7; i++) {
    var d = new Date(monday);
    d.setDate(monday.getDate() + i);
    weekDates.push(d);
  }

  /* Default fallback hours per weekday (Mon=0 … Sun=6 in our array) */
  var fallbackHours = [
    '12:00 \u2013 17:30',
    '10:00 \u2013 17:30',
    '10:00 \u2013 17:30',
    '10:00 \u2013 17:30',
    '10:00 \u2013 20:00',
    '10:00 \u2013 17:00',
    '12:00 \u2013 17:00'
  ];

  function capitalize(s) { return s.charAt(0).toUpperCase() + s.slice(1); }
  function pad(n) { return (n < 10 ? '0' : '') + n; }
  function toKey(d) { return d.getFullYear() + '-' + pad(d.getMonth()+1) + '-' + pad(d.getDate()); }

  function formatDayLabel(date) {
    var dayIdx = date.getDay();
    var dayName = capitalize(names[dayIdx]);
    var dateNum = date.getDate();
    var monthName = months[date.getMonth()];
    return dayName + ' ' + dateNum + ' ' + monthName;
  }

  function renderTable(schedule, closedDays) {
    var tbody = document.querySelector('[data-bm-hours-body]');
    if (!tbody) return;
    closedDays = closedDays || {};
    var html = '';
    for (var i = 0; i < 7; i++) {
      var date = weekDates[i];
      var key = toKey(date);
      var isToday = key === todayStr;
      var label = formatDayLabel(date);
      var holiday = holidays[key];
      var holidayName = holiday ? (holiday[LANG] || holiday.nl) : '';

      var hours;
      if (closedDays[key]) {
        hours = closed;
      } else if (schedule) {
        var gDay = date.getDay(); /* Google day index: 0=Sun */
        hours = schedule[gDay] && schedule[gDay].length ? schedule[gDay].join(', ') : closed;
      } else {
        hours = fallbackHours[i];
      }

      html += '<tr' + (isToday ? ' class="bymetz-hours__today"' : '') + '>';
      html += '<td>' + label;
      if (holidayName) html += '<span class="bymetz-hours__holiday">' + holidayName + '</span>';
      html += '</td>';
      html += '<td>' + hours + '</td>';
      html += '</tr>';
    }
    tbody.innerHTML = html;
  }

  /* Render fallback with dates immediately */
  renderTable(null);

  /* Fetch live hours from Google Places API */
  if (!API_KEY || !PLACE_ID) return;

  var baseUrl = 'https://places.googleapis.com/v1/places/' + PLACE_ID + '?languageCode=' + LANG + '&key=' + API_KEY;

  function parseHours(hours) {
    var schedule = {};
    for (var j = 0; j < 7; j++) schedule[j] = [];
    var closedDays = {};

    if (hours.specialDays) {
      hours.specialDays.forEach(function(sd) {
        if (sd.date) {
          var k = sd.date.year + '-' + pad(sd.date.month) + '-' + pad(sd.date.day);
          if (sd.exceptionalHours === false || (sd.hours && sd.hours.length === 0)) {
            closedDays[k] = true;
          }
        }
      });
    }

    hours.periods.forEach(function(p) {
      var dIdx = p.open.day;
      var open  = pad(p.open.hour) + ':' + pad(p.open.minute);
      var close = p.close ? pad(p.close.hour) + ':' + pad(p.close.minute) : '';
      schedule[dIdx].push(open + (close ? ' \u2013 ' + close : '+'));
    });

    return { schedule: schedule, closedDays: closedDays };
  }

  /* Try currentOpeningHours first (includes holiday/special hours),
     fall back to regularOpeningHours if that field is unsupported */
  fetch(baseUrl + '&fields=currentOpeningHours')
    .then(function(r) {
      if (!r.ok) throw new Error(r.status);
      return r.json();
    })
    .then(function(data) {
      if (data && data.currentOpeningHours && data.currentOpeningHours.periods) {
        var result = parseHours(data.currentOpeningHours);
        renderTable(result.schedule, result.closedDays);
      } else {
        throw new Error('no currentOpeningHours');
      }
    })
    .catch(function() {
      /* Fallback: fetch regularOpeningHours */
      fetch(baseUrl + '&fields=regularOpeningHours')
        .then(function(r) { if (!r.ok) throw new Error(r.status); return r.json(); })
        .then(function(data) {
          if (data && data.regularOpeningHours && data.regularOpeningHours.periods) {
            var result = parseHours(data.regularOpeningHours);
            renderTable(result.schedule, result.closedDays);
          }
        })
        .catch(function(err) {
          console.warn('ByMetz opening hours: using fallback \u2013', err);
        });
    });
})();
</script>
