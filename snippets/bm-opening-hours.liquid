{%- comment -%}
  ByMetz Opening Hours — reads from theme settings, calculates Dutch
  holidays & first/last-Sunday rule in JS, no external API calls.
{%- endcomment -%}

{%- liquid
  assign bm_lang = request.locale.iso_code | default: localization.language.iso_code | default: shop.locale | default: 'nl' | downcase | split: '-' | first
-%}

{%- unless in_nav -%}
<span id="bm-hours-anchor" style="display:block;position:relative;top:-120px;visibility:hidden;"></span>
{%- endunless -%}
{%- if variant == 'compact' -%}
<div class="bymetz-hours bymetz-hours--compact" data-bm-hours>
  <div class="bymetz-hours__compact-row" data-bm-hours-compact-row>
    <span class="bymetz-hours__dot" data-bm-hours-dot></span>
    <span class="bymetz-hours__compact-day" data-bm-hours-compact-day></span>
    <span class="bymetz-hours__compact-sep">·</span>
    <span class="bymetz-hours__compact-time" data-bm-hours-compact-time></span>
  </div>
  <a class="bymetz-hours__cta" href="{{ routes.root_url }}#bm-hours-anchor">
    {%- if request.locale.iso_code == 'de' -%}Öffnungszeiten{%- else -%}{{ 'general.opening_hours_button' | t }}{%- endif -%}
  </a>
</div>
{%- else -%}
<div class="bymetz-hours" data-bm-hours>
  {%- case bm_lang -%}
    {%- when 'en' -%}<h3 class="bymetz-hours__title">Store Opening Hours</h3>
    {%- when 'de' -%}<h3 class="bymetz-hours__title">&Ouml;ffnungszeiten Gesch&auml;ft</h3>
    {%- when 'fr' -%}<h3 class="bymetz-hours__title">Horaires du Magasin</h3>
    {%- when 'es' -%}<h3 class="bymetz-hours__title">Horario de la Tienda</h3>
    {%- when 'it' -%}<h3 class="bymetz-hours__title">Orari del Negozio</h3>
    {%- else -%}<h3 class="bymetz-hours__title">Openingstijden Winkel</h3>
  {%- endcase -%}

  <div class="bymetz-hours__center">
    <table class="bymetz-hours__table" aria-label="Opening hours" data-bm-hours-table>
      <thead>
        <tr>
          {%- case bm_lang -%}
            {%- when 'en' -%}<th scope="col">Day</th><th scope="col">Hours</th>
            {%- when 'de' -%}<th scope="col">Tag</th><th scope="col">&Ouml;ffnungszeiten</th>
            {%- when 'fr' -%}<th scope="col">Jour</th><th scope="col">Horaires</th>
            {%- when 'es' -%}<th scope="col">D&iacute;a</th><th scope="col">Horario</th>
            {%- when 'it' -%}<th scope="col">Giorno</th><th scope="col">Orario</th>
            {%- else -%}<th scope="col">Dag</th><th scope="col">Openingstijden</th>
          {%- endcase -%}
        </tr>
      </thead>
      <tbody data-bm-hours-body>
        {%- comment -%} JS replaces this immediately with dated rows {%- endcomment -%}
        {%- case bm_lang -%}
          {%- when 'en' -%}
            <tr><td>Monday</td><td>12:00 – 17:30</td></tr>
            <tr><td>Tuesday</td><td>10:00 – 17:30</td></tr>
            <tr><td>Wednesday</td><td>10:00 – 17:30</td></tr>
            <tr><td>Thursday</td><td>10:00 – 17:30</td></tr>
            <tr><td>Friday</td><td>10:00 – 20:00</td></tr>
            <tr><td>Saturday</td><td>10:00 – 17:00</td></tr>
            <tr><td>Sunday</td><td>12:00 – 17:00</td></tr>
          {%- when 'de' -%}
            <tr><td>Montag</td><td>12:00 – 17:30</td></tr>
            <tr><td>Dienstag</td><td>10:00 – 17:30</td></tr>
            <tr><td>Mittwoch</td><td>10:00 – 17:30</td></tr>
            <tr><td>Donnerstag</td><td>10:00 – 17:30</td></tr>
            <tr><td>Freitag</td><td>10:00 – 20:00</td></tr>
            <tr><td>Samstag</td><td>10:00 – 17:00</td></tr>
            <tr><td>Sonntag</td><td>12:00 – 17:00</td></tr>
          {%- when 'fr' -%}
            <tr><td>Lundi</td><td>12:00 – 17:30</td></tr>
            <tr><td>Mardi</td><td>10:00 – 17:30</td></tr>
            <tr><td>Mercredi</td><td>10:00 – 17:30</td></tr>
            <tr><td>Jeudi</td><td>10:00 – 17:30</td></tr>
            <tr><td>Vendredi</td><td>10:00 – 20:00</td></tr>
            <tr><td>Samedi</td><td>10:00 – 17:00</td></tr>
            <tr><td>Dimanche</td><td>12:00 – 17:00</td></tr>
          {%- when 'es' -%}
            <tr><td>Lunes</td><td>12:00 – 17:30</td></tr>
            <tr><td>Martes</td><td>10:00 – 17:30</td></tr>
            <tr><td>Mi&eacute;rcoles</td><td>10:00 – 17:30</td></tr>
            <tr><td>Jueves</td><td>10:00 – 17:30</td></tr>
            <tr><td>Viernes</td><td>10:00 – 20:00</td></tr>
            <tr><td>S&aacute;bado</td><td>10:00 – 17:00</td></tr>
            <tr><td>Domingo</td><td>12:00 – 17:00</td></tr>
          {%- when 'it' -%}
            <tr><td>Luned&igrave;</td><td>12:00 – 17:30</td></tr>
            <tr><td>Marted&igrave;</td><td>10:00 – 17:30</td></tr>
            <tr><td>Mercoled&igrave;</td><td>10:00 – 17:30</td></tr>
            <tr><td>Gioved&igrave;</td><td>10:00 – 17:30</td></tr>
            <tr><td>Venerd&igrave;</td><td>10:00 – 20:00</td></tr>
            <tr><td>Sabato</td><td>10:00 – 17:00</td></tr>
            <tr><td>Domenica</td><td>12:00 – 17:00</td></tr>
          {%- else -%}
            <tr><td>Maandag</td><td>12:00 – 17:30</td></tr>
            <tr><td>Dinsdag</td><td>10:00 – 17:30</td></tr>
            <tr><td>Woensdag</td><td>10:00 – 17:30</td></tr>
            <tr><td>Donderdag</td><td>10:00 – 17:30</td></tr>
            <tr><td>Vrijdag</td><td>10:00 – 20:00</td></tr>
            <tr><td>Zaterdag</td><td>10:00 – 17:00</td></tr>
            <tr><td>Zondag</td><td>12:00 – 17:00</td></tr>
        {%- endcase -%}
      </tbody>
    </table>
  </div>
</div>
{%- endif -%}

<style>
  .bymetz-hours {
    width: 100%;
    padding: 0 16px;
    box-sizing: border-box;
  }
  .bymetz-hours__title {
    margin: 0 0 12px 0;
    text-align: center;
    font-weight: 700;
    font-size: 22px;
    line-height: 1.2;
  }
  .bymetz-hours__center {
    display: flex;
    justify-content: center;
    width: 100%;
  }
  .bymetz-hours__table {
    display: table !important;
    overflow: visible !important;
    width: fit-content;
    max-width: 100%;
    border-collapse: collapse;
    background: #fff;
    border: 1px solid rgba(0,0,0,.18);
    box-sizing: border-box;
  }
  .bymetz-hours__table thead th {
    text-align: left;
    font-weight: 700;
    padding: 12px 16px;
    background: #f4f4f4;
    border-bottom: 1px solid rgba(0,0,0,.12);
  }
  .bymetz-hours__table tbody td {
    padding: 12px 16px;
    border-bottom: 1px solid rgba(0,0,0,.08);
    vertical-align: top;
  }
  .bymetz-hours__table tbody tr:last-child td {
    border-bottom: 0;
  }
  .bymetz-hours__table td:nth-child(2) {
    white-space: nowrap;
  }
  .bymetz-hours__today td {
    font-weight: 700;
    background: rgba(0,128,0,.06);
  }
  .bymetz-hours__today--closed td { color: #dc2626; }
  .bymetz-hours__holiday {
    display: block;
    font-size: 0.85em;
    color: #b45309;
    font-weight: 600;
    margin-top: 2px;
  }
  @media (max-width: 600px) {
    .bymetz-hours { padding: 0 14px; }
    .bymetz-hours__title { font-size: 20px; }
    .bymetz-hours__table thead th,
    .bymetz-hours__table tbody td {
      padding: 10px 12px;
      font-size: 14px;
    }
  }
  @media screen and (min-width: 1001px) {
    .bm-nav-hours {
      display: none !important;
    }
  }
  /* Tighten spacing between compact hours and the footer-info/.m6cn block in hamburger */
  #nav .m6cn { padding-top: 0 !important; }
  #nav .m6cn > *:first-child { margin-top: 0 !important; }
  #nav > ul.nav-top { display: none !important; }
  /* ── Compact variant (hamburger menu) ── */
  .bymetz-hours--compact {
    padding: 12px 16px 0;
    padding-left: 16px;
    margin-bottom: 0;
    text-align: left;
  }
  .bymetz-hours__compact-row {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    line-height: 1.3;
    font-variant-numeric: tabular-nums;
  }
  .bymetz-hours__dot {
    display: inline-block;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #9ca3af;
    flex: 0 0 auto;
  }
  .bymetz-hours__dot.is-open   { background: #16a34a; }
  .bymetz-hours__dot.is-closed { background: #dc2626; }
  .bymetz-hours__compact-day  { font-weight: 600; }
  .bymetz-hours__compact-sep  { opacity: 0.4; }
  .bymetz-hours__compact-time { font-weight: 500; }
  .bymetz-hours__cta {
    display: inline-block;
    margin-top: 10px;
    margin-bottom: 4px;
    line-height: 1;
    color: #E65324;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 3px;
    letter-spacing: 0.08em;
    font-size: 11px;
    font-weight: 700;
  }
  .bymetz-hours__cta:hover,
  .bymetz-hours__cta:focus { color: #c43f18; }
</style>

<script>
(function() {
  /* ── Configuration from Shopify theme settings ── */
  var CFG = {
    weekdays: [
      /* 0 = Sunday */
      {open:{{ settings.bm_hours_sun_open | json }},from:{{ settings.bm_hours_sun_from | json }},to:{{ settings.bm_hours_sun_to | json }}},
      /* 1 = Monday */
      {open:{{ settings.bm_hours_mon_open | json }},from:{{ settings.bm_hours_mon_from | json }},to:{{ settings.bm_hours_mon_to | json }}},
      /* 2 = Tuesday */
      {open:{{ settings.bm_hours_tue_open | json }},from:{{ settings.bm_hours_tue_from | json }},to:{{ settings.bm_hours_tue_to | json }}},
      /* 3 = Wednesday */
      {open:{{ settings.bm_hours_wed_open | json }},from:{{ settings.bm_hours_wed_from | json }},to:{{ settings.bm_hours_wed_to | json }}},
      /* 4 = Thursday */
      {open:{{ settings.bm_hours_thu_open | json }},from:{{ settings.bm_hours_thu_from | json }},to:{{ settings.bm_hours_thu_to | json }}},
      /* 5 = Friday */
      {open:{{ settings.bm_hours_fri_open | json }},from:{{ settings.bm_hours_fri_from | json }},to:{{ settings.bm_hours_fri_to | json }}},
      /* 6 = Saturday */
      {open:{{ settings.bm_hours_sat_open | json }},from:{{ settings.bm_hours_sat_from | json }},to:{{ settings.bm_hours_sat_to | json }}}
    ],
    sundayFL: {
      enabled: {{ settings.bm_hours_sun_first_last | json }},
      from: {{ settings.bm_hours_sun_fl_from | json }},
      to: {{ settings.bm_hours_sun_fl_to | json }}
    },
    holidays: {
      open: {{ settings.bm_hours_holidays_open | json }},
      from: {{ settings.bm_hours_holidays_from | json }},
      to: {{ settings.bm_hours_holidays_to | json }},
      closed: {{ settings.bm_hours_holidays_closed | default: '' | json }}
    },
    specialDays: {{ settings.bm_hours_special_days | default: '' | json }},
    lang: {{ bm_lang | json }}
  };

  /* ── Localisation ── */
  var dayNames = {
    nl: ['zondag','maandag','dinsdag','woensdag','donderdag','vrijdag','zaterdag'],
    en: ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'],
    de: ['Sonntag','Montag','Dienstag','Mittwoch','Donnerstag','Freitag','Samstag'],
    fr: ['dimanche','lundi','mardi','mercredi','jeudi','vendredi','samedi'],
    es: ['domingo','lunes','martes','mi\u00e9rcoles','jueves','viernes','s\u00e1bado'],
    it: ['domenica','luned\u00ec','marted\u00ec','mercoled\u00ec','gioved\u00ec','venerd\u00ec','sabato']
  };
  var monthNames = {
    nl: ['januari','februari','maart','april','mei','juni','juli','augustus','september','oktober','november','december'],
    en: ['January','February','March','April','May','June','July','August','September','October','November','December'],
    de: ['Januar','Februar','M\u00e4rz','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'],
    fr: ['janvier','f\u00e9vrier','mars','avril','mai','juin','juillet','ao\u00fbt','septembre','octobre','novembre','d\u00e9cembre'],
    es: ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'],
    it: ['gennaio','febbraio','marzo','aprile','maggio','giugno','luglio','agosto','settembre','ottobre','novembre','dicembre']
  };
  var closedText = {nl:'Gesloten',en:'Closed',de:'Geschlossen',fr:'Ferm\u00e9',es:'Cerrado',it:'Chiuso'};
  var LANG = CFG.lang;
  var names = dayNames[LANG] || dayNames.nl;
  var months = monthNames[LANG] || monthNames.nl;
  var closed = closedText[LANG] || closedText.nl;

  /* ── Dutch holiday calculation ── */
  var holidayNames = {
    'nieuwjaarsdag':       {nl:'Nieuwjaarsdag',en:'New Year\'s Day',de:'Neujahr',fr:'Nouvel An',es:'A\u00f1o Nuevo',it:'Capodanno'},
    'goede vrijdag':       {nl:'Goede Vrijdag',en:'Good Friday',de:'Karfreitag',fr:'Vendredi Saint',es:'Viernes Santo',it:'Venerd\u00ec Santo'},
    'eerste paasdag':      {nl:'Eerste Paasdag',en:'Easter Sunday',de:'Ostersonntag',fr:'P\u00e2ques',es:'Pascua',it:'Pasqua'},
    'tweede paasdag':      {nl:'Tweede Paasdag',en:'Easter Monday',de:'Ostermontag',fr:'Lundi de P\u00e2ques',es:'Lunes de Pascua',it:'Luned\u00ec di Pasqua'},
    'koningsdag':          {nl:'Koningsdag',en:'King\'s Day',de:'K\u00f6nigstag',fr:'F\u00eate du Roi',es:'D\u00eda del Rey',it:'Giorno del Re'},
    'bevrijdingsdag':      {nl:'Bevrijdingsdag',en:'Liberation Day',de:'Befreiungstag',fr:'Jour de la Lib\u00e9ration',es:'D\u00eda de la Liberaci\u00f3n',it:'Giorno della Liberazione'},
    'hemelvaartsdag':      {nl:'Hemelvaartsdag',en:'Ascension Day',de:'Christi Himmelfahrt',fr:'Ascension',es:'Ascensi\u00f3n',it:'Ascensione'},
    'eerste pinksterdag':  {nl:'Eerste Pinksterdag',en:'Whit Sunday',de:'Pfingstsonntag',fr:'Pentec\u00f4te',es:'Pentecost\u00e9s',it:'Pentecoste'},
    'tweede pinksterdag':  {nl:'Tweede Pinksterdag',en:'Whit Monday',de:'Pfingstmontag',fr:'Lundi de Pentec\u00f4te',es:'Lunes de Pentecost\u00e9s',it:'Luned\u00ec di Pentecoste'},
    'eerste kerstdag':     {nl:'Eerste Kerstdag',en:'Christmas Day',de:'1. Weihnachtstag',fr:'No\u00ebl',es:'Navidad',it:'Natale'},
    'tweede kerstdag':     {nl:'Tweede Kerstdag',en:'Boxing Day',de:'2. Weihnachtstag',fr:'Lendemain de No\u00ebl',es:'San Esteban',it:'Santo Stefano'},
    'oudejaarsdag':        {nl:'Oudejaarsdag',en:'New Year\'s Eve',de:'Silvester',fr:'Saint-Sylvestre',es:'Nochevieja',it:'San Silvestro'}
  };

  function easterSunday(year) {
    var a = year % 19;
    var b = Math.floor(year / 100);
    var c = year % 100;
    var d = Math.floor(b / 4);
    var e = b % 4;
    var f = Math.floor((b + 8) / 25);
    var g = Math.floor((b - f + 1) / 3);
    var h = (19 * a + b - d - g + 15) % 30;
    var i = Math.floor(c / 4);
    var k = c % 4;
    var l = (32 + 2 * e + 2 * i - h - k) % 7;
    var m = Math.floor((a + 11 * h + 22 * l) / 451);
    var month = Math.floor((h + l - 7 * m + 114) / 31);
    var day = ((h + l - 7 * m + 114) % 31) + 1;
    return new Date(year, month - 1, day);
  }

  function addDays(d, n) {
    var r = new Date(d);
    r.setDate(r.getDate() + n);
    return r;
  }

  function computeHolidays(year) {
    var easter = easterSunday(year);
    var koningsdag = new Date(year, 3, 27);
    if (koningsdag.getDay() === 0) koningsdag = new Date(year, 3, 26);

    var list = [
      {date: new Date(year, 0, 1),           key: 'nieuwjaarsdag'},
      {date: addDays(easter, -2),             key: 'goede vrijdag'},
      {date: easter,                          key: 'eerste paasdag'},
      {date: addDays(easter, 1),              key: 'tweede paasdag'},
      {date: koningsdag,                      key: 'koningsdag'},
      {date: new Date(year, 4, 5),            key: 'bevrijdingsdag'},
      {date: addDays(easter, 39),             key: 'hemelvaartsdag'},
      {date: addDays(easter, 49),             key: 'eerste pinksterdag'},
      {date: addDays(easter, 50),             key: 'tweede pinksterdag'},
      {date: new Date(year, 11, 25),          key: 'eerste kerstdag'},
      {date: new Date(year, 11, 26),          key: 'tweede kerstdag'},
      {date: new Date(year, 11, 31),          key: 'oudejaarsdag'}
    ];
    var map = {};
    list.forEach(function(h) { map[toKey(h.date)] = h.key; });
    return map;
  }

  /* ── Parse special days textarea ── */
  function parseSpecialDays(text) {
    var map = {};
    if (!text) return map;
    text.split('\n').forEach(function(line) {
      line = line.trim();
      if (!line) return;
      var parts = line.split('|');
      if (parts.length >= 2) {
        map[parts[0].trim()] = parts[1].trim();
      }
    });
    return map;
  }

  /* ── Parse holidays-closed textarea ── */
  function parseHolidaysClosed(text) {
    var set = {};
    if (!text) return set;
    text.split('\n').forEach(function(line) {
      line = line.trim().toLowerCase();
      if (line) set[line] = true;
    });
    return set;
  }

  /* ── First / last Sunday check ── */
  function isFirstOrLastSunday(date) {
    if (date.getDay() !== 0) return false;
    var day = date.getDate();
    if (day <= 7) return true;
    var lastDay = new Date(date.getFullYear(), date.getMonth() + 1, 0).getDate();
    return day > lastDay - 7;
  }

  /* ── Helpers ── */
  function pad(n) { return (n < 10 ? '0' : '') + n; }
  function toKey(d) { return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate()); }
  function capitalize(s) { return s.charAt(0).toUpperCase() + s.slice(1); }

  function formatDayLabel(date) {
    return capitalize(names[date.getDay()]) + ' ' + date.getDate() + ' ' + months[date.getMonth()];
  }

  /* ── Get Amsterdam time ── */
  function getAmsterdamNow() {
    var ams = new Date(new Date().toLocaleString('en-US', {timeZone: 'Europe/Amsterdam'}));
    return ams;
  }

  /* ── Build schedule for a single date ── */
  var specialDays = parseSpecialDays(CFG.specialDays);
  var holidaysClosed = parseHolidaysClosed(CFG.holidays.closed);

  var now = getAmsterdamNow();
  var thisYear = now.getFullYear();
  var allHolidays = {};
  var h1 = computeHolidays(thisYear);
  var h2 = computeHolidays(thisYear + 1);
  for (var k in h1) allHolidays[k] = h1[k];
  for (var k2 in h2) allHolidays[k2] = h2[k2];

  function getHoursForDate(date) {
    var key = toKey(date);
    var dow = date.getDay();
    var holidayKey = allHolidays[key];
    var holidayLabel = null;
    var result = {hours: '', isOpen: false, holidayName: ''};

    /* Priority 1: Manual special days */
    if (specialDays[key]) {
      var val = specialDays[key].toLowerCase();
      if (val === 'gesloten' || val === 'closed' || val === 'geschlossen' || val === 'fermé' || val === 'cerrado' || val === 'chiuso') {
        result.hours = closed;
        if (holidayKey) {
          var hn = holidayNames[holidayKey];
          result.holidayName = hn ? (hn[LANG] || hn.nl) : '';
        }
        return result;
      }
      result.hours = val.replace(/(\d{1,2}:\d{2})-(\d{1,2}:\d{2})/g, '$1 \u2013 $2');
      result.isOpen = true;
      if (holidayKey) {
        var hn2 = holidayNames[holidayKey];
        result.holidayName = hn2 ? (hn2[LANG] || hn2.nl) : '';
      }
      return result;
    }

    /* Priority 2: Holidays */
    if (holidayKey) {
      var hn3 = holidayNames[holidayKey];
      result.holidayName = hn3 ? (hn3[LANG] || hn3.nl) : '';

      if (holidaysClosed[holidayKey]) {
        result.hours = closed;
        return result;
      }
      if (CFG.holidays.open) {
        result.hours = (CFG.holidays.from || '12:00') + ' \u2013 ' + (CFG.holidays.to || '17:00');
        result.isOpen = true;
        return result;
      }
      result.hours = closed;
      return result;
    }

    /* Priority 3: First/last Sunday */
    if (dow === 0 && CFG.sundayFL.enabled && isFirstOrLastSunday(date)) {
      result.hours = (CFG.sundayFL.from || '12:00') + ' \u2013 ' + (CFG.sundayFL.to || '17:00');
      result.isOpen = true;
      return result;
    }

    /* Priority 4: Normal weekday hours */
    var dayConf = CFG.weekdays[dow];
    if (!dayConf || !dayConf.open) {
      result.hours = closed;
      return result;
    }

    result.hours = (dayConf.from || '10:00') + ' \u2013 ' + (dayConf.to || '17:00');
    result.isOpen = true;
    return result;
  }

  /* ── Check if currently open right now ── */
  function isOpenRightNow() {
    var ams = getAmsterdamNow();
    var info = getHoursForDate(ams);
    if (!info.isOpen) return false;

    var currentMinutes = ams.getHours() * 60 + ams.getMinutes();
    var slots = info.hours.split(', ');
    for (var i = 0; i < slots.length; i++) {
      var parts = slots[i].split(' \u2013 ');
      if (parts.length !== 2) continue;
      var openParts = parts[0].trim().split(':');
      var closeParts = parts[1].trim().split(':');
      var openMin = parseInt(openParts[0], 10) * 60 + parseInt(openParts[1], 10);
      var closeMin = parseInt(closeParts[0], 10) * 60 + parseInt(closeParts[1], 10);
      if (currentMinutes >= openMin && currentMinutes < closeMin) return true;
    }
    return false;
  }

  /* ── Render table ── */
  var todayStr = toKey(now);
  var today = new Date(now);
  today.setHours(0, 0, 0, 0);

  var weekDates = [];
  for (var i = 0; i < 7; i++) {
    var d = new Date(today);
    d.setDate(today.getDate() + i);
    weekDates.push(d);
  }

  function renderTable() {
    var openNow = isOpenRightNow();

    /* Full-tabel variant (homepage) */
    var tbodies = document.querySelectorAll('[data-bm-hours-body]');
    if (tbodies.length) {
      var htmlFull = '';
      for (var i = 0; i < 7; i++) {
        var date = weekDates[i];
        var key = toKey(date);
        var isToday = key === todayStr;
        var label = formatDayLabel(date);
        var info = getHoursForDate(date);

        var fullClass = '';
        if (isToday) {
          fullClass = 'bymetz-hours__today' + (openNow ? '' : ' bymetz-hours__today--closed');
        }
        htmlFull += '<tr' + (fullClass ? ' class="' + fullClass + '"' : '') + '>';
        htmlFull += '<td>' + label;
        if (info.holidayName) htmlFull += '<span class="bymetz-hours__holiday">' + info.holidayName + '</span>';
        htmlFull += '</td>';
        htmlFull += '<td>' + info.hours + '</td>';
        htmlFull += '</tr>';
      }
      tbodies.forEach(function(tbody) { tbody.innerHTML = htmlFull; });
    }

    /* Compact variant (hamburger menu) — alleen vandaag */
    var compactRows = document.querySelectorAll('[data-bm-hours-compact-row]');
    if (compactRows.length) {
      var todayDate = weekDates[0];
      var todayInfo = getHoursForDate(todayDate);
      var todayLabel = formatDayLabel(todayDate);
      compactRows.forEach(function(row) {
        var dot = row.querySelector('[data-bm-hours-dot]');
        var dayEl = row.querySelector('[data-bm-hours-compact-day]');
        var timeEl = row.querySelector('[data-bm-hours-compact-time]');
        if (dot) {
          dot.classList.remove('is-open', 'is-closed');
          dot.classList.add(openNow ? 'is-open' : 'is-closed');
        }
        if (dayEl) dayEl.textContent = todayLabel;
        if (timeEl) timeEl.textContent = todayInfo.hours;
      });
    }
  }

  renderTable();

  /* Only run once even if snippet is rendered multiple times */
  if (window._bmHoursFetched) return;
  window._bmHoursFetched = true;

  /* Close mobile hamburger when compact CTA is clicked (link keeps navigating to anchor) */
  document.addEventListener('click', function(e) {
    var cta = e.target.closest('.bymetz-hours__cta');
    if (!cta) return;
    var closeBtn = document.querySelector('#nav a.close-nav');
    if (closeBtn) closeBtn.click();
  });
})();
</script>
