{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign total_stock = current_variant.inventory_quantity
  assign inventory_tracking = false

  assign deliverytime_in_stock = product.metafields.custom.deliverytime_in_stock
  assign deliverytime_not_in_stock = product.metafields.custom.deliverytime_not_in_stock
  unless deliverytime_in_stock
    assign deliverytime_in_stock = settings.default_product_deliverytime_in_stock
  endunless
  unless deliverytime_not_in_stock
    assign deliverytime_not_in_stock = settings.default_product_deliverytime_not_in_stock
  endunless

  if current_variant.inventory_management == 'shopify'
    assign inventory_tracking = true
  endif

  assign bm_show = false
  if inventory_tracking
    if total_stock > 0 or current_variant.inventory_policy == 'continue'
      assign bm_show = true
      assign bm_in_stock = true
    elsif deliverytime_not_in_stock != blank
      assign bm_show = true
      assign bm_in_stock = false
    endif
  elsif deliverytime_in_stock != blank and settings.show_deliverytime_always
    assign bm_show = true
    assign bm_in_stock = true
  endif
-%}

{%- if bm_show -%}
  <div class="bm-delivery">
    {%- if bm_in_stock -%}
      <svg class="bm-delivery__icon bm-delivery__icon--ok" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
        <path d="M10 2a8 8 0 1 1 0 16 8 8 0 0 1 0-16zm3.36 5.22a.75.75 0 0 0-1.06.04L9.4 10.6 7.7 8.9a.75.75 0 1 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.08-.02l3.43-3.91a.75.75 0 0 0-.04-1.06z" fill="currentColor"/>
      </svg>
      <span class="bm-delivery__text">
        {%- if deliverytime_in_stock != blank -%}
          {{ deliverytime_in_stock }}
        {%- else -%}
          {{ 'product.form.in_stock' | t }}
        {%- endif -%}
      </span>
    {%- else -%}
      <svg class="bm-delivery__icon bm-delivery__icon--warn" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
        <circle cx="10" cy="10" r="8" fill="currentColor"/>
        <path d="M10 6v5M10 13v1" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <span class="bm-delivery__text">
        {{ deliverytime_not_in_stock }}
      </span>
    {%- endif -%}
  </div>
{%- endif -%}

<style>
  .bm-delivery {
    display: flex;
    align-items: center;
    gap: 5px;
    margin: 4px 0 8px;
    font-size: clamp(11px, 3.2vw, 15px);
    line-height: 1.3;
    white-space: nowrap;
  }
  .bm-delivery__icon {
    width: 1.2em;
    height: 1.2em;
    min-width: 1.2em;
    flex: 0 0 auto;
  }
  .bm-delivery__icon--ok {
    color: #02ad02;
  }
  .bm-delivery__icon--warn {
    color: #ea6c44;
  }
  .bm-delivery__text {
    min-width: 0;
  }
</style>
