{%- comment -%}
  Sticky mobile filter bar — uses the theme's own f8fl-toggle class
  so the theme's click handler (aria-controls="filter" → toggle f8fl-open)
  works natively. No custom JS for filter opening needed.
{%- endcomment -%}

{%- assign bm_lang = request.locale.iso_code | default: localization.language.iso_code | default: shop.locale | default: 'nl' | downcase | split: '-' | first -%}
{%- case bm_lang -%}
  {%- when 'en' -%}{%- assign bm_filter_label = 'Filter & Sort' -%}
  {%- when 'de' -%}{%- assign bm_filter_label = 'Filtern & Sortieren' -%}
  {%- when 'fr' -%}{%- assign bm_filter_label = 'Filtrer & Trier' -%}
  {%- when 'es' -%}{%- assign bm_filter_label = 'Filtrar & Ordenar' -%}
  {%- when 'it' -%}{%- assign bm_filter_label = 'Filtra & Ordina' -%}
  {%- else -%}{%- assign bm_filter_label = 'Filter & Sorteer' -%}
{%- endcase -%}

<div class="bm-sticky-filter" id="bm-sticky-filter">
  <a href="#filter" class="bm-sticky-filter__btn f8fl-toggle" aria-controls="filter" aria-label="{{ bm_filter_label }}">
    <svg class="bm-sticky-filter__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 15 13.5" fill="currentColor" aria-hidden="true">
      <path d="M5.25 0c-.7 0-1.13-.03-1.61.17A2.25 2.25 0 0 0 2.42 1.39c-.1.26-.08.58-.09.86H.75a.75.75 0 0 0 0 1.5h1.58c.02.28-.01.6.09.86a2.25 2.25 0 0 0 1.22 1.22c.48.2.91.17 1.61.17s1.13.03 1.61-.17a2.25 2.25 0 0 0 1.22-1.22c.2-.48.17-.91.17-1.61s.03-1.13-.17-1.61A2.25 2.25 0 0 0 6.86.17C6.38-.03 5.95 0 5.25 0zm0 1.5c.7 0 .97.03 1.04.06a.75.75 0 0 1 .4.4c.03.07.06.34.06 1.04s-.03.97-.06 1.04a.75.75 0 0 1-.4.4c-.07.03-.34.06-1.04.06s-.97-.03-1.04-.06a.75.75 0 0 1-.4-.4C3.78 3.97 3.75 3.7 3.75 3s.03-.97.06-1.04a.75.75 0 0 1 .4-.4C4.28 1.53 4.55 1.5 5.25 1.5zm4.5.75a.75.75 0 0 0 0 1.5h4.5a.75.75 0 0 0 0-1.5zm0 5.25c-.7 0-1.13-.03-1.61.17a2.25 2.25 0 0 0-1.22 1.22c-.2.48-.17.91-.17 1.61s-.03 1.13.17 1.61a2.25 2.25 0 0 0 1.22 1.22c.48.2.91.17 1.61.17s1.13.03 1.61-.17a2.25 2.25 0 0 0 1.22-1.22c.1-.26.08-.58.09-.86h1.58a.75.75 0 0 0 0-1.5h-1.58c-.02-.28.01-.6-.09-.86a2.25 2.25 0 0 0-1.22-1.22c-.48-.2-.91-.17-1.61-.17zm0 1.5c.7 0 .97.03 1.04.06a.75.75 0 0 1 .4.4c.03.07.06.34.06 1.04s-.03.97-.06 1.04a.75.75 0 0 1-.4.4c-.07.03-.34.06-1.04.06s-.97-.03-1.04-.06a.75.75 0 0 1-.4-.4c-.03-.07-.06-.34-.06-1.04s.03-.97.06-1.04a.75.75 0 0 1 .4-.4c.07-.03.34-.06 1.04-.06zm-9 .75a.75.75 0 0 0 0 1.5h4.5a.75.75 0 0 0 0-1.5z"/>
    </svg>
    <span>{{ bm_filter_label }}</span>
  </a>
</div>

<style>
  .bm-sticky-filter { display: none; }
  @media screen and (max-width: 749px) {
    .bm-sticky-filter {
      display: block;
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      padding: 8px 12px;
      background: #fff;
      box-shadow: 0 -2px 8px rgba(0,0,0,0.12);
      z-index: 100;
    }
    .bm-sticky-filter__btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 42px;
      background: #1a1a1a;
      color: #fff !important;
      border: none;
      border-radius: 4px;
      font-family: inherit;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.02em;
      text-decoration: none;
      gap: 8px;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
    }
    .bm-sticky-filter__btn:active {
      background: #333;
    }
    .bm-sticky-filter__icon {
      width: 16px;
      height: 14px;
      flex-shrink: 0;
    }
    /* Hide original filter link on mobile */
    .f8sr .link-btn > a.f8fl-toggle {
      position: absolute !important;
      width: 1px !important;
      height: 1px !important;
      overflow: hidden !important;
      clip: rect(0,0,0,0) !important;
      white-space: nowrap !important;
      border: 0 !important;
      margin: -1px !important;
      padding: 0 !important;
    }
    #root { padding-bottom: 58px !important; }
  }
</style>

<script>
(function() {
  if (window.innerWidth > 749) return;
  /*
   * Fallback: if the theme's JS already initialized f8fl-toggle handlers
   * before our element existed, attach our own handler that does the same:
   * toggle html.f8fl-open and load the filter CSS.
   */
  var btn = document.querySelector('#bm-sticky-filter .f8fl-toggle');
  if (!btn) return;
  btn.addEventListener('click', function(e) {
    console.log('[bm-sticky-filter] click handler fired');
    e.preventDefault();
    var html = document.documentElement;

    /* Replicate theme's exact handler from custom-async.js lines 3869-3883 */
    html.classList.add('has-filters');

    if (html.classList.contains('f8fl-open')) {
      html.classList.remove('f8fl-open');
    } else {
      /* hidePanels() — close any open panels first (lines 2136-2153) */
      html.classList.remove('m6pn-open', 'm6cp-open', 'f8fl-open');
      document.querySelectorAll('.m6pn').forEach(function(el) {
        el.classList.remove('toggle');
        el.setAttribute('aria-hidden', 'true');
      });

      html.classList.add('f8fl-open');
    }

    /* getStickyFooters — trigger layout recalc */
    if (typeof getStickyFooters === 'function') getStickyFooters();

    /* new_css('css-filters', ...) — load async filter CSS */
    if (window.filepaths && window.filepaths['async_filters_css']) {
      var id = 'css-filters';
      if (!document.getElementById(id)) {
        var lnk = document.createElement('link');
        lnk.id = id;
        lnk.rel = 'stylesheet';
        lnk.href = window.filepaths['async_filters_css'];
        document.head.appendChild(lnk);
      }
    }
  });
})();
</script>
