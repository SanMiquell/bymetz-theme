{%- comment -%}
  Sticky mobile filter bar — physically moves the original filter trigger
  link into a fixed bottom bar. Theme's panel system stays 100% intact.
{%- endcomment -%}

{%- assign bm_lang = request.locale.iso_code | default: localization.language.iso_code | default: shop.locale | default: 'nl' | downcase | split: '-' | first -%}
{%- case bm_lang -%}
  {%- when 'en' -%}{%- assign bm_filter_label = 'Filter & Sort' -%}
  {%- when 'de' -%}{%- assign bm_filter_label = 'Filtern & Sortieren' -%}
  {%- when 'fr' -%}{%- assign bm_filter_label = 'Filtrer & Trier' -%}
  {%- when 'es' -%}{%- assign bm_filter_label = 'Filtrar & Ordenar' -%}
  {%- when 'it' -%}{%- assign bm_filter_label = 'Filtra & Ordina' -%}
  {%- else -%}{%- assign bm_filter_label = 'Filter & Sorteer' -%}
{%- endcase -%}

<div class="bm-sticky-filter" id="bm-sticky-filter"></div>

<style>
  .bm-sticky-filter { display: none; }
  @media screen and (max-width: 749px) {
    .bm-sticky-filter {
      display: block;
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      padding: 8px 12px;
      background: #fff;
      box-shadow: 0 -2px 8px rgba(0,0,0,0.12);
      z-index: 100;
    }
    #root { padding-bottom: 58px !important; }
  }
</style>

<script>
(function() {
  if (window.innerWidth > 749) return;
  var bar = document.getElementById('bm-sticky-filter');
  if (!bar) return;

  var label = {{ bm_filter_label | json }};
  var svgIcon = '<svg style="width:16px;height:16px;margin-right:8px;flex-shrink:0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 15 13.5" fill="currentColor" aria-hidden="true"><path d="M5.25 0c-.7 0-1.13-.03-1.61.17A2.25 2.25 0 0 0 2.42 1.39c-.1.26-.08.58-.09.86H.75a.75.75 0 0 0 0 1.5h1.58c.02.28-.01.6.09.86a2.25 2.25 0 0 0 1.22 1.22c.48.2.91.17 1.61.17s1.13.03 1.61-.17a2.25 2.25 0 0 0 1.22-1.22c.2-.48.17-.91.17-1.61s.03-1.13-.17-1.61A2.25 2.25 0 0 0 6.86.17C6.38-.03 5.95 0 5.25 0zm0 1.5c.7 0 .97.03 1.04.06a.75.75 0 0 1 .4.4c.03.07.06.34.06 1.04s-.03.97-.06 1.04a.75.75 0 0 1-.4.4c-.07.03-.34.06-1.04.06s-.97-.03-1.04-.06a.75.75 0 0 1-.4-.4C3.78 3.97 3.75 3.7 3.75 3s.03-.97.06-1.04a.75.75 0 0 1 .4-.4C4.28 1.53 4.55 1.5 5.25 1.5zm4.5.75a.75.75 0 0 0 0 1.5h4.5a.75.75 0 0 0 0-1.5zm0 5.25c-.7 0-1.13-.03-1.61.17a2.25 2.25 0 0 0-1.22 1.22c-.2.48-.17.91-.17 1.61s-.03 1.13.17 1.61a2.25 2.25 0 0 0 1.22 1.22c.48.2.91.17 1.61.17s1.13.03 1.61-.17a2.25 2.25 0 0 0 1.22-1.22c.1-.26.08-.58.09-.86h1.58a.75.75 0 0 0 0-1.5h-1.58c-.02-.28.01-.6-.09-.86a2.25 2.25 0 0 0-1.22-1.22c-.48-.2-.91-.17-1.61-.17zm0 1.5c.7 0 .97.03 1.04.06a.75.75 0 0 1 .4.4c.03.07.06.34.06 1.04s-.03.97-.06 1.04a.75.75 0 0 1-.4.4c-.07.03-.34.06-1.04.06s-.97-.03-1.04-.06a.75.75 0 0 1-.4-.4c-.03-.07-.06-.34-.06-1.04s.03-.97.06-1.04a.75.75 0 0 1 .4-.4c.07-.03.34-.06 1.04-.06zm-9 .75a.75.75 0 0 0 0 1.5h4.5a.75.75 0 0 0 0-1.5z"/></svg>';

  var moving = false; /* Flag to prevent MutationObserver re-entry */

  function styleLink(link) {
    link.style.cssText = 'display:flex!important;align-items:center;justify-content:center;width:100%;height:42px;padding:0 16px;background:#1a1a1a;color:#fff;border:none;border-radius:4px;font-family:inherit;font-size:14px;font-weight:600;letter-spacing:0.02em;text-decoration:none;cursor:pointer;-webkit-tap-highlight-color:transparent;';
    link.innerHTML = svgIcon + '<span style="line-height:1">' + label + '</span>';
    /* Remove theme's original classes that might interfere */
    link.className = '';
    /* Keep the critical data-panel attribute */
    link.setAttribute('data-panel', 'filters-aside');
  }

  function moveLink() {
    var link = document.querySelector('.f8sr .link-btn a[data-panel="filters-aside"]');
    if (!link) link = document.querySelector('.f8sr a[data-panel="filters-aside"]');
    if (!link) return;

    moving = true;
    styleLink(link);
    bar.innerHTML = '';
    bar.appendChild(link);
    moving = false;
  }

  /* Initial move */
  moveLink();

  /* After AJAX filter updates: move the new link again */
  var debounce = null;
  var obs = new MutationObserver(function() {
    if (moving) return;
    clearTimeout(debounce);
    debounce = setTimeout(function() {
      /* Check if there's a new filter link in .f8sr (AJAX put it back) */
      var fresh = document.querySelector('.f8sr .link-btn a[data-panel="filters-aside"]')
               || document.querySelector('.f8sr a[data-panel="filters-aside"]');
      if (fresh) moveLink();
    }, 250);
  });
  var root = document.getElementById('root');
  if (root) obs.observe(root, { childList: true, subtree: true });
})();
</script>
