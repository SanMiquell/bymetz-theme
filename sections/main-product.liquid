{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{%- liquid
   assign custom_height_ratio = section.settings.custom_product_image_ratio | divided_by: 100.0
   assign image_width = 430
   assign image_height = image_width | times: custom_height_ratio
   assign image_width_small = image_width | divided_by: 3
   assign image_height_small = image_height | divided_by: 3

    assign current_variant = product.selected_or_first_available_variant
    assign featured_media_position = current_variant.featured_media.position
    unless featured_media_position
        assign featured_media_position = 0
    endunless
    assign variant_selection_blocks = section.blocks | where: "type", "variant_selection"
    assign variant_bulk = section.blocks | where: "type", "variant_bulk"
    assign buy_button_block = section.blocks | where: "type", "buy_button"
    assign show_default = true
    if variant_bulk.size != 0 and product.variants.size > 1
        assign show_default = false
    endif
    assign title_block = section.blocks | where: "type", "title" | first
    assign price_block = section.blocks | where: "type", "price" | first
    assign first_block = section.blocks | first
    assign sharing_product = product.current_variant | default: product

    assign show_price = true
    if settings.login_for_prices and customer == nil
        assign show_price = false
    endif

    assign main_width = 700 | minus: 38 | minus: 38
    if section.settings.thumbs_layout == 'aside'
        assign main_width = main_width | minus: 54
    endif
    assign sizes = '(min-width: 1000px) ' | append: main_width | append: 'px, 100vw'

    assign media_images = product.media

    assign variant_selection_block = section.blocks | where: "type", "variant_selection" | first
    assign show_selected_variant_images = variant_selection_block.settings.show_selected_variant_images
    assign triggers = settings.color_swatch_name | newline_to_br | strip_newlines | replace: '<br />', '|' | split: '|'
    if settings.enable_color_swatches and show_selected_variant_images
      for option in product.options_with_values
          if triggers contains option.name
              assign current_color = option.selected_value
              break
          endif
      endfor
    endif
    if current_color
        assign select_featured_media = ''
        for variant in product.variants
            assign options = variant.options | map: 'name'
            if options contains current_color and variant.featured_media != blank
                assign selected_color_products = selected_color_products | append: variant.featured_media.id | append: ','
            endif
        endfor

        assign select_featured_media = selected_color_products | split: ',' | compact | uniq
        assign video = product.media | where: "media_type", 'video'

        if video != blank
            assign select_featured_media = video | concat: select_featured_media
        endif

        assign current_variant_media_id = current_variant.featured_media.id
        if select_featured_media.size == 0
            assign media_images = product.media
        else
            assign media_images = select_featured_media
            for image in media_images
                if image.media_type
                    assign image_id = image.id
                else
                    assign image_id = image | plus: 0
                endif
                if image_id == current_variant_media_id
                    assign featured_media_position = forloop.index
                    break
                endif
            endfor
        endif
    else
        assign show_selected_variant_images = false
    endif
    assign last_images = media_images.size | minus: 2 | modulo: 3

    assign preorder = false
    if current_variant.inventory_management != nil and current_variant.inventory_policy == 'continue' and current_variant.available and current_variant.inventory_quantity <= 0 and settings.preorder and product.gift_card? == false and show_default
        assign preorder = true
    endif

    assign form_id = 'main-product-form-' | append: product.id

    assign fill_images = section.settings.fill_images
    assign fill_first_image = fill_images
    if fill_images and section.settings.fill_not_first
        assign fill_first_image = false
    endif

    assign rating_value = false
    assign rating_count = false
    if product.metafields.syncer.reviews
        assign locale_ratings = product.metafields.syncer.reviews.value.reviews[localization.language.iso_code]
        if locale_ratings
          assign rating_value = locale_ratings.rating
          assign rating_count = locale_ratings.count
        else
          assign rating_value = product.metafields.syncer.reviews.value.cumulative_rating
          assign rating_count = product.metafields.syncer.reviews.value.total_reviews
        endif
    elsif product.metafields.reviews.rating
        assign rating_value = product.metafields.reviews.rating.value
        assign rating_count = product.metafields.reviews.rating_count
    endif
-%}

{%- if show_default == false -%}
  <link rel="stylesheet" href="{{ 'async-product-variants.css' | asset_url }}">
{%- endif -%}

{%- capture header -%}
    {%- liquid
    assign show_list = false
    if rating_value and title_block.settings.show_product_rating
        assign show_list = true
    elsif title_block.settings.show_vendor_brand or title_block.settings.show_vendor_name
        if product.vendor != "vendor-unknown" and product.vendor != shop.name
            assign show_list = true
        endif
    endif
    -%}
    <header {{ title_block.shopify_attributes }} class="class-x">
        <{{ title_block.settings.title_size }} class="{% if show_list %}m5{% endif %} ff-{{ title_block.settings.title_font }} mob-{{ title_block.settings.mobile_title_size }}">{{ product.title | escape }}</{{ title_block.settings.title_size }}>
        {%- if show_list -%}
            <ul class="l4dr m15 base-font">
                {%- if rating_value and title_block.settings.show_product_rating -%}
                  {% capture rating_label %}
                        {%- if rating_count -%}{{ rating_count }} <span>{{ 'product.reviews.count' | t: count: rating_count }}</span>{%- endif -%}
                  {% endcapture %}
                  {% render 'rating-stars', value: rating_value, label: rating_label, link: '#section-reviews', list: true %}
                {%- endif -%}
                {%- if title_block.settings.show_vendor_brand or title_block.settings.show_vendor_name -%}
                    {%- if product.vendor != "vendor-unknown" and product.vendor != shop.name -%}
                        <li>{%- if title_block.settings.show_vendor_brand %}<span class="strong">{{ 'product.vendor' | t }}</span>{%- endif -%}
                            {%- liquid
                                assign vendor_handle = product.vendor | handleize
                                assign vendor_collection = collections[vendor_handle]
                            -%}
                            {%- if vendor_collection != blank and title_block.settings.show_vendor_name -%}<a href="{{ vendor_collection.url }}">{{ product.vendor }}</a>{%- elsif title_block.settings.show_vendor_name -%}{{ product.vendor | link_to_vendor }}{%- endif -%}
                        </li>
                    {%- endif -%}
                {%- endif -%}
            </ul>
        {%- endif -%}
    </header>
{%- endcapture -%}

{%- capture variant_bulk_price -%}
    {% comment %} <span {{ price_block.shopify_attributes }}>{{ 'cart.subtotal' | t }} <span class="s1bx rounded inline font-regular size-small bulk-qty">0</span><br> <span class="bulk-price s1pr{% unless show_price %} s1bl{% endunless %}" style="font-size: {{ price_block.settings.font_size }}px;">{% if show_price %}{{ '0' | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}</span></span> {% endcomment %}
    {% comment %} <span {{ price_block.shopify_attributes }} style="--price_block_font_size: {{ price_block.settings.font_size }}px">{% render 'price', product: product, variant: variant, origin: 'bulk-subtotal', source: 'product' %}</span> {% endcomment %}

    {% comment %} <span {{ price_block.shopify_attributes }}>{{ 'cart.subtotal' | t }} <span class="s1bx rounded inline font-regular size-small bulk-qty">0</span><br> <span class="bulk-price s1pr{% unless show_price %} s1bl{% endunless %}" style="font-size: {{ price_block.settings.font_size }}px;">{% if show_price %}{{ '0' | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}</span>
        {% if settings.productcards_show_tax -%}<span class="size-12 font-regular">{%- if cart.taxes_included -%}{{ 'product.including_tax' | t }}{%- else -%}{{ 'product.excluding_tax' | t }}{%- endif -%}</span>{%- endif -%}
    </span> {% endcomment %}

    <span {{ price_block.shopify_attributes }} style="--price_block_font_size: {{ price_block.settings.font_size }}px">
    {% render 'price', product: product, variant: product.selected_or_first_available_variant, origin: 'bulk-subtotal', source: 'product' %}
    {% if price_block.settings.show_tax %}<span data-syncer-vat-incl class="size-small font-regular">{{ 'product.including_tax' | t }}</span><span data-syncer-vat-excl class="size-12 font-regular">{{ 'product.excluding_tax' | t }}</span>{%- endif -%}
    </span>
{%- endcapture -%}

<article id="main-product" class="m6pr m6pr-{{ section.id }}{% if section.settings.width == 'wide' %} fullwidth{% endif %}{% if section.settings.multiply_bg_mobile and settings.multiply_product_images != 'none' and fill_images == false %} align-labels-left{% endif %}"
    style="
        {% if section.settings.multiply_bg_mobile and settings.multiply_product_images != 'none' %}
            --m6pr_bg: var(--{{ settings.multiply_product_images_color_palette }});
        {% endif %}
        --cont_w: {% if section.settings.width == 'wide' %}40%{% else %}50%{% endif %};
    "
     data-template="{{ section.id }}" data-form-id="{{ form_id }}">
    {%- if title_block.settings.layout == 'title-right' and title_block.settings.layout_mobile == 'title-top' -%}
        {{ header | replace: 'class-x', 'mobile-only' }}
    {%- elsif title_block.settings.layout == 'title-top' and title_block.settings.layout_mobile == 'title-bottom' -%}
        {{ header | replace: 'class-x', 'mobile-hide' }}
    {%- elsif title_block.settings.layout == 'title-top' and title_block.settings.layout_mobile == 'title-top' %}
        {{ header | replace: 'class-x', '' }}
    {%- endif -%}
    <div class="l4pr-container">
        <ul class="l4pr
      {% if section.settings.show_thumbs_desktop == false %}no-thumbs-desktop{% endif %}{% if section.settings.show_thumbs_mobile == false %} no-thumbs-mobile{% endif %}
      {% if section.settings.thumbs_layout == 'aside' and section.settings.show_thumbs_desktop %}aside-pager{% endif %}
      {% unless section.settings.media_layout == 'slider' %}static{% endunless %}
      {% if section.settings.width_mobile == 'wide' %}mobile-wide{% endif %}
      {% if section.settings.width == 'wide' %}{% if section.settings.media_layout != 'slider' or section.settings.show_thumbs_desktop == false %}offset{% endif %}{% endif %}
      {% if section.settings.images_grid_spacing == 0 and section.settings.media_layout != 'slider' %}no-bd-radius{% endif %}
      no-scrollbar
      "
      style="
      --ratio:{{ custom_height_ratio }};
      --dist: {{ section.settings.images_grid_spacing }}px;
      --img_padding:{{ section.settings.images_padding }}%;--img_vertical_position:{{ section.settings.images_vertical_position }}%;
      "
      data-media-size="{{ media_images.size }}"
     {% if show_selected_variant_images and settings.enable_color_swatches %}data-variant-image="true"{% endif %}
     data-featured_media_position={{ featured_media_position }}>
            {%- if media_images.size == 0 -%}
                <li>
                    {%- render 'product-labels' -%}
                    <picture>
                        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    </picture>
                </li>
            {%- endif -%}
            {%- for media_image in media_images -%}
              {% if media_image != blank %}
                {%- liquid
                    if media_image.media_type
                        assign media = media_image
                    else
                        assign media_id_number = media_image | plus: 0
                        assign matched_media = product.media | where: 'id', media_id_number | first
                        assign media = matched_media
                    endif
                    if section.settings.media_layout == 'collage'
                        assign images_left = forloop.length | minus: forloop.index
                        if images_left < last_images
                            assign width = 100 | divided_by: last_images
                            assign width_class = 'w' | append: width
                        else
                            assign width_class = 'w33'
                        endif
                    endif
                -%}
                <li class="has-anchor{% if section.settings.media_layout == 'collage' and forloop.index > 2 %} {{ width_class }}{% endif %}">
                  {% unless section.settings.media_layout == 'slider' %}
                    <span class="anchor" id="section-product-{{ forloop.index }}"></span>
                  {% endunless %}
                  <a data-fancybox="product-gallery-{{ product.id }}"
                    {% if media.media_type == 'image' %}
                      href="{{ media | image_url }}"
                    {% elsif media.media_type == 'external_video' %}
                      href="{{ media | external_video_url }}"
                    {% elsif media.media_type == 'video' %}
                      {%- liquid
                        assign source = media.sources | where: "height", 1080 | where: "format", "mp4" | first
                        if source == nil
                            assign source = media.sources | where: "format", "mp4" | first
                        endif
                        if source == nil
                            assign source = media.sources | where: "format", "mov" | first
                        endif
                        if source == nil
                            assign source = media.sources.first
                        endif
                      -%}
                        href="{{ source.url }}"
                      {% elsif media.media_type == 'model' %}
                        href="#model-3d-{{ forloop.index }}"
                      {% endif %}
                      data-gallery-thumb="
                      {% if fill_images %}
                        {{ media.preview_image | image_url: width: image_width_small, height: image_height_small, crop: 'center' }}
                      {% else %}
                        {{ media.preview_image | image_url: height: image_height_small }}
                      {% endif %}
                      "
                      >
                      {%- if forloop.first -%}
                        {%- render 'product-labels' -%}
                        {%- assign fill = fill_first_image -%}
                      {%- else -%}
                        {%- assign fill = fill_images -%}
                      {%- endif -%}
                      <picture class="{% if settings.multiply_product_images == 'multiply' %}img-multiply{% elsif settings.multiply_product_images == 'multiply-bg' %}img-multiply-bg{% endif %}{% if fill %} cover{% endif %}">
                        {%- liquid
                            assign lazyload = true
                            if forloop.index == featured_media_position
                                assign lazyload = false
                            elsif forloop.first and featured_media_position == 0
                                assign lazyload = false
                            endif
                        -%}
                        {% if media.image %}
                          {% capture srcset %}
                            {%- liquid
                              if fill
                                  render 'image-srcset', image: media, format: 'custom', image_height: custom_height_ratio, crop: 'center'
                              else
                                  render 'image-srcset', image: media
                              endif
                              -%}
                          {% endcapture %}
                          {%- if lazyload -%}
                              {{ media | image_url: width: image_width, height: image_height, crop: 'center' | image_tag: srcset: srcset, sizes: sizes, loading: 'lazy', style: 'object-position:unset;' }}
                          {%- else -%}
                              {{ media | image_url: width: image_width, height: image_height, crop: 'center' | image_tag: srcset: srcset, sizes: sizes, preload: true, style: 'object-position:unset;' }}
                          {%- endif -%}
                        {%- elsif media.media_type != 'model' -%}
                          {% if section.settings.media_layout != 'slider' %}
                              {%- liquid
                                assign source = media.sources | where: "height", 1080 | where: "format", "mp4" | first
                                if source == nil
                                  assign source = media.sources | where: "format", "mp4" | first
                                endif
                                if source == nil
                                  assign source = media.sources | where: "format", "mov" | first
                                endif
                                if source == nil
                                  assign source = media.sources.first
                                endif
                              -%}
                              <video class="lazy" autoplay muted loop playsinline poster="{{ media.preview_image | image_url }}">
                                <source data-src="{{ source.url }}" type="video/mp4">
                              </video>
                          {% else %}
                            {%- if lazyload -%}
                                {{ media.preview_image | image_url: width: image_width, height: image_height, crop: 'center' | image_tag: sizes: sizes, loading: 'lazy' }}
                            {%- else -%}
                                {{ media.preview_image | image_url: width: image_width, height: image_height, crop: 'center' | image_tag: sizes: sizes, preload: true }}
                            {%- endif -%}
                          {% endif %}
                        {%- endif -%}
                        {%- if media.media_type == 'external_video' or media.media_type == 'video' -%}
                          {%- if section.settings.media_layout == 'slider' -%}
                              <i aria-hidden="true" class="icon-play"></i>
                          {%- endif -%}
                        {%- elsif media.media_type == 'model' -%}
                          <span id="model-3d-{{ forloop.index }}" class="model-3d">
                            {{ media | model_viewer_tag: shadow-intensity: "1" }}
                            <button
                              data-shopify-xr
                              data-shopify-model3d-id="{{ media.id }}"
                              data-shopify-title="{{ product.title | escape }}"
                              data-shopify-xr-hidden
                            >
                              <i aria-hidden="true" class="icon-cube"></i> {{ 'product.view_in_your_space' | t }}
                            </button>
                          </span>
                          <i aria-hidden="true" class="icon-cube"></i>
                        {%- endif -%}
                      </picture>
                  </a>
                  {%- if media.media_type == 'model' -%}
                    <button
                      data-shopify-xr
                      data-shopify-model3d-id="{{ media.id }}"
                      data-shopify-title="{{ product.title | escape }}"
                      data-shopify-xr-hidden
                    ><i aria-hidden="true" class="icon-cube"></i> {{ 'product.view_in_your_space' | t }}</button>
                  {%- endif -%}
                </li>
              {% endif %}
            {%- endfor -%}
            {%- if section.settings.img_info != empty -%}
                <li class="sticky base-font">
                    <div class="palette-{{ section.settings.img_info_color_palette }}
                                module-color-palette
                                m6bx
                                inline"
                    >
                        {{ section.settings.img_info }}
                    </div>
                </li>
            {%- endif -%}
        </ul>
    </div>
    {%- assign has_model = media_images | where: "media_type", "model" | first -%}
    {%- if has_model -%}
        <script type="application/json" id="ProductJSON-{{ product.id }}">
        {{ media_images | where: 'media_type', 'model' | json }}
      </script>
    {%- endif -%}
    <div>
        {%- liquid
            if first_block == title_block
                if title_block.settings.layout == 'title-right'
                    if title_block.settings.layout_mobile == 'title-top'
                        echo header | replace: 'class-x', 'mobile-hide'
                    else
                        echo header | replace: 'class-x', ''
                    endif
                elsif title_block.settings.layout_mobile == 'title-bottom'
                    echo header | replace: 'class-x', 'mobile-only'
                endif
            endif
            assign form_class = 'f8pr f8pr-anchor f8pr-buy-button m15'
        -%}
        <div class="f8pr base-font{%- if buy_button_block.size == 0 %} f8pr-anchor{% endif %}">
            <legend>{{ 'product.form.title' | t }}</legend>
            {%- for block in section.blocks -%}
                {%- case block.type -%}
                {%- when '@app' -%}
                    {% render block %}
                {%- when 'spacer' -%}
                    <div class="module-spacer desktop-only" style="margin-bottom:{{ block.settings.height }}px;" {{ block.shopify_attributes }}></div>
                    <div class="module-spacer desktop-hide" style="margin-bottom:{{ block.settings.height_mobile }}px;"></div>
                {%- when 'custom_liquid' -%}
                    {{ block.settings.custom_liquid }}
                {%- when 'custom_html' -%}
                    {{ block.settings.custom_html }}
                {%- when 'title' -%}
                    {%- if forloop.first == false -%}
                        {%- if title_block.settings.layout == 'title-right' -%}
                            {%- if title_block.settings.layout_mobile == 'title-top' %}
                                {{ header | replace: 'class-x', 'mobile-hide' }}
                            {%- else -%}
                                {{ header | replace: 'class-x', '' }}
                            {%- endif -%}
                        {%- elsif title_block.settings.layout_mobile == 'title-bottom' -%}
                            {{ header | replace: 'class-x', 'mobile-only' }}
                        {%- endif -%}
                    {%- endif -%}
                {%- when 'vendor' -%}
                    {%- if block.settings.show_vendor_brand or block.settings.show_vendor_name -%}
                        {%- if product.vendor != "vendor-unknown" and product.vendor != shop.name -%}
                            <ul class="l4dr col m10" {{ block.shopify_attributes }}>
                                <li>{%- if block.settings.show_vendor_brand %}<span class="strong">{{ 'product.vendor' | t }}</span>{%- endif -%}
                                    {%- liquid
                                        assign vendor_handle = product.vendor | handleize
                                        assign vendor_collection = collections[vendor_handle]
                                    -%}
                                    {%- if vendor_collection != blank and block.settings.show_vendor_name -%}<a href="{{ vendor_collection.url }}">{{ product.vendor }}</a>{%- elsif block.settings.show_vendor_name -%}{{ product.vendor | link_to_vendor }}{%- endif -%}
                                </li>
                            </ul>
                        {%- endif -%}
                    {%- endif -%}
                {%- when 'payments' -%}
                    {%- capture payment_classes -%}m10 base-font text-{{ block.settings.alignment }}{%- endcapture -%}
                    {%- render 'payment-methods', shopify_attributes: block.shopify_attributes, classes: payment_classes %}
                {%- when 'product_ratings' -%}
                {%- if rating_value -%}
                    <ul class="l4dr m10" {{ block.shopify_attributes }}>
                        <li class="overlay-gray">
                            {% capture rating_label %}
                                {%- if rating_count -%}{{ rating_count }} <span>{{ 'product.reviews.count' | t: count: rating_count }}</span>{%- endif -%}
                            {% endcapture %}
                            {% render 'rating-stars', value: rating_value, label: rating_label, link: '#section-reviews' %}
                        </li>
                    </ul>
                {%- endif -%}
                {%- when 'share_buttons' -%}
                    {%- liquid
                        assign share_whatsapp = block.settings.share_whatsapp
                        assign share_facebook = block.settings.share_facebook
                        assign share_twitter = block.settings.share_twitter
                        assign share_pinterest = block.settings.share_pinterest
                        assign share_messenger = block.settings.share_messenger
                        assign share_email = block.settings.share_email
                    -%}
                    {%- if share_whatsapp or share_facebook or share_twitter or share_pinterest or share_messenger or share_email -%}
                        <ul class="l4dr m10{% unless block.settings.share_mobile %} mobile-hide{% endunless %}" {{ block.shopify_attributes }}>
                            <li class="has-social">
                                <a href="./" class="toggle mobile-hide" aria-label="{{ 'social_share.share_this_product' | t }}"><i aria-hidden="true" class="icon-upload size-18"></i> <span>{{ 'social_share.share_this_product' | t }}</span></a>
                                <ul class="l4sc box mobile-hide">
                                    {%- render 'social-share-buttons', share: sharing_product, share_whatsapp: share_whatsapp, share_facebook: share_facebook, share_twitter: share_twitter, share_pinterest: share_pinterest, share_messenger: share_messenger, share_email: share_email -%}
                                </ul>
                                <a href="./" data-share="./" role="button" class="mobile-only overlay-theme" aria-label="{{ 'social_share.share_this_product' | t }}"><i aria-hidden="true" class="icon-upload size-18"></i> <span class="hidden">{{ 'social_share.share_this_product' | t }}</span></a>
                            </li>
                        </ul>
                    {%- endif -%}
                {%- when 'tags' -%}
                    {% if product.tags.size > 0 -%}
                        <div {{ block.shopify_attributes }}>
                            {%- if block.settings.title != empty -%}
                                <{{ block.settings.title_size }}>{{ block.settings.title }}</{{ block.settings.title_size }}>
                            {% endif %}
                          <ul class="l4in">
                              {%- for tag in product.tags -%}
                                <li class="palette-{{ block.settings.color_palette }} module-color-palette m6bx compact"><a href="{{ routes.all_products_collection_url }}/{{ tag | handleize }}">{{ tag }}</a></li>
                              {%- endfor -%}
                          </ul>
                      </div>
                    {%- endif -%}
                {%- when 'text' -%}
                    {%- if block.settings.text != empty -%}
                        <div class="palette-{{ block.settings.color_palette }} module-color-palette m6bx compact" {{ block.shopify_attributes }}>
                            {{ block.settings.text }}
                        </div>
                    {%- endif -%}
                {%- when 'short_description' -%}
                    {%- if settings.product_short_description != 'none' %}
                        {%- liquid
                            if settings.product_short_description == 'custom'
                                assign product_short_description_namespace = settings.product_short_description_text | split: '.' | first
                                assign product_short_description_key = settings.product_short_description_text | split: '.' | last
                                assign short_description = product.metafields[product_short_description_namespace][product_short_description_key] | metafield_tag
                                assign custom_short_description = true
                            else
                                assign short_description = product.description | strip_html | truncatewords: 20
                            endif
                        -%}
                        {%- if short_description != empty and short_description != nil -%}
                            <p class="m15 mobile-hide" {{ block.shopify_attributes }}>
                                {{ short_description }}
                                {%- if block.settings.show_read_more -%}
                                    <a href="#section-info" class="strong">{{ 'general.read_more.read_more' | t }}</a>
                                {%- endif -%}
                            </p>
                        {%- endif -%}
                    {%- endif -%}
                {%- when 'pickup' -%}
                    {%- liquid
                        if show_default == false
                            continue
                        endif

                        assign pick_up_availabilities = current_variant.store_availabilities | where: 'pick_up_enabled', true
                        assign pickup_available = false
                        if pick_up_availabilities.size > 0
                            for pick_up_location in pick_up_availabilities
                                if pick_up_location.available
                                    assign pickup_available = true
                                    break
                                endif
                            endfor
                        endif
                    -%}
                    <ul id="f8pr-pickup" class="l4dr col f8pr-pickup pickup{% unless pickup_available %} hidden{% endunless %}" {{ block.shopify_attributes }}>
                        <li><span>{{ 'product.pickup_availability.free_pickup' | t }} <a href="#pickup-availability" data-panel="pickup-availability" data-id="{{ current_variant.id }}" class="inline underline">{{ 'product.pickup_availability.our_stores' | t }}</a></span></li>
                    </ul>
                {%- when 'button' -%}
                   {%- if block.settings.link_text != empty and block.settings.link_url != blank -%}
                        {%- liquid
                          assign button_color = block.settings.button_style | split: ' ' | first
                          assign button_style = block.settings.button_style | split: ' ' | last
                          assign is_link = false
                          if button_style == 'link'
                            assign is_link = true
                          endif
                        -%}
                      <p class="link{% unless is_link %}-btn{% if block.settings.wide %} wide{% endif %}{% endunless %}" {{ block.shopify_attributes }}>
                        <a href="{{ block.settings.link_url }}" class="overlay-{{ button_color }} {% if is_link %}inline strong{% elsif button_style == 'inv' %}inv{% endif %}">
                            <span {% if is_link %}class="link-underline"{% endif %}>{{ block.settings.link_text }}</span>
                        </a>
                      </p>
                   {%- endif -%}
                {%- when 'compare' -%}
                    {%- if settings.enable_compare -%}
                        <p class="check" {{ block.shopify_attributes }}>
                            <input type="checkbox" id="compare-{{ section.id }}-{{ block.id }}" name="product-compare" data-product-url="{{ product.url }}" data-product-id="{{ product.id }}" disabled>
                            <label for="compare-{{ section.id }}-{{ block.id }}"><span data-checked-hide>{{ 'product.compare.add_to_compare' | t }}</span> <span data-checked-show>{{ 'product.compare.added_to_compare' | t }}</span></label>
                        </p>
                    {%- endif -%}
                {%- when 'quote' -%}
                  {% capture title %}
                    {%- if block.settings.title != empty -%}
                      {% unless block.settings.wide %}<div>{% endunless %}
                        <span class="f8pr-quote-title label{% if block.settings.wide %} m15{% endif %}">
                            {{ block.settings.title }}
                        </span>
                      {% unless block.settings.wide %}</div>{% endunless %}
                    {%- endif -%}
                  {% endcapture %}
                  {% capture button %}
                    {% if block.settings.link_text != empty %}
                        {%- liquid
                          assign button_color = block.settings.button_style | split: ' ' | first
                          assign button_style = block.settings.button_style | split: ' ' | last
                          assign is_link = false
                          if button_style == 'link'
                            assign is_link = true
                          endif
                        -%}
                      {% unless block.settings.wide %}<div>{% endunless %}
                      <p class="link{% unless is_link %}-btn{% if block.settings.wide %} wide{% endif %}{% endunless %} m0 form-group">
                        <a data-block-popup="block-popup-{{ section.id }}-{{ block.id }}-{{ current_variant.id }}" class="overlay-{{ button_color }} {% if is_link %}inline strong{% elsif button_style == 'inv' %}inv{% endif %}">
                          <span class="{% if is_link %}link-underline{% endif %}">{{ block.settings.link_text }}</span>
                        </a>
                      </p>
                      {% unless block.settings.wide %}</div>{% endunless %}
                    {% endif %}
                    {% endcapture %}
                  {%- if block.settings.title != empty or block.settings.link_text != empty -%}
                    {% if block.settings.show_border %}<hr class="m15 margin-top-0">{% endif %}
                    <div class="{% unless block.settings.wide %}cols align-middle{% endunless %} m15 f8pr-quote" {{ block.shopify_attributes }}>
                        {{ title }}
                        {{ button }}
                        <article class="popup-a w630" data-title="block-popup-{{ section.id }}-{{ block.id }}-{{ current_variant.id }}" style="--main_mr: 16px; --ppd: 20px;">
                          {%- if block.settings.popup_title != empty or block.settings.text != empty -%}
                            <header class="base-font">
                              {%- if block.settings.popup_title != blank -%}
                                <div class="title-styling
                                  {% if block.settings.popup_title_underline_style != 'none' %}
                                    title-underline-none
                                    {% if block.settings.popup_title_underline_style contains 'accent' %}
                                      title-underline-accent
                                    {% elsif block.settings.popup_title_underline_style contains 'gradient' %}
                                      title-underline-gradient
                                    {% endif %}
                                    {% if block.settings.popup_title_underline_style contains 'secondary_font' %}
                                      title-underline-secondary-font
                                    {% endif %}
                                  {% endif %}
                                ">
                                    {{ block.settings.popup_title }}
                                </div>
                              {%- endif -%}
                              {%- if block.settings.text != empty -%}
                                {{ block.settings.text }}
                              {%- endif -%}
                            </header>
                          {%- endif  -%}
                          {%- assign form_classes = 'f8vl base-font' -%}
                          {%- assign contact_form_id = section.id | append: '-' | append: block.id -%}
                          {%- form 'contact', id: contact_form_id, class: form_classes -%}
                              {%- if form.errors -%}
                                  <script>
                                      document.addEventListener('DOMContentLoaded', function () {
                                          var alertAttributes = { message: "{{ 'service.contact_form.email' | t }} {{ form.errors.messages['email'] }}", type: "error", origin: "contact" },
                                              showAlertEvent = new CustomEvent("showAlert", {detail: alertAttributes});
                                          window.dispatchEvent(showAlertEvent);
                                      });
                                  </script>
                              {%- elsif form.posted_successfully? -%}
                                  <script>
                                      document.addEventListener('DOMContentLoaded', function () {
                                          var alertAttributes = { message: "{{ 'service.contact_form.posted_successfully' | t }}", type: "success", origin: "contact" },
                                              showAlertEvent = new CustomEvent("showAlert", {detail: alertAttributes});
                                          window.dispatchEvent(showAlertEvent);
                                      });
                                  </script>
                              {%- endif -%}
                              <div class="cols cols-mobile">
                                <p class="w80">
                                  <label for="subject-{{ section.id }}-{{ block.id }}">{{ 'service.contact_form.subject' | t }}</label>
                                  <input type="text" id="subject-{{ section.id }}-{{ block.id }}" name="contact[subject]" value="{{ product.title }}" {% if block.settings.show_placeholder %}placeholder="{{ 'service.contact_form.subject' | t }}"{% endif %}>
                                </p>
                                <p class="w20">
                                  <label for="quantity-{{ section.id }}-{{ block.id }}">{{ 'service.contact_form.quantity' | t }}</label>
                                  <input type="number" id="quantity-{{ section.id }}-{{ block.id }}" name="contact[quantity]" value="1" {% if block.settings.show_placeholder %}placeholder="{{ 'service.contact_form.quantity' | t }}"{% endif %}>
                                </p>
                              </div>
                              <div class="cols">
                                <p class="w50">
                                  <label for="name-{{ section.id }}-{{ block.id }}">{{ 'service.contact_form.name' | t }}</label>
                                  <input type="text" id="name-{{ section.id }}-{{ block.id }}" name="contact[name]" {% if block.settings.show_placeholder %}placeholder="{{ 'service.contact_form.name' | t }}"{% endif %}>
                                </p>
                                <p class="w50">
                                  <label for="compay-{{ section.id }}-{{ block.id }}">{{ 'service.contact_form.company' | t }}</label>
                                  <input type="text" id="company-{{ section.id }}-{{ block.id }}" name="contact[company]" {% if block.settings.show_placeholder %}placeholder="{{ 'service.contact_form.company' | t }}"{% endif %}>
                                </p>
                              </div>
                              <div class="cols">
                                <p class="w50">
                                  <label for="email-{{ section.id }}-{{ block.id }}">{{ 'service.contact_form.email' | t }}<span class="overlay-rose">*</span></label>
                                  <input type="email" id="email-{{ section.id }}-{{ block.id }}" name="contact[email]" {% if block.settings.show_placeholder %}placeholder="{{ 'service.contact_form.email' | t }}"{% endif %} required>

                                </p>
                                <p class="w50">
                                  <label for="phone-{{ section.id }}-{{ block.id }}">{{ 'service.contact_form.phone' | t }}</label>
                                  <input type="tel" id="phone-{{ section.id }}-{{ block.id }}" name="contact[phone]" {% if block.settings.show_placeholder %}placeholder="{{ 'service.contact_form.phone' | t }}"{% endif %}>
                                </p>
                              </div>
                              <p class="w50">
                                <label for="body-{{ section.id }}-{{ block.id }}">{{ 'service.contact_form.message' | t }}</label>
                                <textarea id="message-{{ section.id }}-{{ block.id }}" name="contact[body]" {% if block.settings.show_placeholder %}placeholder="{{ 'service.contact_form.quote_message' | t }}"{% endif %}></textarea>
                              </p>
                              <p class="submit text-end"><button type="submit">{{ 'service.contact_form.send' | t }}</button></p>
                          {% endform %}
                        </article>
                    </div>
                    {% if block.settings.show_border %}<hr class="margin-content">{% endif %}
                  {%- endif -%}
                  {% unless block.settings.wide %}
                      {% style %}
                      @media only screen and (min-width: 761px) {
                          #main-product .f8pr-quote .f8pr-quote-title > * {
                            margin-top: 0;
                          }
                          #main-product .f8pr-quote .f8pr-quote-title > *:last-child {
                            margin-bottom: 0;
                          }
                      }
                      {% endstyle %}
                  {% endunless %}
                {%- when 'popup' -%}
                    {%- if block.settings.title != empty or block.settings.text != empty or block.settings.page.content != blank or block.settings.image or block.settings.liquid or block.settings.html -%}
                        {%- if block.settings.link_text != empty -%}
                            {%- liquid
                              assign button_color = block.settings.button_style | split: ' ' | first
                              assign button_style = block.settings.button_style | split: ' ' | last
                              assign is_link = false
                              if button_style == 'link'
                                assign is_link = true
                              endif
                            -%}
                          <p class="link{% unless is_link %}-btn{% if block.settings.wide %} wide{% endif %}{% endunless %}" {{ block.shopify_attributes }}>
                            <a data-block-popup="block-popup-{{ section.id }}-{{ block.id }}-{{ current_variant.id }}" class="overlay-{{ button_color }} {% if is_link %}inline strong{% elsif button_style == 'inv' %}inv{% endif %}">
                                <span {% if is_link %}class="link-underline"{% endif %}>{{ block.settings.link_text }}</span>
                            </a>
                          </p>
                        {%- endif -%}
                    {%- endif -%}
                {%- when 'variant_selection' -%}
                    {%- liquid
                        if variant_bulk.size > 0
                            continue
                        endif

                        assign color_triggers = settings.color_swatch_name | newline_to_br | strip_newlines | replace: '<br />', '|' | split: '|'
                        assign size_triggers = block.settings.size_name | newline_to_br | strip_newlines | replace: '<br />', '|' | split: '|'
                        assign button_options = block.settings.button_options | newline_to_br | strip_newlines | replace: '<br />', '|' | split: '|'
                        assign dropdown_options = block.settings.dropdown_options | newline_to_br | strip_newlines | replace: '<br />', '|' | split: '|'
                    -%}
                    {%- if block.settings.sizechart_title != empty or block.settings.sizechart_text != empty or block.settings.sizechart_page.content != blank or block.settings.sizechart_image != blank or block.settings.sizechart_liquid != blank or block.settings.sizechart_html != blank -%}
                        {%- capture sizechart %}
                            <a href="./" class="strong inline overlay-content" data-panel="sizing-chart-popup-{{ section.id }}-{{ block.id }}"><span class="link-underline">{{ block.settings.sizechart_title | default: "Size chart" }}</span></a>
                        {%- endcapture -%}
                        {%- capture sizechart_popup %}
                            <article id="sizing-chart-popup-{{ section.id }}-{{ block.id }}" class="m6pn">
                                {%- if block.settings.sizechart_title != empty -%}
                                    <{{ settings.drawers_font_size_heading }} class="{{ 'text-' | append: block.settings.sizechart_alignment }}">{{ block.settings.sizechart_title }}</{{ settings.drawers_font_size_heading }}>
                                {%- endif -%}
                                <div>
                                    {{ block.settings.sizechart_text }}
                                    {%- if block.settings.sizechart_page.content != blank -%}
                                        {{ block.settings.sizechart_page.content }}
                                    {%- endif -%}
                                    {%- if block.settings.sizechart_image != blank -%}
                                        <div class="m20">
                                            <img
                                                src="{{ block.settings.sizechart_image | image_url: width: block.settings.sizechart_image_width }}"
                                                srcset="{% render 'image-srcset', image: block.settings.sizechart_image %}"
                                                sizes="
                                                  (min-width: 760px) 500px
                                                  100vw
                                                  "
                                                alt="{{ block.settings.sizechart_image.alt | default: block.settings.sizechart_title | escape }}"
                                                width="{{ block.settings.sizechart_image_width }}"
                                                height="640"
                                                loading="lazy"
                                            >
                                        </div>
                                    {%- endif -%}
                                    {%- if block.settings.sizechart_liquid or block.settings.sizechart_html -%}
                                        <p>
                                            {{ block.settings.sizechart_liquid }}
                                            {{ block.settings.sizechart_html }}
                                        </p>
                                    {%- endif -%}
                                </div>
                            </article>
                        {%- endcapture -%}
                    {%- endif -%}
                    <div class="f8pr-variant-selection no-zindex" {{ block.shopify_attributes }}>
                        {%- if product.has_only_default_variant or product.variants.size == 1 -%}
                            <input name="id" id="id-{{ section.id }}" value="{{ current_variant.id }}" type="hidden" form="{{ form_id }}">
                        {%- endif -%}
                        {%- if product.variants.size > 1 or block.settings.show_single_options -%}
                            {%- liquid
                                assign enable_options = false
                                assign is_color = false
                                assign is_size = false

                                if block.settings.options or product.options.size == 1
                                    if product.options.size > 1
                                        assign enable_options = true
                                    endif
                                    for option in product.options_with_values
                                        if settings.enable_color_swatches and color_triggers contains option.name
                                            assign is_color = true
                                        endif
                                    endfor

                                    for option in product.options_with_values
                                      if sizechart and size_triggers contains option.name
                                        assign is_size = true
                                      endif
                                    endfor
                                endif
                            -%}

                            {%- if product.has_only_default_variant == false -%}
                                {%- liquid
                                    assign variants_with_images = product.variants | where: "image"
                                    assign show_images = true
                                    if is_color
                                        if product.variants.size != variants_with_images.size or block.settings.show_variant_images == false
                                            assign show_images = false
                                        endif
                                    endif
                                    assign selection_type = block.settings.selection_type
                                    if product.options.size == 1
                                        if dropdown_options contains product.options.first
                                            assign selection_type = 'dropdown'
                                        elsif button_options contains product.options.first
                                            assign selection_type = 'buttons'
                                        endif
                                    endif
                                    assign show_variant_picker_image = false
                                    if block.settings.show_variant_images and show_images
                                        assign show_variant_picker_image = true
                                    endif
                                -%}
                                {% unless enable_options %}
                                    {% if selection_type == 'dropdown' %}<p>{% endif %}
                                     <label class="margin-5{% if enable_options %} js-hidden{% endif %} main-product-select" for="id-{{ section.id }}">
                                        {%- unless product.has_only_default_variant -%}
                                            {% if block.settings.show_single_options_title %}{% if product.options.first %}{{ 'product.form.choose_option' | t }}{% else %}{{ product.options.first }}{% endif %}{% endif %}{% if is_color and selection_type == 'buttons' %}<span class="data-change-to-{{ section.id }}">{{ current_variant.title }}</span>{% endif %}
                                        {%- endunless -%}
                                        <span class="text-end">
                                        {% if is_size %}
                                          {{ sizechart }}
                                        {% endif %}
                                        </span>

                                    </label>
                                {% endunless %}
                                {%- if selection_type == 'dropdown' or enable_options -%}
                                    {%- render 'variant-picker',
                                        product: product,
                                        fill_images: fill_images,
                                        show_images: show_variant_picker_image,
                                        form_id: form_id,
                                        section: section,
                                        enable_options: enable_options,
                                        full_variant_dropdown: true,
                                        show_unavailable_variants: block.settings.show_unavailable_variants,
                                        origin: 'product-main'
                                    -%}
                                {%- else -%}
                                    <ul id="f8pr-ul-check-1" class="check margin-10 {% if show_images and block.settings.show_variant_images %}box mobile-scroll{% elsif is_color %}color{% if settings.color_swatch_shape == 'rectangle' %} rect{% endif %}{% else %}box mobile-scroll{% endif %}{% if enable_options %} js-hidden{% endif %}">
                                        {%- for variant in product.variants -%}
                                            {% if block.settings.show_unavailable_variants == false and variant.available == false %}{% continue %}{% endif %}
                                            {% capture swatch %}
                                                {% if variant.options.first.swatch.image %}
                                                  <i aria-hidden="true" class="icon-circle" style="background-image: url('{{ variant.options.first.swatch.image | image_url }}');"></i>
                                                {% elsif variant.options.first.swatch.color %}
                                                  <i aria-hidden="true" class="icon-circle" style="background-color: {{ variant.options.first.swatch.color }};"></i>
                                                {% else %}
                                                    <i aria-hidden="true" class="icon-circle swatch-custom-color-{{ variant.title | handleize }}" style="background-color: {{ variant.title | split: ' ' | last }};"></i>
                                                {% endif %}
                                            {% endcapture %}
                                            <li>
                                                <input type="radio"
                                                       id="option-{{ variant.id }}-{{ section.id }}"
                                                       value="{{ variant.id }}"
                                                       name="id"
                                                       title="{{ variant.title }}"
                                                       {% if variant == current_variant %}checked{% endif %}
                                                    {% unless variant.available %}class="disabled"{% endunless %}
                                                       data-url="{{ product.url }}"
                                                       data-template="{{ section.id }}"
                                                    {% if enable_options %}data-options='{"id":{{ variant.id }},"available":{{ variant.available }},"options":{{ variant.options | json | escape }}}'{% endif %}
                                                    {% if is_color %}data-change=".data-change-to-{{ section.id }}"{% endif %}
                                                       form="{{ form_id }}"
                                                >
                                                <label for="option-{{ variant.id }}-{{ section.id }}" class="">
                                                    {% if variant.image and block.settings.show_variant_images and show_images %}
                                                        <picture>
                                                            <img src="{% if fill_images %}{{ variant.image | image_url: width: image_width_small, height: image_height_small, crop: 'center' }}{% else %}{{ variant.image | image_url: height: image_height_small }}{% endif %}" alt="{{ variant.title }}" width="30" height="23" loading="lazy">
                                                        </picture>
                                                    {% elsif is_color %}
                                                        {{ swatch }}
                                                    {% endif %}
                                                    {% unless is_color %}<span>{{ variant.title }}</span>{% endunless %}
                                                </label>
                                            </li>
                                        {%- endfor -%}
                                    </ul>
                                {%- endif -%}
                            {%- endif -%}

                            {% if enable_options %}
                                {%- for option in product.options_with_values -%}
                                    {%- liquid
                                        assign is_color = false
                                        assign is_size = false
                                        if settings.enable_color_swatches and color_triggers contains option.name
                                            assign is_color = true
                                        endif
                                        if color_triggers contains option.name and block.settings.show_variant_images and product.variants.size == variants_with_images.size
                                            assign option_int = 'option' | append: forloop.index
                                        else
                                            assign option_int = false
                                        endif
                                        if sizechart and size_triggers contains option.name
                                            assign is_size = true
                                        endif

                                        assign selection_type = block.settings.selection_type
                                        if dropdown_options contains option.name
                                            assign selection_type = 'dropdown'
                                        elsif button_options contains option.name
                                            assign selection_type = 'buttons'
                                        endif
                                    -%}
                                    {% if selection_type == 'dropdown' %}
                                        <p class="no-js-hidden{% if option.values.size == 1 and block.settings.show_single_options == false %} hidden{% endif %}">
                                            <label for="option-{{ section.id }}-{{ forloop.index0 }}">
                                                {% if option.name == 'Title' %}{{ 'product.form.choose_option' | t }}{% else %}{{ option.name }}{% endif %}
                                                <span{% if product.variants.size > 1 %} class="text-end"{% endif %}>
                                                    {%- if is_size -%}{{ sizechart }}{%- endif -%}
                                                </span>
                                            </label>
                                            {%- render 'variant-picker',
                                                product: product,
                                                fill_images: fill_images,
                                                show_images: show_variant_picker_image,
                                                form_id: form_id,
                                                section: section,
                                                enable_options: enable_options,
                                                option: option,
                                                forloop_index: forloop.index0,
                                                show_unavailable_variants: block.settings.show_unavailable_variants,
                                                origin: 'product-main'
                                            -%}
                                        </p>
                                    {% else %}
                                        <label for="option-{{ section.id }}-{{ forloop.index0 }}" class="margin-5 no-js-hidden{% if option.values.size == 1 and block.settings.show_single_options == false %} hidden{% endif %}">
                                            {% if option.name == 'Title' %}{{ 'product.form.choose_option' | t }}{% else %}{{ option.name }}{% endif %}{% if is_color %}<span class="data-change-to-option-{{ section.id }}-{{ forloop.index0 }}">{{ option.selected_value }}</span>{% endif %}
                                            <span{% if product.variants.size > 1 %} class="text-end"{% endif %}>
                                                {%- if is_size -%}
                                                    {{ sizechart }}
                                                {%- endif -%}
                                            </span>
                                        </label>
                                        <ul id="f8pr-ul-check-{{ forloop.index | plus: 1 }}" class="check margin-10 {% if show_images == false and is_color %}color{% if settings.color_swatch_shape == 'rectangle' %} rect{% endif %}{% else %}box mobile-scroll{% endif %} no-js-hidden{% if option.values.size == 1 and block.settings.show_single_options == false %} hidden{% endif %}">
                                            {%- for value in option.values -%}
                                                {% capture swatch %}
                                                    {% if value.swatch.image %}
                                                      <i aria-hidden="true" class="icon-circle" style="background-image: url('{{ value.swatch.image | image_url }}');"></i>
                                                    {% elsif value.swatch.color %}
                                                      <i aria-hidden="true" class="icon-circle" style="background-color: {{ value.swatch.color }};"></i>
                                                    {% else %}
                                                        <i aria-hidden="true" class="icon-circle swatch-custom-color-{{ value | handleize }}" style="background-color: {{ value | split: ' ' | last }};"></i>
                                                    {% endif %}
                                                {% endcapture %}
                                                <li>
                                                    <input type="radio"
                                                            data-scroll="#section-product-2"
                                                           id="option-{{ section.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}"
                                                           value="{{ value | escape }}"
                                                           name="options[{{ section.id }}-{{ option.name | escape }}]"
                                                           title="{{ value }}"
                                                           {% if option.selected_value == value %}checked{% endif %}
                                                           data-url="{{ product.url }}"
                                                           data-template="{{ section.id }}"
                                                        {% if is_color %}data-change=".data-change-to-option-{{ section.id }}-{{ forloop.parentloop.index0 }}"{% endif %}
                                                           form="{{ form_id }}"
                                                           {% unless value.variant.available %}class="disabled"{% endunless %}
                                                    >
                                                    <label for="option-{{ section.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}">
                                                        {% if option_int -%}
                                                            {% assign option_variant = product.variants | where: option_int, value | first -%}
                                                            <picture>
                                                                <img src="{% if fill_images %}{{ option_variant.image | image_url: width: image_width_small, height: image_height_small, crop: 'center' }}{% else %}{{ option_variant.image | image_url: height: image_height_small }}{% endif %}" alt="{{ value }}" width="30" height="23" loading="lazy">
                                                            </picture>
                                                            {% unless is_color %}
                                                                <span>{{ value }}</span>
                                                            {% endunless %}
                                                        {% elsif is_color %}
                                                            {{ swatch }}
                                                        {% else %}
                                                            {{ value }}
                                                        {% endif %}
                                                    </label>
                                                </li>
                                            {%- endfor -%}
                                        </ul>
                                    {% endif %}
                                {% endfor %}
                            {% endif %}

                        {%- endif -%}
                        {% if product.selling_plan_groups.size > 0 and block.settings.enable_selling_plans %}
                            {%- if product.selling_plan_groups.size > 1 or product.requires_selling_plan == false -%}
                                <h2 class="label">{{ 'product.form.choose_option' | t }}</h2>
                                <ul class="check inline">
                                    {%- unless product.requires_selling_plan -%}
                                        <li>
                                            <input type="radio" id="purchase_option_single-{{ section.id }}" name="selling_plan_group" value="" data-enable data-template="{{ section.id }}" form="{{ form_id }}" required>
                                            <label for="purchase_option_single-{{ section.id }}">{{ 'product.one_time_purchase' | t }}</label>
                                        </li>
                                    {%- endunless -%}
                                    {%- for group in product.selling_plan_groups -%}
                                        <li>
                                            <input type="radio" id="{{ group.id }}-{{ section.id }}" name="selling_plan_group" value="" data-enable="checkout-type-{{ section.id }}-{{ group.id }}" data-template="{{ section.id }}" form="{{ form_id }}" required>
                                            <label for="{{ group.id }}-{{ section.id }}">{{ group.name }}</label>
                                        </li>
                                    {%- endfor -%}
                                </ul>
                            {%- else -%}
                                {%- assign default_plan = product.selling_plan_groups | first -%}
                                <input type="hidden" id="{{ default_plan.id }}-{{ section.id }}" name="selling_plan_group" value="" data-enable="checkout-type-{{ section.id }}-{{ default_plan.id }}" form="{{ form_id }}" required checked>
                            {%- endif -%}
                            {%- for group in product.selling_plan_groups -%}
                                <p class="m15 f8pr-selling-plan {% if product.requires_selling_plan == false or product.selling_plan_groups.size > 1 %}hidden{% endif %}" data-element="checkout-type-{{ section.id }}-{{ group.id }}">
                                    <span class="label">{{ 'product.form.purchase_options_title' | t }}</span>
                                    <span class="check wide">
                            {%- for plan in group.selling_plans -%}
                                {%- liquid
                                    if plan.price_adjustments
                                        case plan.price_adjustments.first.value_type
                                            when 'percentage'
                                                assign newPrice3 = current_variant.price | times: 1.0 | divided_by: 100
                                                assign newPrice2 = newPrice3 | times: plan.price_adjustments.first.value
                                                assign newPrice = current_variant.price | minus: newPrice2
                                            when 'fixed_amount'
                                                assign newPrice = current_variant.price | minus: plan.price_adjustments.first.value
                                            when 'price'
                                                assign newPrice = plan.price_adjustments.first.value
                                        endcase
                                        assign savedAmount = current_variant.price | minus: newPrice
                                    endif
                                -%}
                                <span class="check-wrap">
                                <input type="radio" id="{{ plan.id }}-{{ section.id }}" name="selling_plan" value="{{ plan.id }}" form="{{ form_id }}" {% if product.selling_plan_groups.size == 1 and product.requires_selling_plan == true %}required{% endif %}>
                                <label for="{{ plan.id }}-{{ section.id }}">{{ plan.name }}</label>
                                <span class="s1pr">
                                  {% if newPrice > 0 %}
                                      {% if savedAmount > 0 %}<span class="old-price">{{ current_variant.price | money }}</span>{% endif %}
                                    {{ newPrice | money }}
                                    {% if savedAmount > 0 %}<span class="small overlay-valid">{{ 'product.save' | t }}&nbsp;{{ savedAmount | money }}</span>{% endif %}
                                  {% else %}
                                      {{ current_variant.price | money }}
                                  {% endif %}
                                </span>
                              </span>
                            {%- endfor -%}
                          </span>
                                </p>
                            {%- endfor -%}
                        {% endif %}
                    </div>
                {%- when 'variant_bulk' -%}
                    <div class="f8pr-bulk s-bulk">
                        {%- if show_default -%}
                          <input name="id" id="id-{{ section.id }}" value="{{ current_variant.id }}" type="hidden" form="{{ form_id }}"></div>
                          {% continue %}
                        {%- endif -%}
                        {% assign limitVariants = 6 %}
                        {% if block.settings.title %}<p class="s1hd m15">{{ block.settings.title }}</p>{% endif %}
                        {% liquid
                            assign selection_type = block.settings.selection_type
                            assign selection_type = 'one_row'
                        %}
                        <ul class="l4ml{% if selection_type == 'two_rows' %} w50{% endif %}" {{ block.shopify_attributes }}>
                          {%- for variant in product.variants -%}
                              <li class="{% unless show_price %}disabled {% endunless %}{% if forloop.index > limitVariants %}hidden{% endif %}">
                                  {% if variant.image and block.settings.show_variant_images and selection_type == 'one_row' %}
                                      <figure>
                                          <picture><img src="{% if fill_images %}{{ variant.image | image_url: width: image_width_small, height: image_height_small, crop: 'center' }}{% else %}{{ variant.image | image_url: height: image_height_small }}{% endif %}" alt="{{ variant.title }}" width="50" height="55" loading="lazy"{% if fill_images %} class="filled"{% endif %}></picture>
                                      </figure>
                                  {% endif %}
                                  {%- capture bulk_variant_price -%}
                                      {% render 'price', product: product, variant: variant, price: variant.compare_at_price, origin: 'bulk', template: 'product', block: block, extraElement: 'element-x' %}
                                      {% comment %} {%- if variant.compare_at_price > variant.price and show_price %}<span class="old-price">{{ variant.compare_at_price | money }}</span>{% if block.settings.selection_type == 'two_rows' %} element-x{% endif %} {% endif %}{% if show_price %}{{ variant.price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}{% if block.settings.selection_type == 'two_rows' %}element-x {% endif -%}
                                      {%- if variant.unit_price_measurement and show_price -%}
                                        {%- liquid
                                          capture unit_price_base_unit
                                            if variant.available and variant.unit_price_measurement
                                              if variant.unit_price_measurement.reference_value != 1
                                                echo variant.unit_price_measurement.reference_value
                                              endif
                                              echo variant.unit_price_measurement.reference_unit
                                            endif
                                          endcapture
                                        -%}
                                        <span class="size-12">{% if show_price %}{{ variant.unit_price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}&nbsp;{{ 'product.unit_price_separator' | t }} {{ unit_price_base_unit }}</span>
                                      {%- endif -%} {% endcomment %}
                                  {%- endcapture -%}
                                  <span>
                                      <span{% if block.settings.shorten_title %} class="s1nw"{% endif %}>{{ variant.title }}</span>
                                      {%- liquid
                                        if block.settings.show_deliverytime
                                          assign hide_deliverytime = false
                                        else
                                          assign hide_deliverytime = true
                                        endif
                                      -%}
                                      {%- render 'product-deliverytime',
                                          product: product,
                                          current_variant: variant,
                                          container: "span",
                                          origin: 'productitem',
                                          no_margin: no_margin,
                                          extra_class: 'size-12',
                                          extra_element: '<br>',
                                          hide_deliverytime: hide_deliverytime
                                      -%}
                                      <br class="mobile-only">
                                      {% comment %} <span class="s1pr mobile-only">
                                          {{ bulk_variant_price | remove: 'element-x' }}
                                      </span> {% endcomment %}
                                      {% render 'price', product: product, variant: variant, price: variant.compare_at_price, origin: 'bulk', template: 'product', block: block, extraClass: 'mobile-only', extraElement: ' ' %}
                                  </span>
                                  {% comment %} <span class="s1pr mobile-hide">
                                      {{ bulk_variant_price | replace: 'element-x', '<br>' }}
                                  </span> {% endcomment %}
                                  {% render 'price', product: product, variant: variant, price: variant.compare_at_price, origin: 'bulk', template: 'product', block: block, extraClass: 'mobile-hide', extraElement: '<br>' %}

                                  <span class="input-amount {% if settings.qty_input_controls == 'enable' %}strong{% else %}no-arrows{% endif %}">
                                      <label for="ml-{{ variant.id }}" class="hidden">{{ 'cart.product.qty' | t }}</label>
                                      <input type="number" id="ml-{{ variant.id }}" name="ml-{{ variant.id }}" value="{% if product.variants.size == 1 %}1{% else %}0{% endif %}"
                                      min="{% if variant.quantity_rule.min > 1 %}{{ variant.quantity_rule.min }}{% elsif product.variants.size == 1 %}1{% else %}0{% endif %}"
                                      {% if variant.inventory_management == 'shopify' and variant.inventory_policy == 'deny' -%}
                                         max="{{ variant.inventory_quantity }}"
                                      {% elsif variant.quantity_rule.max %}
                                         max="{{ variant.quantity_rule.max }}"
                                      {% endif %}
                                      step="{{ variant.quantity_rule.increment }}" required{% if variant.available == false %} disabled{% endif %} data-id="{{ variant.id }}" {% render 'price', product: variant.product, variant: variant, price: variant.price, origin: 'bulk-input' %} data-price="{{ variant.price }}">
                                  </span>
                              </li>
                          {%- endfor -%}
                          {% if product.variants.size > limitVariants %}
                               <li class="link-more"><a href="./" class="link-more strong inline"><span class="link-underline">{{ 'general.read_more.show' | t }} <span>{{ 'general.read_more.all_2' | t }}</span> <span class="hidden">{{ 'general.read_more.less' | t }}</span> {{ 'general.read_more.variants' | t }}</span></a></li>
                          {% endif %}
                      </ul>
                    <select name="id" id="id-{{ section.id }}" data-url="{{ product.url }}" data-template="{{ section.id }}" required class="js-hidden" form="{{ form_id }}">
                        {%- for variant in product.variants -%}
                            {% if block.settings.show_unavailable_variants == false and variant.available == false %}{% continue %}{% endif %}
                            <option
                                    value="{{ variant.id }}"
                                    {% unless variant.available %}data-class="disabled"{% endunless %}
                                {% if variant == current_variant %}selected{% endif %}
                                {% if enable_options %}data-options='{"id":{{ variant.id }},"available":{{ variant.available }},"options":{{ variant.options | json | escape }}}'{% endif %}
                                    {% if variant.image and block.settings.show_variant_images and show_images %}
                                        data-img="{% if fill_images %}{{ variant.image | image_url: width: image_width_small, height: image_height_small, crop: 'center' }}{% else %}{{ variant.image | image_url: height: image_height_small }}{% endif %}"
                                    {% endif %}
                                    {% if settings.show_price_variant_dropdown %}{%- render 'price', product: product, price: variant.price, origin: 'select' -%}{% endif %}
                            >{{ variant.title }}</option>
                        {%- endfor -%}
                    </select>
                  </div>
                {%- when 'inventory' -%}
                    {% if show_default == false %}{% continue %}{% endif %}
                    <div class="f8pr-stock m0" {% if preorder and settings.show_preorder_inventory == false %}style="display:none"{% endif %}>
                        {%- liquid
                            assign next_block = forloop.index
                            if section.blocks[next_block].type == 'price'
                                assign no_margin = true
                            endif
                        -%}
                        {%- render 'product-deliverytime',
                                product: product,
                                current_variant: current_variant,
                        container: "p",
                                origin: 'productpage',
                                no_margin: no_margin,
                                shopify_attributes: block.shopify_attributes
                        -%}
                    </div>
               {% when 'free_shipping' %}
                   {% assign free_shipping_amount = settings.free_shipping_amount | times: 1 | times: 100 %}
                    <ul class="l4al inline f8pr-free-shipping-bar" {{ block.shopify_attributes }}>
                      {%- if free_shipping_amount > cart.total_price -%}
                      {%- assign amount = free_shipping_amount | minus: cart.total_price | money -%}
                        <li class="overlay-rose">{{ 'cart.amount_to_free_shipping_long_html' | t: amount: amount }}</li>
                      {%- else -%}
                        <li class="overlay-lime">{{ 'cart.free_shipping_long_html' | t }}</li>
                      {%- endif -%}
                    </ul>
                {%- when 'codes' -%}
                    <div class="f8pr-codes">
                            {%- liquid
                                if block.settings.show_sku and current_variant.sku != empty and current_variant.sku != nil
                                    assign show_sku = true
                                endif
                                if block.settings.show_barcode and current_variant.barcode != empty and current_variant.barcode != nil
                                    assign show_barcode = true
                                endif
                            -%}
                            {%- if show_sku or show_barcode -%}
                                <p {{ block.shopify_attributes }}>
                                    {%- if show_sku -%}
                                        <span class="strong">{{ 'product.sku' | t }}:</span> {{ current_variant.sku }}
                                    {%- endif -%}
                                    {%- if show_sku and show_barcode -%}<br>{%- endif -%}
                                    {%- if show_barcode -%}
                                        <span class="strong">{{ 'product.barcode' | t }}:</span> {{ current_variant.barcode }}
                                    {%- endif -%}
                                </p>
                            {%- endif -%}
                    </div>
                {%- when 'price' -%}
                    {%- liquid
                        assign skip_block = false
                        assign next_block = forloop.index
                        if section.blocks[next_block].type == 'buy_button' and show_default == false
                          assign skip_block = true
                        endif
                    -%}
                   {% if skip_block %}{% continue %}{% endif %}
                   {% if show_default %}
                        <p class="f8pr-price s1pr{% if current_variant.unit_price_measurement %} m0{% endif %}{% unless show_price %} s1bl{% endunless %}" {{ block.shopify_attributes }}>
                            {%- if current_variant.compare_at_price > current_variant.price and show_price -%}
                                <span class="old-price">{% render 'price', product: current_variant.product, price: current_variant.compare_at_price %}</span>{% if settings.sale_label_price != 'none' %} <span class="discount s1bx inline strong overlay-sale">{% render 'price', product: product, variant: current_variant, price: current_variant.price, origin: 'productpage', source: 'discount' %}</span>{% endif %}<br>
                            {%- endif -%}
                            {% if show_price %}
                              <span style="font-size: {{ price_block.settings.font_size }}px;">{% render 'price', product: current_variant.product, price: current_variant.price %}</span>
                              {% if block.settings.show_tax %}
                                <span data-syncer-vat-incl class="size-small font-regular">{{ 'product.including_tax' | t }}</span><span data-syncer-vat-excl class="size-12 font-regular">{{ 'product.excluding_tax' | t }}</span>
                              {% endif %}
                            {% elsif product.variants.size > 1 %}
                              {{ 0000 | money | money | replace: '0', '-' }}
                            {% endif %}
                            {%- if current_variant.unit_price_measurement and show_price -%}
                              {%- liquid
                                capture unit_price_base_unit
                                  if current_variant.available and current_variant.unit_price_measurement
                                    if current_variant.unit_price_measurement.reference_value != 1
                                      echo current_variant.unit_price_measurement.reference_value
                                    endif
                                    echo current_variant.unit_price_measurement.reference_unit
                                  endif
                                endcapture
                              -%}
                              <span class="font-regular size-small">{{ 'product.unit_price_label' | t }}&nbsp;{% if show_price %}{{ current_variant.unit_price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}&nbsp;{{ 'product.unit_price_separator' | t }} {{ unit_price_base_unit }}</span>
                            {%- endif -%}
                        </p>
                    {% elsif show_price %}
                        <p class="submit">
                            {{ variant_bulk_price }}
                        </p>
                    {% endif %}

                    {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
                    {%- form 'product', product, id: product_form_installment_id, class: 'f8pr-product-form-installment' -%}
                        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                        <div class="shopify-installments-container">{{ form | payment_terms }}</div>
                    {%- endform -%}
                {%- when 'buy_button' -%}
                    {%- liquid
                        assign gift_card_recipient_feature_active = false
                        if block.settings.show_gift_card_recipient and product.gift_card?
                            assign gift_card_recipient_feature_active = true
                        endif
                        assign show_dynamic_buybutton = false
                        if block.settings.show_dynamic_buybutton and gift_card_recipient_feature_active == false
                            assign show_dynamic_buybutton = true
                        endif

                        if preorder
                            if block.settings.preorder_show_dynamic_buybutton == false
                                assign show_dynamic_buybutton = false
                            endif
                            if block.settings.preorder_label != empty
                                assign preorder_label = block.settings.preorder_label | remove: '</p>' | remove: '<p>'
                                assign input_label = 'product.form.pre_order_info' | t
                                if input_label == empty
                                    assign input_label = 'Delivery'
                                endif
                            endif
                        elsif current_variant.available == false
                            assign show_dynamic_buybutton = false
                        endif
                    -%}
                    {%- form 'product', product, id: form_id, class: form_class, autocomplete: "off" -%}
                        {%- if show_price -%}
                            {% liquid
                                assign prev_block = forloop.index0 | minus: 1
                                assign price_before = false
                                if section.blocks[prev_block].type == 'price' and show_default == false
                                    assign price_before = true
                                endif
                            %}
                            {%- if gift_card_recipient_feature_active -%}
                                {%- render 'gift-card-recipient-form', product: product, form: form, section: section -%}
                            {%- endif -%}
                            <div class="submit m10 {% unless current_variant.available %}unavailable{% endunless %}{% if block.settings.show_wishlist_button and show_dynamic_buybutton == false %} nowrap{% endif %}" {{ block.shopify_attributes }} style="--btn_dist: 8px; --btn_dist2: 8px;">
                                {% if price_before %}
                                    {% style %}
                                        @media only screen and (min-width: 761px) {
                                            #root .m6pr .f8pr .submit > span:first-of-type { --btn_dist: 8vw !important; }
                                        }
                                    {% endstyle %}
                                {% endif %}
                                {% liquid
                                    if price_before
                                        echo variant_bulk_price
                                    endif
                                %}
                                <span class="input-amount f8pr-amount {% if settings.qty_input_controls == 'enable' %}strong{% else %}no-arrows{% endif %}"{% unless block.settings.show_amount_selection and show_default %} style="display:none;"{% endunless %}>
                                    <label for="quantity" class="hidden">{{ 'product.form.quantity' | t }}</label>
                                    <input type="number" id="quantity" name="quantity" data-link="#product_qty_sticky" value="{{ current_variant.quantity_rule.min }}"
                                       min="{{ current_variant.quantity_rule.min }}"
                                       {% if current_variant.inventory_management == 'shopify' and current_variant.inventory_policy == 'deny' -%}
                                           max="{{ current_variant.inventory_quantity | at_least: 1 }}"
                                       {% elsif current_variant.quantity_rule.max %}
                                           max="{{ current_variant.quantity_rule.max | at_least: 1 }}"
                                       {% endif %}
                                       {% if current_variant.quantity_rule.increment %}step="{{ current_variant.quantity_rule.increment }}"{% endif %}
                                       required>
                                </span>
                                <div class="f8pr-button wide">
                                    {%- if preorder -%}
                                        <button type="submit" class="overlay-preorder{% if block.settings.button_style == 'inv' %} inv{% endif %}">{{ settings.preorder_button_text }}</button>
                                    {%- elsif current_variant.available -%}
                                        <button type="submit" class="overlay-buy_button{% if block.settings.button_style == 'inv' %} inv{% endif %}{% if show_default == false and product.variants.size > 1 %} disabled{% endif %}">{{ 'product.form.add_to_cart' | t }}</button>
                                    {%- else -%}
                                        <button type="submit" class="disabled visible overlay-unavailable_buy_button{% if block.settings.button_style == 'inv' %} inv{% endif %}">{{ 'product.form.not_in_stock' | t }}</button>
                                    {%- endif -%}
                                    {%- if show_dynamic_buybutton and show_default -%}
                                        <div class="overlay-dynamic_buy_button {{ block.settings.button_style_dynamic_buybutton }}-btn mobile-hide">
                                            {{ form | payment_button }}
                                        </div>
                                    {%- endif -%}
                                </div>
                                {%- if show_dynamic_buybutton and show_default -%}
                                    <div class="overlay-dynamic_buy_button {{ block.settings.button_style_dynamic_buybutton }}-btn mobile-only">
                                        {{ form | payment_button }}
                                    </div>
                                {%- endif -%}
                                {% if block.settings.show_wishlist_button and show_dynamic_buybutton == false %}
                                    <span class="wishlist-productpage hidden"><a href="#wishlist" aria-label="Wishlist" data-product-id="{{ product.id }}" data-variant-id="{{ current_variant.id }}"><i class="icon-heart-outline"></i></a></span>
                                {% endif %}
                            </div>
                        {%- else -%}
                            <p class="link-btn m10" {{ block.shopify_attributes }}>
                                <a href="{{ routes.account_login_url }}" class="wide overlay-buy_button{% if block.settings.button_style == 'inv' %} inv{% endif %}">{{ 'customer.login.login_for_prices_html' | t }}</a>
                            </p>
                        {%- endif -%}
                        <ul class="f8pr-preorder l4al inline{% unless preorder and preorder_label %} m0{% endunless %}">
                            {%- if preorder and preorder_label -%}
                                <li class="overlay-{{ block.settings.preorder_label_color_palette }} text-center">
                                    {%- render 'icons', icon: 'clock' -%}&nbsp;{{ preorder_label }}
                                </li>
                                <input class="hidden" id="{{ input_label | handleize }}" type="text" name="properties[{{ input_label }}]" value="{{ preorder_label | strip_html }}">
                            {%- endif -%}
                        </ul>
                {%- endform -%}
                    <div class="m10">
                        {%- render 'bm-reviewbar' -%}
                    </div>
                {%- when 'usp' -%}
                    {%- liquid
                        assign next_block_is_usp = false
                        assign next_block_index = forloop.index0 | plus: 1
                        assign next_block = section.blocks[next_block_index]
                        if next_block.type == 'usp'
                            assign next_block_is_usp = true
                        endif
                    -%}
                    <ul class="l4us mobile-static{% unless next_block_is_usp %} margin-content{% endunless %}" {{ block.shopify_attributes }}>
                      {%- if block.settings.usp != empty -%}
                        <li class="{% if block.settings.usp_item_icon != 'default' or block.settings.image %} no-checks{% endif %}">
                            <span class="cols cols-mobile" style="--cols: 8px;">
                              {% if block.settings.image or block.settings.usp_item_icon != 'none' %}
                                {% if block.settings.image %}
                                  {%- assign image_width = block.settings.image_width -%}
                                  {%- assign image_width_2 = block.settings.image_width | times: 2 -%}
                                  <figure class="m0 no-border" style="width: calc({{ image_width }}px + var(--cols));">
                                    <picture>
                                      <img
                                        src="{{ block.settings.image | image_url: height: image_width }}"
                                        srcset="{{ block.settings.image | image_url: height: image_width }} 1x,{{ block.settings.image | image_url: height: image_width_2 }} 2x"
                                        height="50"
                                        width="{{ image_width }}"
                                        style="width:{{ image_width }}px!important; height: auto!important;"
                                        alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                                        loading="{% if section.index > 1 or forloop.first == false or section.location == 'footer' %}lazy{% else %}eager{% endif %}"
                                      >
                                    </picture>
                                  </figure>
                                {% else %}
                                  {%- render 'icons', icon: block.settings.usp_item_icon -%}
                                {% endif %}
                              {% endif %}
                              <span>
                                {%- assign usp_text = block.settings.usp | remove: '<p>' | remove: '</p>' | split: '|' -%}
                                {%- assign cycle_group = 'cycle-' | append: forloop.index -%}
                                {%- for text in usp_text -%}
                                  {%- capture cycle -%}{% cycle cycle_group: 'odd', 'even' %}{%- endcapture -%}
                                  {%- if cycle == 'odd' -%}
                                    <span>{{ text }}</span>
                                  {%- else -%}
                                    <span class="overlay-theme">{{ text }}</span>
                                  {%- endif -%}
                                {%- endfor -%}
                              </span>
                            </span>
                        </li>
                      {%- endif -%}
                    </ul>
                {%- when 'trustbadge' -%}
                    {%- liquid
                        assign block_attributes = block.shopify_attributes
                        render 'trustbadge', shopify_attributes: block_attributes
                    -%}
                {%- when 'shipping_timer' -%}
                    {%- if current_variant.requires_shipping -%}
                        {% assign set_hidden = false %}
                        {% if current_variant.available == false and settings.shipping_timer_show_unavailable == false %}{% assign set_hidden = true %}{% endif %}
                        <ul class="l4al f8pr-shipping-timer inline compact margin-content"{% if preorder or set_hidden %} style="height: 0; opacity: 0; visibility: hidden;"{% endif %} {{ block.shopify_attributes }}>
                            {%- render 'shipping-timer' -%}
                        </ul>
                    {%- endif -%}
                {%- when 'true_size' -%}
                    {%- if block.settings.option_1 != empty and block.settings.option_2 != empty and block.settings.option_3 != empty and block.settings.true_size_value != empty -%}
                        <p class="true-size" {{ block.shopify_attributes }}>
                            <label for="true_size" class="m5">
                                {{ block.settings.title }}
                                {%- if block.settings.text != empty -%}
                                   <span class="s1tt"><span>{{ block.settings.text | remove: '<h1>' | remove: '</h1>' | remove: '<h2>' | remove: '</h2>' | remove: '<h3>' | remove: '</h3>' | remove: '<h4>' | remove: '</h4>' | remove: '<h5>' | remove: '</h5>' | remove: '<h6>' | remove: '</h6>' | replace: '</p><p>', '<br>' | remove: '<p>' | remove: '</p>' }}</span></span>
                                {%- endif -%}
                            </label>
                            <span class="input-range single">
                                <input  type="number" id="true_size" name="true_size" min="1" max="3" disabled value="
                                        {%- if block.settings.option_1 == block.settings.true_size_value -%}1
                                        {%- elsif block.settings.option_2 == block.settings.true_size_value -%}2
                                        {%- elsif block.settings.option_3 == block.settings.true_size_value -%}3
                                        {%- endif -%}">
                            </span>
                            <span class="input-range-steps">
                                <span>{{ block.settings.option_1 }}</span>
                                <span>{{ block.settings.option_2 }}</span>
                                <span>{{ block.settings.option_3 }}</span>
                            </span>
                        </p>
                    {%- endif -%}
                {%- when 'manual_docs' -%}
                    {%- if block.settings.title != empty or block.settings.link_text != empty -%}
                        <div {{ block.shopify_attributes }}>
                            {%- if block.settings.title != empty -%}
                                <{{ block.settings.title_size }} class="cols cols-mobile text-start align-middle" style="--cols: 8px;">
                                    {% if block.settings.show_icon or block.settings.header_image %}
                                        {%- if block.settings.header_image -%}
                                            {%- assign image_width = block.settings.header_image_width -%}
                                            {%- assign image_width_2 = image_width | times: 2 -%}
                                            <img
                                                src="{{ block.settings.header_image | image_url: width: image_width }}"
                                                srcset="{{ block.settings.header_image | image_url: width: image_width }} 1x,{{ block.settings.header_image | image_url: width: image_width_2 }} 2x"
                                                height="20"
                                                width="{{ image_width }}"
                                                style="width:{{ image_width }}px!important"
                                                alt="{{ block.settings.header_image.alt | default: block.settings.title | escape }}"
                                                loading="lazy"
                                                class="no-bd-radius"
                                            >
                                        {%- else -%}
                                            <i aria-hidden="true" class="icon-document size-20"></i>
                                        {%- endif %}
                                    {%- endif %}
                                    <span>{{ block.settings.title }}</span>
                                </{{ block.settings.title_size }}>
                            {% endif %}
                            {%- if block.settings.link_text != empty -%}
                                <p><a href="{% if block.settings.link_url != empty %}{{ block.settings.link_url }}{% else %}./{% endif %}" class="overlay-content text-no-underline hover-theme" target="_blank">{{ block.settings.link_text }}&nbsp; <i aria-hidden="true" class="icon-download"></i></a></p>
                            {%- endif -%}
                        </div>
                    {%- endif -%}
                {%- when 'wishlist' -%}
                    {% if block.settings.custom_liquid != empty and block.settings.custom_liquid != blank %}
                        <div class="m20" {{ block.shopify_attributes }}>
                            {{ block.settings.custom_liquid }}
                        </div>
                    {% else %}
                        {%- liquid
                          assign button_color = block.settings.button_style | split: ' ' | first
                          assign button_style = block.settings.button_style | split: ' ' | last
                          assign is_link = false
                          if button_style == 'link'
                            assign is_link = true
                          endif
                        -%}
                      <p class="wishlist-productpage hidden link{% unless is_link %}-btn{% if block.settings.wide %} wide{% endif %}{% endunless %}" {{ block.shopify_attributes }}>
                        <a href="#wishlist" class="overlay-{{ button_color }} {% if is_link %}inline strong{% elsif button_style == 'inv' %}inv{% endif %}" data-product-id="{{ product.id }}" data-variant-id="{{ current_variant.id }}">
                            <span {% if is_link %}class="link-underline"{% endif %}><i class="icon-heart-outline"></i> {{ 'product.form.add_to_wishlist' | t }}</span>
                        </a>
                      </p>
                    {% endif %}
                {%- when 'benefit_score' -%}
                    {%- liquid
                        assign next_block_is_score = false
                        assign next_block_index = forloop.index0 | plus: 1
                        assign next_block = section.blocks[next_block_index]
                        if next_block.type == 'benefit_score'
                            assign next_block_is_score = true
                        endif
                    -%}
                    {%- if block.settings.benefit_value != empty -%}
                        <p class="benefit{% if next_block_is_score %} m10{% endif %}" {{ block.shopify_attributes }}>
                            {%- if block.settings.title != empty -%}
                              <label for="benefit-{{ block.id }}" class="m5">
                                {{ block.settings.title }}
                                {%- if block.settings.title_text != empty -%}
                                    &nbsp;<span class="s1tt"><span>{{ block.settings.title_text | remove: '<h1>' | remove: '</h1>' | remove: '<h2>' | remove: '</h2>' | remove: '<h3>' | remove: '</h3>' | remove: '<h4>' | remove: '</h4>' | remove: '<h5>' | remove: '</h5>' | remove: '<h6>' | remove: '</h6>' | replace: '</p><p>', '<br>' | remove: '<p>' | remove: '</p>' }}</span></span>
                                {%- endif -%}
                              </label>
                            {%- endif -%}
                            {%- if block.settings.benefit_title != empty -%}
                                <span class="overlay-gray m0">
                                    {{ block.settings.benefit_title }}
                                    {%- if block.settings.benefit_text != empty -%}
                                        &nbsp;<span class="s1tt"><span>{{ block.settings.benefit_text | remove: '<h1>' | remove: '</h1>' | remove: '<h2>' | remove: '</h2>' | remove: '<h3>' | remove: '</h3>' | remove: '<h4>' | remove: '</h4>' | remove: '<h5>' | remove: '</h5>' | remove: '<h6>' | remove: '</h6>' | replace: '</p><p>', '<br>' | remove: '<p>' | remove: '</p>' }}</span></span>
                                    {%- endif -%}
                                </span>
                            {%- endif -%}
                            <span class="input-range single">
                                <input  type="number" id="benefit-{{ block.id }}" name="benefit-{{ block.id }}" min="0" max="5" disabled value="{{ block.settings.benefit_value }}">
                            </span>
                            <span class="input-range-steps">
                                <span></span>
                                <span>1</span>
                                <span>2</span>
                                <span>3</span>
                                <span>4</span>
                                <span>5</span>
                            </span>
                        </p>
                    {%- endif -%}
                {%- else -%}
                    {%- if block.type == 'content' -%}
                        {%- liquid
                            assign show = false
                            if block.settings.text != empty or block.settings.text_specs != empty or block.settings.page != blank or block.settings.image != blank or block.settings.liquid != blank or block.settings.html != blank or block.settings.show_contact_form
                                assign show = true
                            elsif block.settings.layout == 'none'
                                assign show = true
                            endif
                        -%}
                    {%- endif -%}
                    {%- if show or block.type == 'complementary_products' -%}
                        {% capture block_attributes %}
                            {% if block.type == 'complementary_products' %}
                                data-template="{{ section.id }}" data-product-id="{{ product.id }}" data-intent="complementary"
                                {% if recommendations.products_count == 0 and request.design_mode == false %}data-hide{% endif %}
                            {%- endif -%}
                        {%- endcapture -%}
                        {%- capture header_img -%}
                            {%- if block.settings.header_image -%}
                                {%- assign image_width = block.settings.header_image_width -%}
                                {%- assign image_width_2 = image_width | times: 2 -%}
                                <img
                                    src="{{ block.settings.header_image | image_url: width: image_width }}"
                                    srcset="{{ block.settings.header_image | image_url: width: image_width }} 1x,{{ block.settings.header_image | image_url: width: image_width_2 }} 2x"
                                    height="20"
                                    width="{{ image_width }}"
                                    style="border-radius: var(--b2r); width:{{ image_width }}px!important"
                                    alt="{{ block.settings.header_image.alt | default: block.settings.title | escape }}"
                                    loading="lazy"
                                >
                            {%- elsif block.settings.icon != 'none' -%}
                                {%- render 'icons', icon: block.settings.icon -%}
                                {% style %}
                                    #shopify-section-{{ section.id }} .block-{{ block.id }} svg, #quickshop .block-{{ block.id }} svg { height: {% if block.settings.enable_tab or block.settings.layout != 'none' %}20{% else %}25{% endif %}px!important; width: {% if block.settings.enable_tab or block.settings.layout != 'none' %}20{% else %}25{% endif %}px!important; }
                                {% endstyle %}
                            {%- endif -%}
                        {%- endcapture -%}
                        {%- capture content -%}
                            {%- if block.type == 'content' -%}
                                {%- if block.settings.text != empty -%}{{ block.settings.text }}{%- endif -%}
                                {%- if block.settings.text_specs != empty -%}
                                    {%- liquid
                                        assign specs_split_char = '|'
                                        unless block.settings.text_specs contains 'metafield-single_line_text_field-array'
                                            assign specs_split_char = ','
                                        endunless
                                    -%}
                                    {% assign specs = block.settings.text_specs | remove: '<ul class="metafield-single_line_text_field-array">' | remove: '<li class="metafield-single_line_text_field">' | replace: '</li>', specs_split_char | remove: '</ul>' | remove: '<p>' | remove: '</p>' | newline_to_br | strip_newlines | replace: '<br/>', specs_split_char | replace: '<br />', specs_split_char | replace: ' and ', specs_split_char | split: specs_split_char %}
                                    {% if specs.size > 0 %}
                                        <ul class="l4if strong">
                                            {%- for spec in specs -%}
                                                {% assign spec_obj = spec | split: ': ' %}
                                                {%- assign spec_name = spec | split: ': ' | first | strip -%}
                                                {%- assign spec_value = spec | split: ': ' | last | strip -%}
                                                {% unless spec_obj.size == 2 %}{% continue %}{% endunless %}
                                                {% if spec_value contains "href" %}
                                                    {% assign spec_link = spec_value | split: 'href=&quot;' | last | split: "&quot;" | first %}
                                                    {% assign spec_link_name = spec_value | split: '&quot;&gt;' | last | split: "&lt;/a" | first %}
                                                    {% assign spec_value = spec_link_name | link_to: spec_link %}
                                                {% endif %}
                                                {%- if spec_name != empty -%}
                                                    <li class="s1bw{% if specs.size > 9 and forloop.index > 9 %} hidden{% endif %}">
                                                        <span>{{ spec_name | remove: '<p>' | remove: '</p>' }}:</span> {{ spec_value | remove: '<p>' | remove: '</p>' }}
                                                    </li>
                                                {%- endif -%}
                                            {%- endfor -%}
                                            {%- if specs.size > 9 -%}
                                                <li><a href="./" class="link-more strong inline"><span class="link-underline">{{ 'general.read_more.show' | t }} <span>{{ 'general.read_more.more' | t }}</span> <span class="hidden">{{ 'general.read_more.less' | t }}</span></span></a></li>
                                            {%- endif -%}
                                        </ul>
                                    {% else %}
                                        {{ block.settings.text_specs }}
                                    {% endif %}
                                {%- endif -%}
                                {%- if block.settings.page != blank -%}{{ block.settings.page.content }}{%- endif -%}
                                {%- if block.settings.image != blank -%}
                                    <div class="m20">
                                        <img
                                            src="{{ block.settings.image | image_url: width: block.settings.image_width }}"
                                            srcset="{% render 'image-srcset', image: block.settings.image %}"
                                            sizes="
                                                (min-width: 760px) 500px
                                                100vw
                                                "
                                            alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                                            width="{{ block.settings.image_width }}"
                                            height="640"
                                            loading="lazy"
                                            >
                                    </div>
                                {%- endif -%}
                                {%- if block.settings.liquid != empty -%}{{ block.settings.liquid }}{%- endif -%}
                                {%- if block.settings.html != empty -%}{{ block.settings.html }}{%- endif -%}
                                {%- if block.settings.show_contact_form -%}
                                    {%- assign contactform_classes = 'f8cm f8vl w940 m30' -%}
                                    {%- assign contactform_id = section.id | append: '-' | append: block.id -%}
                                    {%- form 'contact', id: contactform_id, class: contactform_classes -%}
                                        {%- if form.errors -%}
                                            <script>
                                                document.addEventListener('DOMContentLoaded', function () {
                                                    var alertAttributes = { message: "{{ 'service.contact_form.email' | t }} {{ form.errors.messages['email'] }}", type: "error", origin: "contact" },
                                                        showAlertEvent = new CustomEvent("showAlert", {detail: alertAttributes});
                                                    window.dispatchEvent(showAlertEvent);
                                                });
                                            </script>
                                        {%- elsif form.posted_successfully? -%}
                                            <script>
                                                document.addEventListener('DOMContentLoaded', function () {
                                                    var alertAttributes = { message: "{{ 'service.contact_form.posted_successfully' | t }}", type: "success", origin: "contact" },
                                                        showAlertEvent = new CustomEvent("showAlert", {detail: alertAttributes});
                                                    window.dispatchEvent(showAlertEvent);
                                                });
                                            </script>
                                        {%- endif -%}
                                        <fieldset>
                                            <legend>{{ 'service.contact_form.title' | t }}</legend>
                                            <p>
                                                <label for="subject">{{ 'service.contact_form.subject' | t }}</label>
                                                <input type="text" id="subject" name="contact[subject]" placeholder="{{ 'service.contact_form.subject' | t }}">
                                            </p>
                                            <div class="cols">
                                                <p class="w50">
                                                    <label for="name">{{ 'service.contact_form.name' | t }}</label>
                                                    <input type="text" id="name" name="contact[name]" placeholder="{{ 'service.contact_form.name' | t }}">
                                                </p>
                                                <p class="w50">
                                                    <label for="email">{{ 'service.contact_form.email' | t }}<span class="overlay-theme">*</span></label>
                                                    <input type="email" id="email" name="contact[email]" placeholder="{{ 'service.contact_form.email' | t }}" required>
                                                </p>
                                            </div>
                                            <p>
                                                <label for="body">{{ 'service.contact_form.message' | t }}<span class="overlay-theme">*</span></label>
                                                <textarea id="message" name="contact[body]" placeholder="{{ 'service.contact_form.message' | t }}" required></textarea>
                                            </p>
                                            <p class="submit m0"><button type="submit">{{ 'service.contact_form.send' | t }}</button></p>
                                        </fieldset>
                                    {% endform %}
                                {%- endif -%}
                            {%- elsif block.type == 'complementary_products' -%}
                                {%- liquid
                                    if block.settings.products_layout == 'grid'
                                        assign width_class = 'w33'
                                    endif
                                    assign products_show_variant_picker = false
                                    if block.settings.products_layout == 'list' and block.settings.products_show_variant_picker
                                        assign products_show_variant_picker = true
                                    endif
                                -%}
                                <ul class="{% if block.settings.products_layout == 'list' %}{% if products_show_variant_picker %}l4ca compact with-form {% else %}l4cl hr inv {% endif %}{% unless block.settings.products_show_image %}no-img {% endunless %}{% else %}l4cl compact{% endif %}"
                                    style="{% if products_show_variant_picker %}--offset:122px;{% endif %}"
                                >
                                    {%- liquid
                                        if block.settings.product_list != blank
                                            assign products = block.settings.product_list
                                        elsif recommendations.performed and recommendations.products_count > 0
                                            assign products = recommendations.products
                                        endif
                                    -%}
                                    {%- if product != blank and products.count > 0 -%}
                                        {%- for product in products -%}
                                            {%- liquid
                                                capture placeholder_int
                                                    cycle 1, 2, 3, 4, 5, 6
                                                endcapture
                                            -%}
                                            {%- render 'product-item',
                                                product: product,
                                                placeholder_int: placeholder_int,
                                                layout: block.settings.products_layout,
                                                origin: 'complementary',
                                                enable_variant_picker: products_show_variant_picker,
                                                show_image: block.settings.products_show_image,
                                                show_vendor: block.settings.products_show_vendor,
                                                show_title: block.settings.products_show_title,
                                                show_rating: block.settings.products_show_rating,
                                                show_price: block.settings.products_show_price,
                                                show_stock: block.settings.products_show_stock
                                            -%}
                                        {%- endfor -%}
                                    {%- elsif request.design_mode -%}
                                        {%- for product in (1..5) -%}
                                            {%- liquid
                                                capture placeholder_int
                                                    cycle 1, 2, 3, 4, 5
                                                endcapture
                                            -%}
                                            {%- render 'product-item',
                                                product: blank,
                                                placeholder_int: placeholder_int,
                                                layout: block.settings.products_layout,
                                                origin: 'complementary',
                                                enable_variant_picker: false,
                                                show_image: block.settings.products_show_image,
                                                show_vendor: block.settings.products_show_vendor,
                                                show_title: block.settings.products_show_title,
                                                show_rating: block.settings.products_show_rating,
                                                show_price: block.settings.products_show_price,
                                                show_stock: block.settings.products_show_stock,
                                                show_compare_checkbox: false
                                            -%}
                                        {%- endfor -%}
                                    {%- endif -%}
                                </ul>
                            {%- endif -%}
                        {%- endcapture -%}
                        {%- if block.settings.layout == 'tab' -%}
                            {%- liquid
                                assign prev_block_index = forloop.index0 | minus: 1
                                assign next_block_index = forloop.index0 | plus: 1
                                assign prev_block = section.blocks[prev_block_index]
                                assign next_block = section.blocks[next_block_index]
                                assign is_first_tab = false

                                assign show_prev_block = false
                                if prev_block.type == 'content' and prev_block.settings.layout == 'tab'
                                    if prev_block.settings.text != empty or prev_block.settings.text_specs != empty or prev_block.settings.page != blank or prev_block.settings.image != blank or prev_block.settings.liquid != blank or prev_block.settings.html != blank or prev_block.settings.show_contact_form
                                        assign show_prev_block = true
                                    endif
                                elsif prev_block.type == 'complementary_products' and prev_block.settings.layout == 'tab'
                                    assign show_prev_block = true
                                endif
                                assign show_next_block = false
                                if next_block.type == 'content' and next_block.settings.layout == 'tab'
                                    if next_block.settings.text != empty or next_block.settings.text_specs != empty or next_block.settings.page != blank or next_block.settings.image != blank or next_block.settings.liquid != blank or next_block.settings.html != blank or next_block.settings.show_contact_form
                                        assign show_next_block = true
                                    endif
                                elsif next_block.type == 'complementary_products' and next_block.settings.layout == 'tab'
                                    assign show_prev_block = true
                                endif
                            -%}
                            {%- if forloop.first or show_prev_block == false -%}
                                {%- assign is_first_tab = true %}
                                <div class="m6tb btn" data-active-class="overlay-{{ settings.active_tabs_color }}">
                                    <nav class="strong">
                                        <ul>
                                            <li class="link-btn overlay-{{ settings.active_tabs_color }} block-{{ block.id }}"><a href="#"{% if settings.button_style == 'inv' %} class="inv"{% endif %}>{{ header_img }}<span>{{ block.settings.title }}</span></a></li>
                                            {% for block in section.blocks offset: forloop.index %}
                                                {%- liquid
                                                    assign show_block = false
                                                    if block.settings.text != empty or block.settings.text_specs != empty or block.settings.page != blank or block.settings.image != blank or block.settings.liquid != blank or block.settings.html != blank or block.settings.show_contact_form
                                                        assign show_block = true
                                                    endif
                                                -%}
                                                {%- if block.type == 'content' and block.settings.layout == 'tab' and show_block -%}
                                                    <li class="block-{{ block.id }}"><a href="#"{% if settings.button_style == 'inv' %} class="inv"{% endif %}>
                                                        {%- if block.settings.header_image -%}
                                                            {%- assign image_width = block.settings.header_image_width -%}
                                                            {%- assign image_width_2 = image_width | times: 2 -%}
                                                            <img
                                                                src="{{ block.settings.header_image | image_url: width: image_width }}"
                                                                srcset="{{ block.settings.header_image | image_url: width: image_width }} 1x,{{ block.settings.header_image | image_url: width: image_width_2 }} 2x"
                                                                height="20"
                                                                width="{{ image_width }}"
                                                                style="border-radius: var(--b2r); width:{{ image_width }}px!important"
                                                                alt="{{ block.settings.header_image.alt | default: block.settings.title | escape }}"
                                                                loading="lazy"
                                                            >
                                                        {%- elsif block.settings.icon != 'none' -%}
                                                            {%- render 'icons', icon: block.settings.icon -%}
                                                            <style>
                                                                #shopify-section-{{ section.id }} .block-{{ block.id }} svg:not(.placeholder-svg), #quickshop .block-{{ block.id }} svg:not(.placeholder-svg) { height: {% if block.settings.enable_tab or block.settings.layout != 'none' %}20{% else %}25{% endif %}px!important; width: {% if block.settings.enable_tab or block.settings.layout != 'none' %}20{% else %}25{% endif %}px!important; }
                                                            </style>
                                                        {%- endif -%}
                                                        <span>{{ block.settings.title }}</span>
                                                    </a></li>
                                                {%- else -%}{% break %}{%- endif -%}
                                            {% endfor %}
                                        </ul>
                                    </nav>
								<div>
                            {%- endif -%}
                                <div class="{% if block.settings.layout == 'tab' and block.settings.collapse %}tab-closed{% endif %}{% if block.type == 'complementary_products' and block.settings.product_list == blank %} tab product-recommendations{% unless request.design_mode %} hidden{% endunless %}{% endif %}{% if is_first_tab == false %} hidden{% endif %}{% if block.settings.collapse %} hidden-mobile{% endif %}" {{ block_attributes }} {{ block.shopify_attributes }}>
                                    {{ content }}
                                </div>
                            {%- if forloop.last or show_next_block == false -%}
                                </div>
                                </div>
                            {%- endif -%}
                        {%- elsif block.settings.layout == 'accordion' -%}
                            {%- if block.settings.title != empty -%}
                                <div class="block-{{ block.id }} accordion-a compact{% if block.type == 'complementary_products' and block.settings.product_list == blank %} product-recommendations{% unless request.design_mode %} hidden{% endunless %}{% endif %}" {{ block_attributes }}>
                                    <details{% unless block.settings.collapse %} open{% endunless %} {{ block.shopify_attributes }}>
                                        <summary>
                                            {{ header_img }}<span class="m0">{{ block.settings.title }}</span>
                                        </summary>
                                        <div>
                                            {{ content }}
                                        </div>
                                    </details>
                                </div>
                            {%- endif -%}
                        {%- else -%}
                            <div class="block-{{ block.id }} {% if block.type == 'complementary_products' and block.settings.product_list == blank %}product-recommendations{% unless request.design_mode %} hidden{% endunless %}{% endif %}" {{ block_attributes }} {{ block.shopify_attributes }}>
                                {%- if block.settings.title != empty or header_img != empty -%}
                                    <{{ block.settings.title_size }} class="heading-has-image cols cols-mobile text-start align-middle" style="--cols: 8px;">
                                        {{ header_img }} <span>{{ block.settings.title }}</span>
                                    </{{ block.settings.title_size }}>
                                {% endif %}
                                {{ content }}
                            </div>
                        {%- endif -%}
                    {%- endif -%}
                {%- endcase -%}
            {%- endfor -%}
            {%- if variant_selection_blocks.size == 0 and variant_bulk.size == 0 %}
                <input name="id" value="{{ current_variant.id }}" type="hidden" form="{{ form_id }}" class="f8pr-fallback-id-input">
            {%- endif -%}
            {%- if custom_short_description and short_description != empty and short_description != blank -%}
                <p class="mobile-only">{{ short_description }}</p>
            {%- endif -%}
        </div>
    </div>
</article>

{%- if sizechart_popup -%}
    {{ sizechart_popup }}
{%- endif %}
{%- assign popup_blocks = section.blocks | where: "type", "popup" -%}
{%- for block in popup_blocks %}
    {%- if block.settings.text != empty or block.settings.text_specs != empty or block.settings.page.content != blank or block.settings.image or block.settings.liquid or block.settings.html -%}
        <article class="popup-a wide mobile-panel" id="block-popup-{{ section.id }}-{{ block.id }}" data-title="block-popup-{{ section.id }}-{{ block.id }}-{{ current_variant.id }}">
            {%- if block.settings.title != empty -%}
                <{{ block.settings.title_size }} class="{{ 'text-' | append: block.settings.alignment }}">{{ block.settings.title }}</{{ block.settings.title_size }}>
            {%- endif -%}
            <div class="base-font">
                {{ block.settings.text }}
                {{ block.settings.text_specs }}
                {%- if block.settings.page.content != blank -%}
                    {{ block.settings.page.content }}
                {%- endif -%}
                {%- if block.settings.image != blank -%}
                    <div class="m20">
                        <img
                            src="{{ block.settings.image | image_url: width: block.settings.image_width }}"
                            srcset="{% render 'image-srcset', image: block.settings.image %}"
                            sizes="
                              (min-width: 760px) 500px
                              100vw
                              "
                            alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                            width="{{ block.settings.image_width }}"
                            height="640"
                            loading="lazy"
                        >
                    </div>
                {%- endif -%}
                {%- if block.settings.liquid or block.settings.html -%}
                    <p>
                        {{ block.settings.liquid }}
                        {{ block.settings.html }}
                    </p>
                {%- endif -%}
            </div>
        </article>
    {%- endif -%}
{%- endfor -%}

<style>
    @media only screen and (max-width: 760px) {
        #shopify-section-{{ section.id }} .m6tb .tabs-header, .m6tb.static .tabs-header, #shopify-section-{{ section.id }} .accordion-a.compact summary {
            font-size: var(--mob_{{ section.settings.mobile_tabs_title_size }});
        }
        #shopify-section-{{ section.id }} .m6tb .tabs-header svg { width: 20px!important; }
    }
    {% unless section.settings.media_layout == 'slider' %}
        #shopify-section-{{ section.id }} .l4pr.static {
            {% if section.settings.media_layout == 'rows' %}
                --width: 100%;
                --c: 1;
            {% else %}
                --c: 0.5;
            {% endif %}
         }
         #shopify-section-{{ section.id }} .l4pr.static[data-media-size~="1"] {
            --width: 100%;
            --c: 1;
        }
    {% endunless %}

    {% if section.settings.width == 'wide' %}
    @media only screen and (min-width: 761px) {
        .shopify-section-breadcrumbs:has(+ div[id*="main-product"]) .n6br { max-width: unset; }
    }
    {% endif %}
</style>

