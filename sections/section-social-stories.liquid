      "default": false
    },
    {
      "type": "range",
      "id": "number_of_items",
      "label": "t:sections.social_stories.settings.number_of_items.label",
      "info": "t:sections.social_stories.settings.number_of_items.info",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "space_between",
      "label": "t:sections.social_stories.settings.space_between.label",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "id": "text_alignment",
      "type": "select",
      "label": "t:global.typography.title_position.label",
      "options": [
        {
          "value": "start",
          "label": "t:global.alignment.left.label"
        },
        {
          "value": "center",
          "label": "t:global.alignment.center.label"
        }
      ],
      "default": "start"
    },
    {
      "type": "header",
      "content": "t:global.typography.title.label"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "t:global.typography.title.label",
      "info": "t:global.typography.title.info",
