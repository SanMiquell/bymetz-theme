{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-marquee.css' | asset_url | stylesheet_tag }}

{%- liquid
    assign animation = section.settings.animation
    case animation
        when 'left'
            assign animation_class = 'inv'
        when 'type'
            assign animation_class = 'type'
        else
            assign animation_class = ''
    endcase

    assign animation_speed = section.settings.text_speed | at_most: 99
-%}

<div class="palette-{{ section.settings.color_palette }} overlay m6bx{% if section.settings.width == 'wide' %} wide{% endif %}
  module-color-palette {% if section.settings.overlay_opacity == 0 %}no-padding{% endif %}
">
  <div class="m6kn {{ animation_class }} {{ section.settings.text_size }}{% if animation == 'type' and section.settings.content_position == 'center' %} text-center{% endif %} {{ section.settings.mobile_height }}
       {% if section.settings.animation == 'type' %}ff-heading ff-{{ section.settings.font }}{% endif %}
       {% if section.settings.animation != 'type' and section.settings.kinetic_text_dots %} dot{% endif %}
       "
  style="--dist: {{ section.settings.space_between_text }}px; --duration: {{ 100 | minus: animation_speed }}s; {% if section.settings.enable_custom_height %}--mih: {{ section.settings.custom_height }}px{% endif %}"
  >
      <ul class="m0">
        {%- for block in section.blocks -%}
          <li {{ block.shopify_attributes }}>
            {% if block.settings.image and animation != 'type' %}
                <div class="cols cols-mobile align-middle">
                  {%- assign image_width = block.settings.image_width -%}
                  {%- assign image_width_2 = block.settings.image_width | times: 2 -%}
                  <figure class="m0 no-border" style="width: calc({{ image_width }}px + var(--cols));">
                    <picture>
                      {%- if block.settings.link_url != blank and section.settings.animation != 'type' -%}
                        <a href="{{ block.settings.link_url }}" aria-label="{{ block.settings.text | escape | default: block.settings.image.alt | default: "Kinetic text banner image" }}">
                      {%- endif -%}
                      <img
                        src="{{ block.settings.image | image_url: height: image_width }}"
                        srcset="{{ block.settings.image | image_url: height: image_width }} 1x,{{ block.settings.image | image_url: height: image_width_2 }} 2x"
                        height="50"
                        width="{{ image_width }}"
                        style="width:{{ image_width }}px!important; height: auto!important;"
                        alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                        loading="{% if section.index > 1 or forloop.first == false or section.location == 'footer' %}lazy{% else %}eager{% endif %}"
                      >
                      {%- if block.settings.link_url != blank and section.settings.animation != 'type' -%}
                        </a>
                      {%- endif -%}
                    </picture>
                  </figure>
            {% endif %}
            <span {% unless section.settings.animation == 'type' %}class="ff-heading ff-{{ block.settings.font }}"{% endunless %}>
                {%- if block.settings.link_url != blank and section.settings.animation != 'type' -%}
                  <a href="{{ block.settings.link_url }}">
                {%- endif -%}
                {{ block.settings.text }}
                {%- if block.settings.link_url != blank and section.settings.animation != 'type' -%}
                  </a>
                {%- endif -%}
            </span>
          {% if block.settings.image and animation != 'type' %}
              </div>
          {% endif %}
          </li>
        {%- endfor -%}
    </ul>
  </div>
</div>
<style>
    #shopify-section-{{ section.id }} .m6bx .m6kn { --primary_text_h: var(--primary_text) }
    #shopify-section-{{ section.id }} .module-color-palette:before { opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}; }
    #shopify-section-{{ section.id }} { z-index: {{ section.settings.fix_zindex }}!important; }
    @media only screen and (min-width: 47.5em) {
      #shopify-section-{{ section.id }} .m6bx { margin-bottom: {{ section.settings.spacing_desktop }}px; }
      {%- if section.settings.enable_custom_text_size -%}
        #shopify-section-{{ section.id }} .m6bx .m6kn { --main_{{ section.settings.text_size }}: {{ section.settings.custom_text_size }}px; }
      {%- endif -%}
      {% if section.settings.spacing_desktop < 0 %}
        #shopify-section-{{ section.id }} + *.has-kinetic-text { pointer-events: none; }
      {% endif %}

    }
    @media only screen and (max-width: 47.5em) {
      #shopify-section-{{ section.id }} .m6bx { margin-bottom: {{ section.settings.spacing_mobile }}px; }
      #shopify-section-{{ section.id }} .m6bx .m6kn {
        --main_{{ section.settings.text_size }}: var(--mob_{{ section.settings.mobile_text_size }});
      }
      {% if section.settings.spacing_mobile < 0 %}
        #shopify-section-{{ section.id }} + *.has-kinetic-text { pointer-events: none; }
      {% endif %}
    }
</style>
{% schema %}
{
  "name": "t:sections.kinetic_text.name",
  "tag": "article",
  "class": "section has-kinetic-text",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay"
    ]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_palette",
      "label": "t:global.color_palette.label",
      "default": "scheme-5"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.kinetic_text.settings.overlay_opacity.label",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "animation",
      "label": "t:sections.kinetic_text.settings.animation.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.kinetic_text.settings.animation.options__1.label"
        },
        {
          "value": "right",
          "label": "t:sections.kinetic_text.settings.animation.options__2.label"
        },
        {
          "value": "type",
          "label": "t:sections.kinetic_text.settings.animation.options__3.label"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "text_speed",
      "label": "t:sections.kinetic_text.settings.text_speed.label",
      "info": "t:sections.kinetic_text.settings.text_speed.info",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 75
    },
    {
      "id": "kinetic_text_dots",
      "type": "checkbox",
      "label": "t:static_sections.announcement_bar.settings.kinetic_text.kinetic_text_dots.label",
      "default": true
    },
    {
      "type": "range",
      "id": "space_between_text",
      "label": "t:sections.kinetic_text.settings.space_between_text.label",
      "info": "t:sections.kinetic_text.settings.space_between_text.info",
      "min": 20,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:global.layout.width.label",
      "options": [
        {
          "value": "boxed",
          "label": "t:global.layout.width.options__1.label"
        },
        {
          "value": "wide",
          "label": "t:global.layout.width.options__2.label"
        }
      ],
      "default": "boxed"
    },
    {
      "id": "enable_custom_height",
      "type": "checkbox",
      "label": "t:sections.kinetic_text.settings.enable_custom_height.label"
    },
    {
      "type": "range",
      "id": "custom_height",
      "label": "t:sections.kinetic_text.settings.custom_height.label",
      "info": "t:sections.kinetic_text.settings.custom_height.info",
      "min": 50,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "default": 300
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "t:global.typography.content_position.label",
      "info": "t:sections.kinetic_text.settings.content_position.info",
      "options": [
        {
          "value": "start",
          "label": "t:global.alignment.left.label"
        },
        {
          "value": "center",
          "label": "t:global.alignment.center.label"
        }
      ],
      "default": "start"
    },
    {
      "type": "select",
      "id": "text_size",
      "label": "t:sections.kinetic_text.settings.text_size.label",
      "options": [
        {
          "value": "h1",
          "label": "t:global.typography.title_size.h1.label"
        },
        {
          "value": "h2",
          "label": "t:global.typography.title_size.h2.label"
        },
        {
          "value": "h3",
          "label": "t:global.typography.title_size.h3.label"
        },
        {
          "value": "h4",
          "label": "t:global.typography.title_size.h4.label"
        },
        {
          "value": "h5",
          "label": "t:global.typography.title_size.h5.label"
        }
      ],
      "default": "h2"
    },
    {
      "id": "enable_custom_text_size",
      "type": "checkbox",
      "label": "t:sections.kinetic_text.settings.enable_custom_text.label"
    },
    {
      "id": "custom_text_size",
      "type": "range",
      "label": "t:sections.kinetic_text.settings.custom_text_size.label",
      "info": "t:sections.kinetic_text.settings.custom_text_size.info",
      "min": 8,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 80
    },
    {
      "type": "select",
      "id": "font",
      "label": "t:global.typography.font.label",
      "info": "t:sections.kinetic_text.settings.font.info",
      "options": [
        {
          "value": "primary",
          "label": "t:global.typography.font.primary.label"
        },
        {
          "value": "secondary",
          "label": "t:global.typography.font.secondary.label"
        }
      ],
      "default": "secondary"
    },
    {
      "type": "header",
      "content": "t:global.mobile.header"
    },
    {
      "type": "select",
      "id": "mobile_text_size",
      "label": "t:sections.kinetic_text.settings.text_size.label",
      "options": [
        {
          "value": "h1",
          "label": "t:global.typography.title_size.h1.label"
        },
        {
          "value": "h2",
          "label": "t:global.typography.title_size.h2.label"
        },
        {
          "value": "h3",
          "label": "t:global.typography.title_size.h3.label"
        },
        {
          "value": "h4",
          "label": "t:global.typography.title_size.h4.label"
        },
        {
          "value": "h5",
          "label": "t:global.typography.title_size.h5.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "mobile_height",
      "label": "t:sections.kinetic_text.settings.mobile.mobile_height.label",
      "options": [
        {
          "value": "size-xs-mobile",
          "label": "t:sections.kinetic_text.settings.mobile.mobile_height.options__1.label"
        },
        {
          "value": "size-s-mobile",
          "label": "t:sections.kinetic_text.settings.mobile.mobile_height.options__2.label"
        },
        {
          "value": "size-m-mobile",
          "label": "t:sections.kinetic_text.settings.mobile.mobile_height.options__3.label"
        },
        {
          "value": "size-l-mobile",
          "label": "t:sections.kinetic_text.settings.mobile.mobile_height.options__4.label"
        }
      ],
      "default": "size-xs-mobile"
    },
    {
      "type": "header",
      "content": "t:global.spacing.header"
    },
    {
      "id": "spacing_desktop",
      "type": "range",
      "label": "t:global.spacing.spacing_desktop.label",
      "min": -300,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 50
    },
    {
      "id": "spacing_mobile",
      "type": "range",
      "label": "t:global.spacing.spacing_mobile.label",
      "min": -300,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 30
    },
    {
      "id": "fix_zindex",
      "type": "range",
      "label": "t:global.fix_zindex.label",
      "info": "t:global.fix_zindex.info",
      "min": 0,
      "max": 25,
      "step": 1,
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "t:sections.kinetic_text.blocks.title.name",
      "settings": [
        {
          "type": "select",
          "id": "font",
          "label": "t:global.typography.font.label",
          "info": "t:sections.kinetic_text.blocks.title.settings.font.info",
          "options": [
            {
              "value": "primary",
              "label": "t:global.typography.font.primary.label"
            },
            {
              "value": "secondary",
              "label": "t:global.typography.font.secondary.label"
            }
          ],
          "default": "secondary"
        },
        {
          "id": "text",
          "type": "inline_richtext",
          "label": "t:sections.kinetic_text.blocks.title.settings.text.label",
          "default": "This is an animated text banner"
        },
        {
          "id": "link_url",
          "type": "url",
          "label": "t:sections.kinetic_text.blocks.title.settings.link_url.label",
          "info": "t:sections.kinetic_text.blocks.title.settings.link_url.info"
        },
        {
          "id": "image",
          "type": "image_picker",
          "label": "t:sections.kinetic_text.blocks.title.settings.image.label",
          "info": "t:sections.kinetic_text.blocks.title.settings.image.info"
        },
        {
          "type": "range",
          "id": "image_width",
          "label": "t:sections.usp_bar.blocks.usp.settings.image_width.label",
          "min": 5,
          "max": 180,
          "step": 5,
          "unit": "px",
          "default": 55
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.kinetic_text.presets.name",
      "blocks": [
        {
          "type": "title"
        }
      ]
    }
  ]
}
{% endschema %}
