{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{%- liquid
  assign collections_menu = empty
  assign quick_links = empty
  assign show_menu = false
  if section.settings.enable_menu or section.settings.enable_collections
    if section.settings.enable_collections and section.settings.collections_menu != blank
      assign collections_menu = section.settings.collections_menu
    endif
    if section.settings.enable_menu
      assign quick_links = linklists[section.settings.filter_menu]
    endif
    assign show_menu = true
  endif
  assign sorting_block = section.blocks | where: 'type', 'sorting' | first
  assign description_block = section.blocks | where: 'type', 'description' | first
  assign show_filters_and_menu = true
  assign show_filters = section.settings.enable_filters
  assign static = true
  if section.settings.filters_layout == "drawer"
    assign static = false
  endif
  if show_filters and collection.filters == empty
    assign show_filters = false
  endif
  if show_menu and quick_links == empty and collections_menu == empty
    assign show_menu = false
  endif

  if show_filters == false and show_menu == false
    assign show_filters_and_menu = false
    assign static = false
   endif
  assign show_sidebar_menu = false
  if show_filters_and_menu and section.settings.filters_layout == 'drawer'
    assign show_sidebar_menu = true
  endif

  if section.settings.enable_secondary_products_per_row_mobile
    assign enable_collection_grid_choice_mobile = true
    assign first_width_class_mobile = 'w100-mobile|1'
    assign secondary_width_class_mobile = 'w50-mobile|2'
  else
    if section.settings.default_grid_mobile == '1'
      assign first_width_class_mobile = 'w100-mobile|1'
    else
      assign first_width_class_mobile = 'w50-mobile|2'
    endif
    assign secondary_width_class_mobile = first_width_class_mobile
  endif
  assign first_collection_grid_view_mobile = first_width_class_mobile | split: '|' | first
  assign secondary_collection_grid_view_mobile = secondary_width_class_mobile | split: '|' | first
  assign has_selected_view_mobile = false
  if cart.attributes.collection_grid_view_mobile == first_collection_grid_view_mobile or cart.attributes.collection_grid_view_mobile == secondary_collection_grid_view_mobile
    assign has_selected_view_mobile = true
  endif
  if has_selected_view_mobile and section.settings.enable_secondary_products_per_row_mobile
    assign width_class_mobile = cart.attributes.collection_grid_view_mobile | split: '|' | first
  else
    if section.settings.default_grid_mobile == '1'
      assign width_class_mobile = first_width_class_mobile | split: '|' | first
    else
      assign width_class_mobile = secondary_width_class_mobile | split: '|' | first
    endif
  endif

  case section.settings.products_per_row
    when 1
      assign first_width_class = 'w100|1'
    when 2
      assign first_width_class = 'w50|2'
    when 3
      assign first_width_class = 'w33|3'
    when 4
      assign first_width_class = 'w25|4'
  endcase
  assign img_width = 100 | divided_by: section.settings.products_per_row

  if section.settings.enable_secondary_products_per_row
    assign enable_collection_grid_choice = true
    case section.settings.secondary_products_per_row
      when 1
        assign secondary_width_class = 'w100|1'
      when 2
        assign secondary_width_class = 'w50|2'
      when 3
        assign secondary_width_class = 'w33|3'
      when 4
        assign secondary_width_class = 'w25|4'
      when 5
        assign secondary_width_class = 'w20|5'
    endcase
  else
    assign secondary_width_class = first_width_class
  endif
  assign first_collection_grid_view = first_width_class | split: '|' | first
  assign secondary_collection_grid_view = secondary_width_class | split: '|' | first
  assign has_selected_view_mobile = false
  if cart.attributes.collection_grid_view == first_collection_grid_view or cart.attributes.collection_grid_view == secondary_collection_grid_view
    assign has_selected_view = true
  endif
  if has_selected_view and section.settings.enable_secondary_products_per_row
    assign width_class = cart.attributes.collection_grid_view | split: '|' | first
  else
    if section.settings.default_grid == 'primary'
      assign width_class = first_width_class | split: '|' | first
    else
      assign width_class = secondary_width_class | split: '|' | first
    endif
  endif

  assign products_in_view = 1

  if section.settings.enable_variants
    if section.settings.enable_grid_list_toggle
      assign enable_collection_view_choice = true
    endif
    assign collection_view = cart.attributes.collection_view | default: section.settings.default_view
  else
    assign collection_view = 'grid'
  endif
-%}

{%- capture image_sizes -%}
  {% if settings.width < 2000 %}
    (min-width: 1300px)
    {%- if show_filters_and_menu -%}
      {%- if img_width == 100 -%}
        calc(({{ settings.width }}px - 275px) * 0.2)
      {%- else -%}
        calc(({{ settings.width }}px - 275px) * 0.{{ img_width }})
      {%- endif -%}
    {%- else -%}
      {%- if img_width == 100 -%}
        calc({{ settings.width }}px * 0.2)
      {%- else -%}
        calc({{ settings.width }}px * 0.{{ img_width }})
      {%- endif -%}
    {%- endif -%}
    ,
  {% endif %}
  (min-width: 1000px)
  {%- if show_filters_and_menu -%}
    {%- if img_width == 100 -%}
      calc((100vw - 275px) * 0.2)
    {%- else -%}
      calc((100vw - 275px) * 0.{{ img_width }})
    {%- endif -%}
  {%- else -%}
    {%- if img_width == 100 -%}
      calc(100vw * 0.2)
    {%- else -%}
      calc(100vw * 0.{{ img_width }})
    {%- endif -%}
  {%- endif -%}
  ,
  {%- if width_class_mobile contains 'w100-mobile' -%}
    100vw
  {%- else -%}
    50vw
  {%- endif -%}
{%- endcapture -%}

{%- if section.settings.enable_variants -%}
  <link rel="stylesheet" href="{{ 'async-product-variants.css' | asset_url }}">
{%- endif -%}

<div class="collection-wrapper {% if static or show_menu %}m6cl{% if section.settings.filter_sticky and static %} sticky{% endif %}{% endif %}{% if section.settings.filters_menu_alignment == 'right' %} m6cl-inv{% endif %}" {% if section.settings.enable_filters %}data-filters="true"{% endif %}>
  {%- if show_filters_and_menu -%}<div>{%- endif -%}
    {%- for block in section.blocks -%}
      {%- case block.type -%}
      	{%- when '@app' -%}
          {% render block %}
        {%- when 'spacer' -%}
          <div class="module-spacer" style="margin-bottom:{{ block.settings.height }}px;" {{ block.shopify_attributes }}></div>
        {%- when 'title'-%}
          <{{ block.settings.title_size }} class="{% if block.settings.text_alignment == 'center' %}text-center{% else %}text-start{% endif %}" {{ block.shopify_attributes }}>
              {{ collection.title }}{% if section.settings.show_amount_of_products_in_collection %} ({{ collection.products_count | default: 0 }}){% endif %}
          </{{ block.settings.title_size }}>
          {%- if sorting_block == nil and show_filters -%}
            {%- render 'filters-sorting',
              display: 'filter-button',
              sticky: section.settings.filter_sticky,
              layout: section.settings.filters_layout,
              show_filters: show_filters
            -%}
          {%- endif -%}
        {%- when 'short_description'-%}
          {%- liquid
            assign read_more = false
            if block.settings.short_description == 'custom'
              assign short_description = block.settings.short_description_text
              assign read_more = true
            else
              if block.settings.strip_html
                assign short_description = collection.description | strip_html | truncatewords: 50, '...'
                assign word_count = collection.description | strip_html | split: ' ' | size
              else
                assign short_description = collection.description | truncatewords: 50, '...'
                assign word_count = collection.description | split: ' ' | size
              endif
              if word_count > 50
                assign read_more = true
              endif
            endif
          -%}
          {% if short_description != blank and short_description != empty %}
            <article class="{% if block.settings.text_alignment == 'center' %}text-center{% endif %}{% if block.settings.content_alignment == 'center' %} align-center{% endif %}" {% unless settings.width < 2000 and block.settings.max_width == 1280 %}style="max-width: {{ block.settings.max_width }}px;"{% endunless %} {{ block.shopify_attributes }}>
              <div>
                {{ short_description }}
                {% if block.settings.enable_read_more and description_block != nil and read_more %}
                  <p class="has-link-more"><a href="#description" class="strong inline"><span class="link-underline">{{ 'general.read_more.read' | t }} {{ 'general.read_more.more' | t }}</span></a></p>
                {% endif %}
              </div>
            </article>
          {% endif %}
        {%- when 'custom_liquid' -%}
          {{ block.settings.custom_liquid }}
        {%- when 'description'-%}
          <article id="description" class="cols b30 {% if block.settings.text_alignment == 'center' %}text-center{% endif %}{% if block.settings.content_alignment == 'center' %} align-center{% endif %}"
              {% unless settings.width < 2000 and block.settings.max_width == 1280 %}style="max-width: {{ block.settings.max_width }}px;"{% endunless %} {{ block.shopify_attributes }}>
            {%- if collection.image and section.settings.show_collection_image -%}
              <figure class="w50 desktop-hide {% if settings.multiply_collection_images == 'multiply' %}img-multiply{% elsif settings.multiply_collection_images == 'multiply-bg' %}img-multiply-bg{% endif %}">
                <img
                  src="{{ collection.image | image_url: width: 640 }}"
                  srcset="{% render 'image-srcset', image: collection.image, max_width: 720 %}"
                  sizes="
                    (min-width: 1000px) 0
                    (min-width: 760px) 50vw
                    100vw
                  "
                  alt="{{ collection.image.alt | default: collection.title | escape }}"
                  width="640"
                  height="640"
                  loading="lazy"
                >
              </figure>
            {%- endif -%}
            {%- if collection.description != empty or block.settings.text != empty -%}
              <div class="w50">
                {%- if block.settings.enable_read_more -%}
                  <div class="m6lm">
                      {{ collection.description }}
                  </div>
                  <p class="has-link-more"><a href="./" class="strong inline link-more"><span class="link-underline">{{ 'general.read_more.read' | t }} <span>{{ 'general.read_more.more' | t }}</span> <span class="hidden">{{ 'general.read_more.less' | t }}</span></span></a></p>

                {%- else -%}
                    {{ collection.description }}
                {% endif %}
              </div>
            {%- endif -%}
          </article>
        {%- when 'sorting'-%}
          {%- render 'filters-sorting',
            display: 'sorting',
            sticky: section.settings.filter_sticky,
            show_filters: show_filters,
            origin: "collection",
            object: collection,
            collection_view: collection_view,
            enable_collection_view_choice: enable_collection_view_choice,
            enable_collection_grid_choice: enable_collection_grid_choice,
            collection_grid_view: width_class,
            grid_1: first_width_class,
            grid_2: secondary_width_class,
            enable_collection_grid_choice_mobile: enable_collection_grid_choice_mobile,
            collection_grid_view_mobile: width_class_mobile,
            grid_1_mobile: first_width_class_mobile,
            grid_2_mobile: secondary_width_class_mobile,
            layout: section.settings.filters_layout
          -%}
        {%- when 'product_grid' -%}
          {%- if collection.products.size > 0 -%}
            {%- paginate collection.products by section.settings.pagination_qty -%}
              {%- if section.settings.pagination_type == 'button' and paginate.previous %}
                {% render 'pagination',
                  paginate: paginate,
                  pagination_type: section.settings.pagination_type,
                  prev_button: true
                %}
              {%- endif -%}
              <ul id="collection" class="l4cl margin-20 {{ width_class }} {{ width_class_mobile }} {% unless settings.grid_style == 'default' %}l4cl-{{ settings.grid_style }}{% endunless %}{% if collection_view == 'list' %} list{% endif %} {% unless show_filters_and_menu %} mobile-wide{% endunless %} mobile-scroll{% if settings.layout_productcard contains 'add_to_cart' %} has-variant-picker{% if section.settings.mobile_show_add_to_cart == false %} mobile-no-form{% endif %}{% endif %}" {{ block.shopify_attributes }}
                  style="--dist: {{ settings.space_between_products }}px; --dist_a: {% if settings.grid_style == 'border' %}0px;{% else %}{{ settings.space_between_products }}px;{% endif %}{% if static == false and section.settings.enable_variants %} --img_w: clamp(120px, 25%, 320px);{% endif %}"
              >
                {%- liquid
                  if section.settings.fill_product_images
                    assign largest_product_img = collection.products.first
                  else
                    if show_sidebar_menu and products_in_view > 3 and section.settings.custom_product_image_ratio < 100
                      assign products_in_view = products_in_view | times: 2
                    endif
                    for product in collection.products limit: products_in_view
                      if product.selected_or_first_available_variant.featured_image
                        assign product_image = product.selected_or_first_available_variant.featured_image
                      else
                        assign product_image = product.featured_image
                      endif
                      if largest_img_width == nil or product_image.width > largest_img_width
                        assign largest_img_width = product_image.width
                        assign largest_product_img = product
                      endif
                    endfor
                  endif
                  assign fill_first_image = section.settings.fill_images
                  if section.settings.fill_images and section.settings.fill_not_first
                    assign fill_first_image = false
                  endif

                  unless paginate.previous
                    assign banners = section.blocks | where: "type", "banner"
                  endunless
                -%}
                {%- for product in collection.products -%}
                  {%- liquid
                    capture placeholder_int
                      cycle 1, 2, 3, 4, 5, 6
                    endcapture
                    assign no_lazyload = false
                    if forloop.first or largest_product_img == product
                      assign no_lazyload = true
                    elsif width_class contains 'w50-mobile' and forloop.index == 2
                      assign no_lazyload = true
                    else
                      assign no_lazyload = false
                    endif
                  -%}
                  {%- render 'product-item',
                    product: product,
                    placeholder_int: placeholder_int,
                    sizes: image_sizes,
                    fill_images: section.settings.fill_images,
                    fill_first_image: fill_first_image,
                    img_padding: section.settings.images_padding,
                    img_vertical_position: section.settings.images_vertical_position,
                    custom_height_ratio: section.settings.custom_product_image_ratio,
                    no_lazyload: no_lazyload,
                    type: 'both',
                    enable_bulk: section.settings.enable_variants,
                    origin: 'collection'
                  -%}

                  {% for banner in banners %}
                    {% if banner.settings.position == forloop.parentloop.index %}
                      {%- liquid
                        assign custom_height_ratio = 100 | divided_by: 100.0
                        assign image_width = 430
                        assign image_height = image_width | times: custom_height_ratio | round
                        assign image_width_2 = image_width | times: 1.5
                        assign image_height_2 = image_height | times: 1.5
                      -%}
                      <li class="palette-{{ banner.settings.color_palette }} module-color-palette featured text-{{ banner.settings.text_position | split: ' ' | last }} {{ banner.settings.height }}-height" style="--ratio:{{ section.settings.custom_product_image_ratio | divided_by: 100.0 }};" {{ banner.shopify_attributes }}>
                        {% if banner.settings.height == 'auto' %}<div><div>{% endif %}
                        <figure>
                          <span class="img-overlay" style="opacity:{{ banner.settings.overlay_opacity | divided_by: 100.0 }}"></span>
                          <picture>
                            {% if banner.settings.image %}
                              {% assign image = banner.settings.image %}
                              <img
                                      src="{{ image | image_url: width: image_width_2, height: image_height_2, crop: 'center' }}"
                                      srcset="{{ image | image_url: width: image_width, height: image_height, crop: 'center' }} 1x, {{ image | image_url: width: image_width_2, height: image_height_2, crop: 'center' }} 2x "
                                      width="{{ image_width }}"
                                      height="{{ image_height }}"
                                      alt="{{ image.alt | default: product.title | escape }}"
                                      loading="{% if section.index > 1 %}lazy{% else %}eager{% endif %}"
                                      class="filled"
                              >
                            {% else %}
                              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                            {% endif %}
                          </picture>
                        </figure>
                        <div style="--align_text: {{ banner.settings.text_position | split: ' ' | first }};
                                --justify_text: {{ banner.settings.text_position | split: ' ' | last }};">
                          {% if banner.settings.link_url != blank %}<a class="link-overlay" href="{{ banner.settings.link_url }}"></a>{% endif %}
                          {%- if banner.settings.title != empty -%}
                            <div class="
                            {% if banner.settings.title_underline_style != 'none' %}
                              title-underline-none
                              {% if banner.settings.title_underline_style contains 'accent' %}
                                title-underline-accent
                              {% elsif banner.settings.title_underline_style contains 'gradient' %}
                                title-underline-gradient
                              {% endif %}
                              {% if banner.settings.title_underline_style contains 'secondary_font' %}
                                title-underline-secondary-font
                              {% endif %}
                            {% endif %}
                          ">
                              {{ banner.settings.title }}
                            </div>
                          {%- endif -%}
                          {% liquid
                            assign link = false
                            if banner.settings.show_link and banner.settings.link_text != empty and banner.settings.link_url != blank
                              assign link = true
                            endif
                          %}
                          {%- if banner.settings.text != empty -%}<div>{{ banner.settings.text }}</div>{%- endif -%}
                          {%- if link -%}
                            {%- liquid
                              assign button_color = banner.settings.button_style | split: ' ' | first
                              assign button_style = banner.settings.button_style | split: ' ' | last
                              assign is_link = false
                              if button_style == 'link'
                                assign is_link = true
                              endif
                            -%}
                            <p class="link{% unless is_link %}-btn{% endunless %} m0">
                              <a href="{{ banner.settings.link_url }}" class="overlay-{{ button_color }} {% if is_link %}strong inline{% elsif button_style == 'inv' %}inv{% endif %}">
                                <span {% if is_link %}class="link-underline"{% endif %}>{{ banner.settings.link_text }}</span>
                              </a>
                            </p>
                          {%- endif %}
                          {%- if settings.banners_clickable and banner.settings.show_link and banner.settings.link_url != blank and banner.settings.link_text == blank -%}
                            <a class="link-overlay" href="{{ banner.settings.link_url }}" aria-label="{{ banner.settings.title | escape | default: banner.settings.image.alt | default: "Image banner" }}"></a>
                          {%- endif -%}
                        </div>
                        {% if banner.settings.height == 'auto' %}</div></div>{% endif %}
                      </li>
                    {% endif %}
                  {% endfor %}

                {%- endfor -%}
              </ul>
              {% render 'pagination',
                paginate: paginate,
                pagination_type: section.settings.pagination_type,
                show_amount: section.settings.show_amount_of_products_in_collection
              %}
            {%- endpaginate -%}
          {%- else -%}
            <p class="base-font">{{ 'collection.empty_collection_html' | t }}</p>
          {%- endif -%}
        {%- when 'brand_slider'-%}
          {%- liquid
            assign skip_slider = false
            if collection.all_vendors != blank
              for product_vendor in collection.all_vendors
                assign product_vendor_handleized = product_vendor | escape | handleize
                assign collection_title_handleized = collection.title | escape | handleize
                if forloop.length < 2 and product_vendor_handleized == collection_title_handleized
                  assign skip_slider = true
                endif
              endfor
            else
                assign skip_slider = true
            endif
            if skip_slider
              continue
            endif
          -%}
          {%- comment -%} Build vendor list in collection product order (respects collection sort — set to "Best selling" in admin for bestseller ordering) {%- endcomment -%}
          {%- liquid
            assign bm_sorted_vendors = ''
            for product in collection.products limit: 250
              assign pv = product.vendor
              assign bm_vl_arr = bm_sorted_vendors | split: '|||'
              assign bm_found = false
              for v in bm_vl_arr
                if v == pv
                  assign bm_found = true
                  break
                endif
              endfor
              unless bm_found
                if bm_sorted_vendors == ''
                  assign bm_sorted_vendors = pv
                else
                  assign bm_sorted_vendors = bm_sorted_vendors | append: '|||' | append: pv
                endif
              endunless
            endfor
            assign bm_sorted_arr = bm_sorted_vendors | split: '|||'
          -%}
      <div class="bm-brands" {{ block.shopify_attributes }}>
        <div class="bm-brands__track">
          {%- for bm_vendor in bm_sorted_arr -%}
            {%- liquid
              assign vendor_handle = bm_vendor | handleize
              assign vendor_collection = collections[vendor_handle]
              assign has_vendor_image = false
              if vendor_collection != blank and vendor_collection.image.src
                assign has_vendor_image = true
              endif
            -%}
            <a href="{{ vendor_collection.url | default: '#' }}" class="bm-brands__item" title="{{ bm_vendor | escape }}">
              {%- if has_vendor_image -%}
                <img
                  src="{{ vendor_collection.image.src | image_url: width: 160 }}"
                  srcset="{% render 'image-srcset', image: vendor_collection.image.src, max_width: 320 %}"
                  sizes="140px"
                  width="140"
                  height="64"
                  alt="{{ bm_vendor | escape }}"
                  loading="{% if forloop.index > 6 %}lazy{% else %}eager{% endif %}"
                  {% if block.settings.multiply %}class="img-multiply"{% endif %}
                >
              {%- else -%}
                <span class="bm-brands__name">{{ bm_vendor | escape }}</span>
              {%- endif -%}
            </a>
          {%- endfor -%}
        </div>
      </div>
      <style>
        .bm-brands {
          position: relative;
          margin: 0 0 8px;
          overflow: hidden;
        }
        .bm-brands::after {
          content: '';
          position: absolute;
          top: 0;
          right: 0;
          bottom: 0;
          width: 40px;
          background: linear-gradient(to right, transparent, #fff);
          pointer-events: none;
          z-index: 1;
        }
        .bm-brands__track {
          display: flex;
          gap: 12px;
          overflow-x: auto;
          scroll-behavior: smooth;
          -webkit-overflow-scrolling: touch;
          scrollbar-width: none;
          padding: 8px 0;
          align-items: center;
        }
        .bm-brands__track::-webkit-scrollbar { display: none; }
        .bm-brands__item {
          flex: 0 0 auto;
          display: flex;
          align-items: center;
          justify-content: center;
          height: 32px;
          padding: 4px 8px;
          text-decoration: none;
        }
        .bm-brands__item img {
          max-height: 24px;
          width: auto;
          object-fit: contain;
        }
        .bm-brands__name {
          font-size: 10px;
          font-weight: 600;
          color: #666;
          white-space: nowrap;
        }
        @media screen and (min-width: 750px) {
          .bm-brands__track {
            flex-wrap: wrap;
            overflow-x: visible;
            gap: 16px;
          }
          .bm-brands::after {
            display: none;
          }
          .bm-brands__item img {
            max-height: 28px;
          }
        }
      </style>
        {%- when 'collection_navigation'-%}
          {%- liquid
            assign collection_nav = collections[block.settings.collection]
            assign link = false

            if block.settings.show_link and block.settings.link_text != empty and block.settings.link_url != blank
              assign link = true
            endif

            if block.settings.title != empty
              assign show_header = true
            elsif link and block.settings.text_alignment == 'start'
              assign show_header = true
            endif

            if block.settings.title != empty
              assign container_div = true
            endif

            capture title_classes
              echo 'w900'
              if block.settings.text_alignment == 'center'
                echo ' text-center align-center'
              endif
            endcapture

            if block.settings.collections == blank and request.design_mode == false
              continue
            endif
          -%}
          {%- if link %}
            {%- capture link -%}
              {%- liquid
                assign button_color = block.settings.button_style | split: ' ' | first
                assign button_style = block.settings.button_style | split: ' ' | last
                assign is_link = false
                if button_style == 'link'
                  assign is_link = true
                endif
              -%}
              <p class="class-x link{% unless is_link %}-btn{% endunless %}"><a href="{{ block.settings.link_url }}" class="overlay-{{ button_color }} {% if is_link %}inline strong{% elsif button_style == 'inv' %}inv{% endif %}"><span {% if is_link %}class="link-underline"{% endif %}>{{ block.settings.link_text }}</span></a></p>
            {%- endcapture %}
          {%- endif -%}

          {%- if show_header -%}
            <header class="cols{% if link and is_link == false %} align-middle{% endif %}{% if block.settings.title == empty %} text-end{% endif %}">
            {%- if container_div -%}<div class="{{ title_classes }}">{%- endif -%}
                {%- if block.settings.title != blank -%}
                  <div class="title-styling
                    {% if block.settings.title_underline_style != 'none' %}
                      title-underline-none
                      {% if block.settings.title_underline_style contains 'accent' %}
                        title-underline-accent
                      {% elsif block.settings.title_underline_style contains 'gradient' %}
                        title-underline-gradient
                      {% endif %}
                      {% if block.settings.title_underline_style contains 'secondary_font' %}
                        title-underline-secondary-font
                      {% endif %}
                    {% endif %}
                  ">
                    {{ block.settings.title }}
                  </div>
                {%- endif -%}
            {%- if container_div -%}</div>{%- endif -%}
            {%- if link and block.settings.text_alignment == 'start' -%}
              {{ link | replace: 'class-x', 'mobile-hide' }}
            {%- endif -%}
          </header>
        {%- endif -%}
        {% if block.settings.collection_layout == 'slider' %}
          {%- liquid
            assign cn_number = block.settings.number_of_items
            case cn_number
              when 0
                assign cn_width_class = 'w33'
              when 1
                assign cn_width_class = 'w33'
              when 2
                assign cn_width_class = 'w50'
              when 3
                assign cn_width_class = 'w33'
              when 4
                assign cn_width_class = 'w25'
              when 5
                assign cn_width_class = 'w20'
              when 6
                assign cn_width_class = 'w16'
              when 7
                assign cn_width_class = 'w14'
              else
                assign cn_width_class = 'w12'
            endcase
          -%}
          <div class="syk-slider-container" data-visible-items="{{ block.settings.number_of_items }}">
          <ul class="l4cl category b2r bls dont-move syk-slider auto-height {{ cn_width_class }} align-stretch text-center{% if block.settings.mobile_layout == 'grid' %} mobile-scroll {% if block.settings.show_collection_titles %}w50-mobile{% else %}w25-mobile{% endif %}{% endif %}" {% unless block.settings.show_collection_titles %} style="--img_small_w: 70px;"{% endunless %} {{ block.shopify_attributes }}>
            {%- if block.settings.collections == blank %}
              {%- for i in (1..block.settings.number_of_items) %}
                {%- liquid
                  capture current
                    cycle 1, 2, 3, 4, 5
                  endcapture
                -%}
                <li class="{% if block.settings.show_collection_titles %}has-text{% elsif block.settings.show_in_circle and block.settings.custom_image_ratio == 100 %} rounded{% endif %}" style="--bw: 1px; --bd: {{ block.settings.border_color }}; --pd: 10px;">
                  <a href="{{ collection_nav.url }}" class="link-overlay" aria-label="Collection title"></a>
                  {% if block.settings.show_collection_titles %}<div class="cols cols-mobile align-middle"><div>{% endif %}
                  <figure class="no-bd-radius{% if settings.multiply_collection_images == 'multiply' %} img-multiply{% elsif settings.multiply_collection_images == 'multiply-bg' %} img-multiply-bg{% endif %}{% if block.settings.show_in_circle and block.settings.custom_image_ratio == 100 %} rounded{% endif %}" style="--ratio:{{ block.settings.custom_image_ratio | divided_by: 100.0 }};">
                    <picture>
                      {{ 'collection-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
                    </picture>
                  </figure>
                  {% if block.settings.show_collection_titles %}</div><div class="{% if block.settings.collection_title_position == 'start' %}text-start{% endif %}"><p class="inline fw-{{ block.settings.text_weight }} ff-{{ block.settings.text_font }} fw-{{ block.settings.text_weight }} size-{{ block.settings.collection_title_size | remove: 'px' }}">Collection title</p></div></div>{% endif %}
                </li>
              {%- endfor -%}
            {%- else %}
              {% for collection in block.settings.collections %}
                {%- liquid
                  capture current
                    cycle 1, 2, 3, 4, 5, 6
                  endcapture
                -%}
                <li class="{% if block.settings.show_collection_titles %}has-text{% elsif block.settings.show_in_circle and block.settings.custom_image_ratio == 100 %} rounded{% endif %}"  style="--bw: 1px; --bd: {{ block.settings.border_color }}; --pd: 10px;">
                  <a href="{{ collection.url }}" class="link-overlay"></a>
                  {% if block.settings.show_collection_titles %}<div class="cols cols-mobile align-middle"><div>{% endif %}
                  <figure class="no-bd-radius{% if settings.multiply_collection_images == 'multiply' %} img-multiply{% elsif settings.multiply_collection_images == 'multiply-bg' %} img-multiply-bg{% endif %}{% if block.settings.show_in_circle and block.settings.custom_image_ratio == 100 %} rounded{% endif %}" style="--ratio:{{ block.settings.custom_image_ratio | divided_by: 100.0 }};">
                    <picture>
                      {% if collection.featured_image %}
                        <img
                          src="{{- collection.featured_image | image_url: width: 125 -}}"
                          srcset="{{ collection.featured_image | image_url: width: 125 }} 1x,{{ collection.featured_image | image_url: width: 250 }} 2x"
                          width="125"
                          height="125"
                          alt="{{ collection.featured_image.alt | default: collection.title | escape }}"
                          {% if block.settings.fill_images %}class="filled"{% endif %}
                          loading="{% if block.index > 1 or forloop.first == false %}lazy{% else %}eager{% endif %}"
                        >
                      {% else %}
                        {{ 'collection-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
                      {% endif %}
                    </picture>
                  </figure>
                  {% if block.settings.show_collection_titles %}
                    </div><div class="{% if block.settings.collection_title_position == 'start' %}text-start{% endif %}">
                      <p class="inline fw-{{ block.settings.text_weight }} ff-{{ block.settings.text_font }} size-{{ block.settings.collection_title_size | remove: 'px' }}">{{ collection.title }}</p>
                    </div></div>
                  {% endif %}
                </li>
              {% endfor %}
            {% endif %}
          </ul>
          <div class="syk-slider-pagination">
            <span class="syk-slider-button hidden" data-direction="prev" role="button" aria-label="Previous slide"></span>
            <span class="syk-slider-button" data-direction="next" role="button" aria-label="Next slide"></span>
          </div>
          </div>
        {% else %}
          <ul class="l4cl category category-navigation {% if block.settings.mobile_layout == 'grid' %} mobile-scroll w50-mobile{% endif %}{% if block.settings.text_alignment == 'center' %} justify-center{% endif %}{% if block.settings.collection_title_position == 'center' %} text-center{% endif %}"
              style="--fixed_width: {{ block.settings.collection_size }}px" {{ block.shopify_attributes }}
          >
            {%- if block.settings.collections == blank %}
              {%- for i in (1..5) %}
                {%- liquid
                  capture current
                    cycle 1, 2, 3, 4, 5
                  endcapture
                -%}
                <li>
                  <figure class="{% if block.settings.show_collection_titles %}m10 {% endif %}{% if settings.multiply_collection_images == 'multiply' %}img-multiply{% elsif settings.multiply_collection_images == 'multiply-bg' %}img-multiply-bg{% endif %}{% if block.settings.show_in_circle and block.settings.custom_image_ratio == 100 %} rounded{% endif %}" style="--ratio:{{ block.settings.custom_image_ratio | divided_by: 100.0 }}; {% if block.settings.show_border %}--bw: var(--btn_bd); --bd: {{ block.settings.border_color }};{% endif %} --pd: 3px;">
                    <picture>
                      {% if block.settings.show_collection_titles == false %}
                        <a href="{{ collection_nav.url }}" aria-label="Collection title"></a>
                      {% endif %}
                      {{ 'collection-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
                    </picture>
                  </figure>
                  {% if block.settings.show_collection_titles %}<p class="inline"><a href="" class="overlay-content"><span class="fw-{{ block.settings.text_weight }} ff-{{ block.settings.text_font }} size-{{ block.settings.collection_title_size | remove: 'px' }}">Collection title</span></a></p>{% endif %}
                </li>
              {%- endfor -%}
            {%- else %}
              {%- for collection in block.settings.collections -%}
                {%- liquid
                  capture current
                    cycle 1, 2, 3, 4, 5, 6
                  endcapture
                -%}
                <li>
                  <figure class="{% if block.settings.show_collection_titles %}m10 {% endif %}{% if settings.multiply_collection_images == 'multiply' %}img-multiply{% elsif settings.multiply_collection_images == 'multiply-bg' %}img-multiply-bg{% endif %}{% if block.settings.show_in_circle and block.settings.custom_image_ratio == 100 %} rounded{% endif %}" style="--ratio:{{ block.settings.custom_image_ratio | divided_by: 100.0 }}; {% if block.settings.show_border %}--bw: var(--btn_bd); --bd: {{ block.settings.border_color }};{% endif %} --pd: 3px;">
                    <picture>
                      {% if block.settings.show_collection_titles == false %}
                        <a href="{{ collection.url }}" aria-label="{{ collection.title | escape }}"></a>
                      {% endif %}
                      {% if collection.featured_image %}
                        <img
                            src="{{- collection.featured_image | image_url: width: 125 -}}"
                            srcset="{{ collection.featured_image | image_url: width: 125 }} 1x,{{ collection.featured_image | image_url: width: 250 }} 2x"
                            width="125"
                            height="125"
                            alt="{{ collection.featured_image.alt | default: collection.title | escape }}"
                            {% if block.settings.fill_images %}class="filled"{% endif %}
                            loading="{% if block.index > 1 or forloop.first == false %}lazy{% else %}eager{% endif %}"
                        >
                      {% else %}
                        {{ 'collection-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
                      {% endif %}
                    </picture>
                  </figure>
                  {% if block.settings.show_collection_titles %}<p class="inline"><a href="{{ collection.url }}" class="overlay-content"><span class="fw-{{ block.settings.text_weight }} ff-{{ block.settings.text_font }} size-{{ block.settings.collection_title_size | remove: 'px' }}">{{ collection.title }}</span></a></p>{% endif %}
                </li>
              {%- endfor -%}
            {% endif -%}
          </ul>
        {% endif %}
        {%- if link and block.settings.text_alignment == 'center' -%}
          {{ link | replace: 'class-x', 'text-center' }}
        {%- elsif link and block.settings.text_alignment == 'start' -%}
          {{ link | replace: 'class-x', 'mobile-only' }}
        {%- endif -%}

        <style>
          #shopify-section-{{ block.id }} { z-index: {{ block.settings.fix_zindex }}!important; }
          @media only screen and (min-width: 47.5em) {
          {% if link and block.settings.text_alignment == 'center' %}
            #shopify-section-{{ block.id }} { margin-bottom: {{ block.settings.spacing_desktop }}px; }
          {% else %}
            #shopify-section-{{ block.id }} .l4cl { margin-bottom: {{ block.settings.spacing_desktop | minus: 22 }}px; }
          {% endif %}
          {% if block.settings.spacing_desktop < 0 %}
            #shopify-section-{{ block.id }} + *.has-kinetic-text { pointer-events: none; }
          {% endif %}

          }
          @media only screen and (max-width: 47.5em) {
          {% if link %}
            #shopify-section-{{ block.id }} { margin-bottom: {{ block.settings.spacing_mobile }}px; }
          {% else %}
            #shopify-section-{{ block.id }} .l4cl { margin-bottom: {{ block.settings.spacing_mobile | minus: 8 }}px; }
          {% endif %}
          {% if block.settings.spacing_mobile < 0 %}
            #shopify-section-{{ block.id }} + *.has-kinetic-text { pointer-events: none; }
          {% endif %}
          }
        </style>
      {%- endcase -%}
    {%- endfor -%}
    {%- if description_block == nil and section.settings.show_collection_image and collection.image -%}
      <article class="cols b30" {{ block.shopify_attributes }}>
        <figure class="w50 desktop-hide {% if settings.multiply_collection_images == 'multiply' %}img-multiply{% elsif settings.multiply_collection_images == 'multiply-bg' %}img-multiply-bg{% endif %}">
          <img
            src="{{ collection.image | image_url: width: 640 }}"
            srcset="{% render 'image-srcset', image: collection.image, max_width: 720 %}"
            sizes="
              (min-width: 1000px) 0
              (min-width: 760px) 50vw
              100vw
            "
            alt="{{ collection.image.alt | default: collection.title | escape }}"
            width="640"
            height="640"
            loading="lazy"
          >
        </figure>
      </article>
    {%- endif -%}
  {%- if show_filters_and_menu -%}</div>{%- endif -%}
  {% if show_filters_and_menu %}

    {% if show_sidebar_menu %}
      <aside>
        {%- render 'filters-sorting',
            display: 'menu',
            layout: section.settings.filters_layout,
            quick_links: quick_links,
            collections_menu: collections_menu,
            show_collection_image: section.settings.show_collection_image
        -%}
      </aside>
    {% endif %}

    {% for filter in collection.filters limit: 1 %}{% endfor %} {% comment %} This is just to get rid of the "this theme does not support filters" message in the shopify admin {% endcomment %}
    {% if section.settings.filters_layout == 'static' %}<aside>{% else %}<div {% if request.design_mode %}data-editor="true"{% endif %} class="m6pn{% if section.settings.filters_menu_alignment == 'left' %} inv{% endif %}" id="filters-aside">{% endif %}
      {%- render 'filters-sorting',
        display: 'filters',
        layout: section.settings.filters_layout,
        show_filters: show_filters,
        quick_links: quick_links,
        collections_menu: collections_menu,
        show_collection_image: section.settings.show_collection_image,
        filters_show_more_limit: section.settings.filters_show_more_limit,
        reverse_order: section.settings.menu_below_filters
      -%}
      {% if section.settings.filters_layout == 'static' %}</aside>{% else %}</div>{% endif %}
  {% endif %}
</div>

<style>
  #shopify-section-{{ section.id }} { position: initial !important; z-index: {{ section.settings.fix_zindex }}!important; }
  @media only screen and (min-width: 761px) {
    .l4cl.dynamic-quickshop .link-btn.visible { display: none; }
  }

  @media only screen and (min-width: 47.5em) {
    #shopify-section-{{ section.id }} .m6cl { margin-bottom: {{ section.settings.spacing_desktop | minus: 16 }}px; }
    {% if section.settings.spacing_desktop < 0 %}
      #shopify-section-{{ section.id }} + *.has-kinetic-text { pointer-events: none; }
    {% endif %}
  }
  @media only screen and (max-width: 47.5em) {
    #shopify-section-{{ section.id }} .m6cl { margin-bottom: {{ section.settings.spacing_mobile | minus: 16 }}px; }
    {% if section.settings.spacing_mobile < 0 %}
      #shopify-section-{{ section.id }} + *.has-kinetic-text { pointer-events: none; }
    {% endif %}
  }
</style>

{% schema %}
{
  "name": "t:main.collection.name",
  "settings": [
    {
      "type": "header",
      "content": "t:main.collection.settings.layout.header"
    },
    {
      "type": "range",
      "id": "pagination_qty",
      "label": "t:main.collection.settings.layout.pagination_qty.label",
      "min": 12,
      "max": 48,
      "step": 6,
      "default": 18
    },
    {
      "id": "pagination_type",
      "type": "select",
      "label": "t:main.collection.settings.layout.pagination_type.label",
      "options": [
        {
          "value": "pages",
          "label": "t:main.collection.settings.layout.pagination_type.options__1.label"
        },
        {
          "value": "button",
          "label": "t:main.collection.settings.layout.pagination_type.options__2.label"
        }
      ],
      "default": "button"
    },
    {
      "type": "checkbox",
      "id": "show_amount_of_products_in_collection",
      "label": "t:main.collection.settings.layout.show_amount_of_products_in_collection.label",
      "info": "t:main.collection.settings.layout.show_amount_of_products_in_collection.info",
      "default": true
    },
    {
      "type": "header",
      "content": "t:main.search.settings.grid.header"
    },
    {
      "type": "range",
      "id": "products_per_row",
      "label": "t:main.collection.settings.grid.products_per_row.label",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "id": "enable_secondary_products_per_row",
      "type": "checkbox",
      "label": "t:main.collection.settings.grid.enable_secondary_products_per_row.label",
      "default": true
    },
    {
      "type": "range",
      "id": "secondary_products_per_row",
      "label": "t:main.collection.settings.grid.secondary_products_per_row.label",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "id": "default_grid",
      "type": "select",
      "label": "t:main.collection.settings.grid.default_grid.label",
      "options": [
        {
          "value": "primary",
          "label": "t:main.collection.settings.grid.default_grid.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:main.collection.settings.grid.default_grid.options__2.label"
        }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "t:main.collection.settings.variants.header"
    },
    {
      "id": "enable_variants",
      "type": "checkbox",
      "label": "t:main.collection.settings.variants.enable_variants.label",
      "info": "t:main.collection.settings.variants.enable_variants.info",
      "default": true
    },
    {
      "id": "bulk_title",
      "type": "text",
      "label": "t:main.collection.settings.variants.bulk_title.label",
      "default": "Select quantities",
      "placeholder": "Select quantities"
    },
    {
      "type": "checkbox",
      "id": "bulk_show_unavailable_variants",
      "label": "t:main.collection.settings.variants.bulk_show_unavailable_variants.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "bulk_show_variant_images",
      "label": "t:main.collection.settings.variants.bulk_show_variant_images.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "bulk_shorten_title",
      "label": "t:main.collection.settings.variants.bulk_shorten_title.label",
      "info": "t:main.collection.settings.variants.bulk_shorten_title.info",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "bulk_show_deliverytime",
      "label": "t:main.collection.settings.variants.bulk_show_deliverytime.label"
    },
    {
      "id": "show_product_description",
      "type": "checkbox",
      "label": "t:main.collection.settings.variants.show_product_description.label",
      "default": true
    },
    {
      "id": "enable_grid_list_toggle",
      "type": "checkbox",
      "label": "t:main.collection.settings.enable_grid_list_toggle.label",
      "info": "t:main.collection.settings.enable_grid_list_toggle.info",
      "default": true
    },
    {
      "id": "default_view",
      "type": "select",
      "label": "t:main.collection.settings.default_view.label",
      "options": [
        {
          "value": "grid",
          "label": "t:main.collection.settings.default_view.options__1.label"
        },
        {
          "value": "list",
          "label": "t:main.collection.settings.default_view.options__2.label"
        }
      ],
      "default": "list"
    },
    {
      "type": "header",
      "content": "t:main.collection.settings.images.header"
    },
    {
      "id": "custom_product_image_ratio",
      "type": "range",
      "label": "t:main.collection.settings.images.custom_product_image_ratio.label",
      "info": "t:main.collection.settings.images.custom_product_image_ratio.info",
      "min": 50,
      "max": 175,
      "step": 5,
      "unit": "%",
      "default": 125
    },
    {
      "id": "fill_images",
      "type": "checkbox",
      "label": "t:main.collection.settings.images.fill_images.label",
      "default": true
    },
    {
      "id": "fill_not_first",
      "type": "checkbox",
      "label": "t:main.collection.settings.images.fill_not_first.label",
      "info": "t:main.collection.settings.images.fill_not_first.info"
    },
    {
      "type": "range",
      "id": "images_padding",
      "label": "t:main.collection.settings.images.images_padding.label",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "%",
      "default": 0
    },
    {
      "type": "range",
      "id": "images_vertical_position",
      "label": "t:main.collection.settings.images.images_vertical_position.label",
      "min": -100,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "label": "t:main.collection.settings.show_collection_image.label",
      "info": "t:main.collection.settings.show_collection_image.info"
    },
    {
      "type": "header",
      "content": "t:main.collection.settings.filters.header"
    },
    {
      "type": "checkbox",
      "id": "enable_filters",
      "label": "t:main.collection.settings.filters.enable_filters.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_menu",
      "label": "t:main.collection.settings.filters.enable_menu.label",
      "info": "t:main.collection.settings.filters.enable_menu.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_collections",
      "label": "t:main.collection.settings.filters.enable_collections.label",
      "default": true
    },
    {
      "type": "select",
      "id": "filters_menu_alignment",
      "label": "t:main.collection.settings.filters.filters_menu_alignment.label",
      "options": [
        {
          "value": "left",
          "label": "t:global.alignment.left.label"
        },
        {
          "value": "right",
          "label": "t:global.alignment.right.label"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "filters_layout",
      "label": "t:main.collection.settings.filters.filters_layout.label",
      "options": [
        {
          "value": "static",
          "label": "t:main.collection.settings.filters.filters_layout.options__1.label"
        },
        {
          "value": "drawer",
          "label": "t:main.collection.settings.filters.filters_layout.options__2.label"
        }
      ],
      "default": "static"
    },
    {
      "type": "checkbox",
      "id": "menu_below_filters",
      "label": "t:main.collection.settings.filters.menu_below_filters.label",
      "info": "t:main.collection.settings.filters.menu_below_filters.info",
      "default": false
    },
    {
      "type": "link_list",
      "id": "filter_menu",
      "label": "t:main.collection.settings.filters.filter_menu.label",
      "info": "t:main.collection.settings.filters.filter_menu.info",
      "default": "main-menu"
    },
    {
      "type": "collection_list",
      "id": "collections_menu",
      "label": "t:main.collection.settings.filters.collections_menu.label",
      "info": "t:main.collection.settings.filters.collections_menu.info"
    },
    {
      "type": "checkbox",
      "id": "filter_sticky",
      "label": "t:main.collection.settings.filters.filter_sticky.label",
      "default": true
    },
    {
      "id": "filters_show_more_limit",
      "type": "range",
      "label": "t:main.collection.settings.filters.filters_show_more_limit.label",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 7
    },
    {
      "type": "header",
      "content": "t:main.collection.settings.filter_swatches.header"
    },
    {
      "type": "paragraph",
      "content": "t:main.collection.settings.filter_swatches.paragraph"
    },
    {
      "type": "select",
      "id": "image_swatches_size",
      "label": "t:main.collection.settings.filter_swatches.image_swatches_size.label",
      "options": [
        {
          "value": "xs",
          "label": "t:main.collection.settings.filter_swatches.image_swatches_size.options__1.label"
        },
        {
          "value": "s",
          "label": "t:main.collection.settings.filter_swatches.image_swatches_size.options__2.label"
