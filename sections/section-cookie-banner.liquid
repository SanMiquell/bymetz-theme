{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{%- if section.settings.show_cookiebanner == 'banner' -%}
    <footer id="cookie-bar">
        <div id="cookie-inner">
            <i aria-hidden="true" class="icon-cookie"></i>
            {%- if section.settings.cookiebanner_text -%}{{ section.settings.cookiebanner_text }}{%- endif -%}
            <p class="link-btn">
                <a href="./" class="inline close cookie-decline">{{ 'cookiebanner.decline' | t }}</a>
                <a href="./" class="close cookie-accept{% if section.settings.button_style == 'inv' %} inv{% endif %}">{{ 'cookiebanner.accept' | t }}</a>
            </p>
        </div>
    </footer>
{%- elsif section.settings.show_cookiebanner == 'popup' -%}
    <article id="cookie" class="popup-a w690 box" data-title="cookies-popup" data-popup-delay="000">
        {%- if section.settings.cookiebanner_image -%}
            <figure class="aside">
                <picture>
                    <img
                            src="{{- section.settings.cookiebanner_image | image_url: width: 290, height: 268 -}}"
                            srcset="{{ section.settings.cookiebanner_image | image_url: width: 290, height: 268 }} 1x,{{ section.settings.cookiebanner_image | image_url: width: 580, height: 536 }} 2x"
                            width="290"
                            height="268"
                            alt="{{ section.settings.cookiebanner_image.alt | default: section.settings.cookiebanner_title | escape }}"
                            loading="lazy"
                    >
                </picture>
            </figure>
        {%- endif -%}
        {%- if section.settings.cookiebanner_title != empty -%}
            <header>
                <div class="title-styling
        {% if section.settings.cookiebanner_title_underline_style != 'none' %}
          title-underline-none
          {% if section.settings.cookiebanner_title_underline_style contains 'accent' %}
            title-underline-accent
          {% elsif section.settings.cookiebanner_title_underline_style contains 'gradient' %}
            title-underline-gradient
          {% endif %}
          {% if section.settings.cookiebanner_title_underline_style contains 'secondary_font' %}
            title-underline-secondary-font
          {% endif %}
        {% endif %}
      ">
                    {{ section.settings.cookiebanner_title }}
                </div>
            </header>
        {%- endif -%}
        {%- if section.settings.cookiebanner_text -%}{{ section.settings.cookiebanner_text }}{%- endif -%}
        <p class="link-btn">
            <a href="./" class="inline close cookie-decline">{{ 'cookiebanner.decline' | t }}</a>
            <a href="./" class="close cookie-accept{% if settings.button_style == 'inv' %} inv{% endif %}">{{ 'cookiebanner.accept' | t }}</a>
        </p>
    </article>
{%- endif -%}
{% schema %}
{
  "name": "t:settings_schema.cookies.name",
  "settings": [
    {
      "id": "show_cookiebanner",
      "type": "select",
      "label": "t:settings_schema.cookies.settings.show_cookiebanner.label",
      "info": "t:settings_schema.cookies.settings.show_cookiebanner.info",
      "options": [
        {
          "value": "banner",
          "label": "t:settings_schema.cookies.settings.show_cookiebanner.options__1.label"
        },
        {
          "value": "popup",
          "label": "t:settings_schema.cookies.settings.show_cookiebanner.options__2.label"
        }
      ],
      "default": "banner"
    },
    {
      "type": "image_picker",
      "id": "cookiebanner_image",
      "label": "t:settings_schema.cookies.settings.cookiebanner_image.label",
      "info": "t:settings_schema.cookies.settings.cookiebanner_image.info"
    },
    {
      "type": "header",
      "content": "t:settings_schema.cookies.settings.content.header"
    },
    {
      "type": "paragraph",
      "content": "t:settings_schema.cookies.settings.content.paragraph"
    },
    {
      "id": "cookiebanner_title",
      "type": "richtext",
      "label": "t:global.typography.title.label",
      "default": "<h2>Cookies</h2>"
    },
    {
      "type": "select",
      "id": "cookiebanner_title_underline_style",
      "label": "t:global.typography.title_underline_style.label",
      "options": [
        {
          "value": "none",
          "label": "t:global.typography.title_underline_style.none.label"
        },
        {
          "value": "secondary_font",
          "label": "t:global.typography.title_underline_style.secondary_font.label",
          "group": "t:global.typography.title_underline_style.group.fonts"
        },
        {
          "value": "secondary_font_accent",
          "label": "t:global.typography.title_underline_style.secondary_font_accent.label",
          "group": "t:global.typography.title_underline_style.group.fonts"
        },
        {
          "value": "secondary_font_gradient",
          "label": "t:global.typography.title_underline_style.secondary_font_gradient.label",
          "group": "t:global.typography.title_underline_style.group.fonts"
        },
        {
          "value": "accent",
          "label": "t:global.typography.title_underline_style.accent.label",
          "group": "t:global.typography.title_underline_style.group.colors"
        },
        {
          "value": "gradient",
          "label": "t:global.typography.title_underline_style.gradient.label",
          "group": "t:global.typography.title_underline_style.group.colors"
        }
      ]
    },
    {
      "id": "cookiebanner_text",
      "type": "richtext",
      "label": "t:settings_schema.cookies.settings.cookiebanner_text.label",
      "info": "t:settings_schema.cookies.settings.cookiebanner_text.info",
      "default": "<p>Our site uses cookies. By clicking on accept you agree with our <a href=\"/policies/terms-of-service\" target=\"_blank\" title=\"Terms of Service\">terms of service</a> and <a href=\"/policies/privacy-policy\" target=\"_blank\" title=\"Privacy Policy\">privacy policy</a>.</p>"
    }
  ]
}
{% endschema %}
