{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{% liquid
  assign custom_height_ratio = settings.custom_product_image_ratio | divided_by: 100.0
  assign image_width = 430
  assign image_height = image_width | times: custom_height_ratio | round
  assign image_width_2 = image_width | times: 1.5
  assign image_height_2 = image_height | times: 1.5

  assign show_price = true
  if settings.login_for_prices and customer == nil
    assign show_price = false
  endif

  if section.settings.products != empty
    assign product = section.settings.products | first
    assign form_class = 'l4ml-form list-only f8pr product-card s-bulk'
    if product.variants.size == 1
      assign form_class = form_class | append: ' form-card s-bulk'
    endif
    assign form_id = 'bulk-add-' | append: section.id | append: product.id
    assign current_variant = product.selected_or_first_available_variant

    assign custom_height_ratio = settings.custom_product_image_ratio | divided_by: 100.0
    assign image_width = 430
    assign image_height = image_width | times: custom_height_ratio
    assign image_width_small = image_width | divided_by: 3
    assign image_height_small = image_height | divided_by: 3

    assign total_stock = 0
    assign preorder = false
    for variant in product.variants
      if variant.matched and variant.inventory_quantity > 0
        assign total_stock = total_stock | plus: variant.inventory_quantity
      endif
    endfor
    if total_stock <= 0
      assign total_stock = current_variant.inventory_quantity
    endif
    if total_stock <= 0 and current_variant.inventory_management != nil and current_variant.inventory_policy == 'continue' and current_variant.available and current_variant.inventory_quantity <= 0 and settings.preorder
      assign preorder = true
    endif
  endif

  assign first_block = section.blocks | first

  assign width = 'calc(2 / 3 * 100%)'
  assign ratio = 1
  for block in section.blocks
    assign aspect_ratio = block.settings.height | split: '/'
    assign temp = aspect_ratio[0] | append: '.0'
    assign padding_bottom_avatar = aspect_ratio[1] | divided_by: temp | round: 2
    if padding_bottom_avatar > ratio
      assign ratio = padding_bottom_avatar
    endif
  endfor

  assign ref_img = section.settings.image
  if section.settings.height == 'adapt'
    assign padding_bottom = 1 | divided_by: ref_img.aspect_ratio | times: 100 | round: 2
  else
    assign aspect_ratio = section.settings.height | split: '/'
    assign temp = aspect_ratio[0] | append: '.0'
    assign ratio = aspect_ratio[1] | divided_by: temp | round: 2
    assign padding_bottom = ratio | times: 100 | round: 2
  endif


%}
<div class="
  m6as
  text-start
  {{ section.settings.width }}
  {% if section.settings.products.count <= 1 %}align-top{% endif %}
  {% if section.settings.layout == 'right' %}inv{% endif %}
  "
  style="
    --d: 16px;
    --w_f: {{ width }};
    --padding_bottom: {{ padding_bottom }};
  "
     {% if section.settings.enable_animations %}data-sal="fade" data-sal-duration="500"{% endif %}
  >
    <link href="{{ 'async-product-variants.css' | asset_url }}" rel="preload" as="style" onload="this.rel='stylesheet'">
    <noscript>
      <link rel="stylesheet" href="{{ 'async-product-variants.css' | asset_url }}">
    </noscript>
    <figure{% if section.settings.width == 'wide' %} class="mobile-wide"{% endif %}>
      <ul class="l4hs static {% if section.settings.products.count > 1 %}l4cl{% endif %} dont-move" {% if section.settings.products.count > 1 %}style="--dist_a: 0px;"{% endif %}>
        {%- if section.settings.products.count <= 1 -%}
          <li class="product-card {% if settings.productcards_text_alignment == 'left' %}text-start{% elsif settings.productcards_text_alignment == 'center' %}text-center{% elsif settings.productcards_text_alignment == 'right' %}text-end{% endif %}" style="--ratio:{{ custom_height_ratio }}; --horizontal: 10%; --vertical: 75%;">
            <div>
              {%- if section.settings.products != empty %}
                <figure class="{% if settings.fill_product_images %}cover {% endif %}{% if settings.multiply_product_images == 'multiply' %}img-multiply{% elsif settings.multiply_product_images == 'multiply-bg' %}img-multiply-bg{% endif %}">
                  {%- render 'product-labels', product: product, origin: 'productitem' -%}
                  <a href="{{ product.url }}">
                    <picture>
                      {% if current_variant.image %}
                        {% assign image = current_variant.image %}
                        <img
                          src="{%- if settings.fill_product_images -%}{{ image | image_url: width: image_width_2, height: image_height_2, crop: 'center' }}{%- else -%}{{ image | image_url: height: image_height_2 }}{%- endif -%}"
                          {%- if sizes -%}
                            srcset="
                              {%- if settings.fill_product_images -%}
                                {%- render 'image-srcset', image: image, format: 'custom', image_height: custom_height_ratio, max_width: 640, crop: 'center' -%}
                              {%- else -%}
                                {%- render 'image-srcset', image: image, max_width: 640 -%}
                              {%- endif -%}
                            "
                            sizes="{{ sizes }}"
                          {%- else -%}
                            srcset="
                              {%- if settings.fill_product_images -%}
                                {{ image | image_url: width: image_width, height: image_height, crop: 'center' }} 1x, {{ image | image_url: width: image_width_2, height: image_height_2, crop: 'center' }} 2x
                              {%- else -%}
                                {{ image | image_url: height: image_height }} 1x, {{ image | image_url: height: image_height_2 }} 2x
                              {%- endif -%}
                            "
                          {%- endif -%}
                          width="{{ image_width }}"
                          height="{{ image_height }}"
                          alt="{{ image.alt | default: product.title | escape }}"
                          loading="{% if section.index > 1 or forloop.first == false %}lazy{% else %}eager{% endif %}"
                          {% if settings.fill_product_images %}class="filled"{% endif %}
                        >
                      {% elsif product.featured_media %}
                        {% assign image = product.featured_media %}
                        <img
                          src="{%- if settings.fill_product_images -%}{{ image | image_url: width: image_width_2, height: image_height_2, crop: 'center' }}{%- else -%}{{ image | image_url: height: image_height_2 }}{%- endif -%}"
                          {%- if sizes -%}
                            srcset="
                            {%- if settings.fill_product_images -%}
                              {%- render 'image-srcset', image: image, format: 'custom', image_height: custom_height_ratio, max_width: 640, crop: 'center' -%}
                            {%- else -%}
                              {%- render 'image-srcset', image: image, max_width: 640 -%}
                            {%- endif -%}
                            "
                            sizes="{{ sizes }}"
                          {%- else -%}
                            srcset="
                              {%- if settings.fill_product_images -%}
                                {{ image | image_url: width: image_width, height: image_height, crop: 'center' }} 1x, {{ image | image_url: width: image_width_2, height: image_height_2, crop: 'center' }} 2x
                              {%- else -%}
                                {{ image | image_url: height: image_height }} 1x, {{ image | image_url: height: image_height_2 }} 2x
                              {%- endif -%}
                            "
                          {%- endif -%}
                          width="{{ image_width }}"
                          height="{{ image_height }}"
                          alt="{{ image.alt | default: product.title | escape }}"
                          loading="{% if section.index > 1 or forloop.first == false %}lazy{% else %}eager{% endif %}"
                          {% if settings.fill_product_images %}class="filled"{% endif %}
                        >
                      {% else %}
                        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      {% endif %}
                    </picture>
                  </a>
                </figure>
                <h3>{%- if product.vendor != "vendor-unknown" and product.vendor != shop.name and settings.show_vendor -%}<span class="small">{{ product.vendor }}</span> {% endif %}<a href="{{ current_variant.url }}" class="fw-{{ settings.product_heading_font_weight }} ff-{{ settings.product_heading_font }} text-{{ settings.product_heading_case }} fz-heading-productcard">{{ product.title }}</a></h3>
              {% else %}
                <figure>
                  <picture>
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  </picture>
                </figure>
                <h3>{% if settings.show_vendor %}<span class="small">Vendor name</span> {% endif %}<a href="./" class="fw-{{ settings.product_heading_font_weight }} ff-{{ settings.product_heading_font }} text-{{ settings.product_heading_case }} fz-heading-productcard">Product title</a></h3>
              {% endif %}
            </div>
          </li>
        {% else %}
          {% render 'product-item', product: product, extra_style: '--horizontal: 10%; --vertical: 75%; padding-inline: 0px!important; width: 100%;' %}
        {% endif %}
      </ul>
      <span class="palette-{{ section.settings.color_palette }} module-color-palette img-overlay" style="opacity:{{ section.settings.overlay_opacity_img | divided_by: 100.0 }}"></span>
      {%- if section.settings.image -%}
        {%- liquid
          if section.index > 1 and section.location != 'footer'
            assign lazyload = true
          endif
        -%}
        {% if section.settings.image_mobile %}
          <picture class="mobile-only">
            {% capture srcset %}
              {% render 'image-srcset', image: section.settings.image_mobile, max_width: 940 %}
            {% endcapture %}
            {% capture sizes %}
              (min-width: 768px) 0,
              100vw
            {% endcapture %}
            {% assign alt = section.settings.image_mobile.alt | default: section.settings.title | escape %}
            {%- if lazyload -%}
              {{ section.settings.image_mobile | image_url: width: 700, height: 530, crop: 'center' | image_tag: srcset: srcset, sizes: sizes, loading: 'lazy', alt: alt }}
            {%- else -%}
              {{ section.settings.image_mobile | image_url: width: 700, height: 530, crop: 'center' | image_tag: srcset: srcset, sizes: sizes, preload: true, alt: alt }}
            {%- endif -%}
          </picture>
        {% endif %}
        <picture {% if section.settings.image_mobile %}class="mobile-hide"{% endif %}>
          {% capture srcset %}
            {% render 'image-srcset', image: section.settings.image, max_width: 2900 %}
          {% endcapture %}
          {% capture sizes %}
            (min-width: 1000px){% if section.settings.width == 'boxed' or settings.width < 2000 %}calc({{ settings.width }}px / 2),{% else %}calc(100vw / 2),{% endif %}
            {% if section.settings.image_mobile %}0{% else %}100vw{% endif %}
          {% endcapture %}
          {% assign alt = section.settings.image.alt | default: section.settings.title | escape %}
          {%- if lazyload -%}
            {{ section.settings.image | image_url: width: 700, height: 530, crop: 'center' | image_tag: srcset: srcset, sizes: sizes, loading: 'lazy', alt: alt }}
          {%- else -%}
            {{ section.settings.image | image_url: width: 700, height: 530, crop: 'center' | image_tag: srcset: srcset, sizes: sizes, preload: true, alt: alt }}
          {%- endif -%}
        </picture>
      {% else %}
        <picture>
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </picture>
      {% endif %}
    </figure>
    <div {% if section.settings.products.count > 1 %}style="justify-content: start"{% endif %}>
      <div class="l4ml-form">
        {%- if section.settings.products != empty and section.settings.products != blank and section.settings.products.count == 1 %}
          {%- form 'product', product, id: form_id, class: form_class, autocomplete: "off" -%}
            <fieldset>
              <legend>{{ section.settings.bulk_title }}</legend>
              <{{ section.settings.title_size }} class="mob-{{ section.settings.mobile_title_size }}"><a href="{{ current_variant.url }}">{{ product.title }}</a></{{ section.settings.title_size }}>
              {%- if product.variants.size == 1 -%}
                {%- render 'product-deliverytime',
                  product: product,
                  current_variant: current_variant,
                  container: "span",
                  origin: 'productitem',
                  extra_class: 'size-12'
                -%}
              {%- else -%}
                <p class="s1hd m15">{{ section.settings.bulk_title }}</p> 
                <ul class="l4ml">
                  {% assign limitVariants = 3 %}
                  {%- for variant in product.variants -%}
                  <li class="{% unless show_price %}disabled {% endunless %}{% if forloop.index > limitVariants %}hidden{% endif %}">
                    {%- if variant.image and section.settings.bulk_show_variant_images -%}
                      <figure>
                        <picture><img src="{% if settings.fill_product_images %}{{ variant.image | image_url: width: image_width_small, height: image_height_small, crop: 'center' }}{% else %}{{ variant.image | image_url: height: image_height_small }}{% endif %}" alt="{{ variant.title }}" width="50" height="55" loading="lazy" {% if settings.fill_product_images %}class="filled"{% endif %}></picture>
                      </figure>
                    {%- endif -%}
                    <span>
                      <span {% if section.settings.bulk_shorten_title %}class="s1nw"{% endif %}><a href="{{ variant.url }}">{{ variant.title }}</a></span>
                      {%- liquid
                        if section.settings.show_deliverytime
                          assign hide_deliverytime = false
                        else
                          assign hide_deliverytime = true
                        endif
                      -%}
                      {%- render 'product-deliverytime',
                          product: variant,
                          current_variant: variant,
                          container: "span",
                          origin: 'productitem',
                          extra_class: 'size-12',
                          extra_element: '<br>',
                          hide_deliverytime: hide_deliverytime
                      -%}
                      <br class="mobile-only">
                      {% comment %} <span class="s1pr mobile-only">{% if variant.compare_at_price > variant.price and show_price %}<span class="old-price">{{ variant.compare_at_price | money }}</span> {% endif %}{% if show_price %}{{ variant.price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}</span> {% endcomment %}
                      {% render 'price', product: variant.product, variant: variant, price: variant.compare_at_price, origin: 'bulk', extraClass: 'mobile-only' %}
                    </span>
                    {% comment %} <span class="s1pr mobile-hide">{% if variant.compare_at_price > variant.price and show_price %}<span class="old-price">{{ variant.compare_at_price | money }}</span> {% endif %}{% if show_price %}{{ variant.price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}</span> {% endcomment %}
                    {% render 'price', product: variant.product, variant: variant, price: variant.compare_at_price, origin: 'bulk', break: true, extraClass: 'mobile-hide' %}
                    <span class="input-amount {% if settings.qty_input_controls == 'enable' %}strong{% else %}no-arrows{% endif %}">
                      <label for="ml-{{ section.id }}-{{ variant.id }}" class="hidden">{{ 'product.form.quantity' | t }}</label>
                      <input type="number" id="ml-{{ section.id }}-{{ variant.id }}" name="ml-{{ section.id }}-{{ variant.id }}" placeholder="0"
                      min="{% if variant.quantity_rule.min > 1 %}{{ variant.quantity_rule.min }}{% elsif product.variants.size == 1 %}1{% else %}0{% endif %}"
                      {% if variant.inventory_management == 'shopify' and variant.inventory_policy == 'deny' -%}
                         max="{{ variant.inventory_quantity }}"
                      {% elsif variant.quantity_rule.max %}
                         max="{{ variant.quantity_rule.max }}"
                      {% endif %}
                      step="{{ variant.quantity_rule.increment }}" required{% if variant.available == false %} disabled{% endif %} data-id="{{ variant.id }}" data-price="{{ variant.price }}">
                    </span>
                  </li>
                  {%- endfor -%}
                  {% if product.variants.size > limitVariants %}
                    <li class="link-more"><a href="./" class="link-more strong inline"><span class="link-underline">{{ 'general.read_more.show' | t }} <span>{{ 'general.read_more.all' | t }}</span> <span class="hidden">{{ 'general.read_more.less' | t }}</span> {{ 'general.read_more.variants' | t }}</span></a></li>
                  {% endif %}
                </ul>
              {%- endif -%}
              {%- if show_price -%}
                {%- if product.variants.size == 1 -%}
                  <p class="submit margin-0 nowrap">
                    <span class="margin-10">
                      {% render 'price', product: current_variant.product, variant: current_variant, price: current_variant.compare_at_price, origin: 'bulk' %}
                    {% if settings.productcards_show_tax -%}<span data-syncer-vat-incl class="size-small font-regular">{{ 'product.including_tax' | t }}</span><span data-syncer-vat-excl class="size-12 font-regular">{{ 'product.excluding_tax' | t }}</span>{%- endif -%}
                    </span>
                  </p>
                {%- endif -%}
                <div class="submit nowrap" style="--btn_dist: clamp(16px, 4vw, 40px);">
                  {%- if product.variants.size == 1 -%}
                    <input name="id" value="{{ current_variant.id }}" type="hidden">
                    {% if product.variants.size > 1 %}<span class="margin-0">{% render 'price', product: current_variant.product, variant: current_variant, price: current_variant.compare_at_price, origin: 'bulk' %}</span>{% endif %}
                    {%- if current_variant.available -%}
                      <span class="margin-0 input-amount {% if settings.qty_input_controls == 'enable' %}strong{% else %}no-arrows{% endif %}">
                          <label for="quantity-{{ form_id }}-id" class="hidden">{{ 'product.form.quantity' | t }}</label>
                          <input type="number" id="quantity-{{ form_id }}-id" name="quantity" value="{{ current_variant.quantity_rule.min }}"
                            min="{{ current_variant.quantity_rule.min }}"
                            {% if current_variant.inventory_management == 'shopify' and current_variant.inventory_policy == 'deny' -%}
                              max="{{ current_variant.inventory_quantity }}"
                            {% elsif current_variant.quantity_rule.max %}
                              max="{{ current_variant.quantity_rule.max }}"
                            {% endif %}
                            {% if current_variant.quantity_rule.increment %}step="{{ current_variant.quantity_rule.increment }}"{% endif %}
                            required
                          >
                      </span>
                    {%- endif -%}
                  {%- else -%}
                    <span class="margin-0">
                      {% render 'price', product: section.settings.product, origin: 'bulk-subtotal' %}
                      {% if settings.productcards_show_tax -%}<span data-syncer-vat-incl class="size-small font-regular">{{ 'product.including_tax' | t }}</span><span data-syncer-vat-excl class="size-12 font-regular">{{ 'product.excluding_tax' | t }}</span>{%- endif -%}
                    </span>              
                  {%- endif -%}
                  {%- if current_variant.available -%}
                    <button type="submit" class="wide {% if preorder %}overlay-preorder{% else %}overlay-buy_button{% endif %}{% if settings.button_style == 'inv' %} inv{% endif %} {% if product.variants.size > 1 %} disabled{% endif %} margin-0">{% if preorder %}{{ settings.preorder_button_text }}{% else %}{{ 'product.form.add_to_cart' | t }}{% endif %}</button>
                  {%- else -%}
                    <button type="submit" class="wide visible overlay-unavailable_buy_button{% if settings.button_style == 'inv' %} inv{% endif %} disabled margin-0">{{ 'product.form.not_in_stock' | t }}</button>
                  {%- endif -%}
                </div>
              {%- else -%}
                <p class="link-btn m10">
                  <a href="{{ routes.account_login_url }}" class="wide overlay-buy_button{% if settings.buy_button_style == 'inv' %} inv{% endif %}">{{ 'customer.login.login_for_prices_html' | t }}</a>
                </p>
              {%- endif -%}
            </fieldset>
          {%- endform -%}
        {%- elsif section.settings.products.count > 1 -%}
          <ul class="l4cl hr">
            {%- liquid
              for product in section.settings.products 
                if forloop.index > 1
                capture placeholder_int
                  cycle 1, 2, 3
                endcapture
                render 'product-item', product: product, placeholder_int: placeholder_int, layout: 'list'
                endif
              endfor
            -%}
          </ul>
        {%- else -%}
        <fieldset class="f8pr">
          <legend>{{ 'product.form.multiple_variants' | t }}</legend>
          <{{ section.settings.title_size }} class="mob-{{ section.settings.mobile_title_size }}">Product title</{{ section.settings.title_size }}>
          {%- if show_price -%}
              {%- if block.settings.product.variants.size == 1 -%}
                <p class="submit margin-0 mobile-only">
                  <span class="margin-5"><span class="size-16 strong bulk-price">{% if current_variant.compare_at_price > current_variant.price and show_price %}<span class="old-price">{{ current_variant.compare_at_price | money }}</span> {% endif %}{% if show_price %}{{ current_variant.price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}</span></span>
              </p>
              {%- endif -%}
            <p class="submit m5" style="--btn_dist: clamp(16px, 4vw, 40px);">
              {%- if block.settings.product.variants.size == 1 -%}
                <input name="id" value="{{ current_variant.id }}" type="hidden">
                <span {% if block.settings.product.variants.size == 1 %}class="mobile-hide"{% endif %}><span class="size-16 strong bulk-price">{% if current_variant.compare_at_price > current_variant.price and show_price %}<span class="old-price">{{ current_variant.compare_at_price | money }}</span> {% endif %}{% if show_price %}{{ current_variant.price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}</span></span>
                <span class="margin-0 input-amount {% if settings.qty_input_controls == 'enable' %}strong{% else %}no-arrows{% endif %} in-popup">
                    <label for="quantity-{{ form_id }}-id" class="hidden">{{ 'product.form.quantity' | t }}</label>
                    <input type="number" id="quantity-{{ form_id }}-id" name="quantity" value="{{ current_variant.quantity_rule.min }}"
                      min="{{ current_variant.quantity_rule.min }}"
                      {% if current_variant.inventory_management == 'shopify' and current_variant.inventory_policy == 'deny' -%}
                        max="{{ current_variant.inventory_quantity }}"
                      {% elsif current_variant.quantity_rule.max %}
                        max="{{ current_variant.quantity_rule.max }}"
                      {% endif %}
                      {% if current_variant.quantity_rule.increment %}step="{{ current_variant.quantity_rule.increment }}"{% endif %}
                      required
                    >
                </span>
              {%- else -%}
                <span>{{ 'cart.subtotal' | t }} <span class="s1bx rounded inline font-regular bulk-qty">0</span><br> <span class="size-16 strong bulk-price">{{ '0' | money }}</span></span>
              {%- endif -%}
                <button type="submit" class="wide visible overlay-unavailable_buy_button{% if settings.button_style == 'inv' %} inv{% endif %} disabled">{{ 'product.form.not_in_stock' | t }}</button>
            </p>
          {%- else -%}
            <p class="link-btn m10">
              <a href="{{ routes.account_login_url }}" class="wide overlay-buy_button{% if settings.buy_button_style == 'inv' %} inv{% endif %}">{{ 'customer.login.login_for_prices_html' | t }}</a>
            </p>
          {%- endif -%}
        </fieldset>
        {% endif %}
      </div>
    </div>
</div>

<style>
  #shopify-section-{{ section.id }} .m6as { margin-bottom: {{ section.settings.spacing_desktop }}px }
  #shopify-section-{{ section.id }} { z-index: {{ section.settings.fix_zindex }}!important; }
  #shopify-section-{{ section.id }} .l4cl:not(.list) li>div:last-child { flex-grow: 0!important; }
  @media only screen and (min-width: 47.5em) {
    #shopify-section-{{ section.id }} .m6as > figure {
      min-height: calc(var(--mih) + var(--main_mr));
    }
    {% if section.settings.enable_custom_font_styling %}
      #shopify-section-{{ section.id }} article { font-size:{{ section.settings.font_size }}; }
    {% endif %}
    {% if section.settings.spacing_desktop < 0 %}
      #shopify-section-{{ section.id }} + *.has-kinetic-text { pointer-events: none; }
    {% endif %}
  }
  @media only screen and (max-width: 47.5em) {
    #shopify-section-{{ section.id }} .m6as { margin-bottom: {{ section.settings.spacing_mobile }}px; }
    {% if section.settings.spacing_mobile < 0 %}
      #shopify-section-{{ section.id }} + *.has-kinetic-text { pointer-events: none; }
    {% endif %}
    #shopify-section-{{ section.id }} .m6cu.size-xs-mobile, #shopify-section-{{ section.id }} .m6as.size-xs-mobile > figure { min-height: 170px; }
    #shopify-section-{{ section.id }} .m6cu.size-s-mobile, #shopify-section-{{ section.id }} .m6as.size-s-mobile > figure { min-height: 260px; }
    #shopify-section-{{ section.id }} .m6cu.size-m-mobile, #shopify-section-{{ section.id }} .m6as.size-m-mobile > figure { min-height: 390px; }
    #shopify-section-{{ section.id }} .m6cu.size-l-mobile, #shopify-section-{{ section.id }} .m6as.size-l-mobile > figure { min-height: 520px; }
    #shopify-section-{{ section.id }} .m6cu.size-xl-mobile, #shopify-section-{{ section.id }} .m6as.size-xl-mobile > figure { min-height: 700px; }
    #shopify-section-{{ section.id }} .m6as > div {
      padding: 0 0 0 var(--d)!important;
    }
  }
  #shopify-section-{{ section.id }} .m6as {
    margin-left: calc(0px - var(--d));
  }
  #shopify-section-{{ section.id }} .m6as > figure {
    border-left: var(--d) solid transparent;
  }
