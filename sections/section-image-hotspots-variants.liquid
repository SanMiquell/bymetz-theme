{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{% liquid
  assign show_price = true
  if settings.login_for_prices and customer == nil
    assign show_price = false
  endif

  assign ref_img = section.settings.image
  if section.settings.enable_custom_height
    assign padding_bottom = 0
  else
    if section.settings.height == 'adapt' and ref_img
      assign padding_bottom = 1 | divided_by: ref_img.aspect_ratio | times: 100 | round: 2
    else
      if section.settings.height == 'adapt'
        assign aspect_ratio = '16/9' | split: '/'
      else
        assign aspect_ratio = section.settings.height | split: '/'
      endif
      assign temp = aspect_ratio[0] | append: '.0'
      assign ratio = aspect_ratio[1] | divided_by: temp | round: 2
      assign padding_bottom = ratio | times: 100 | round: 2
    endif
  endif

  if section.settings.height_mobile == 'adapt' and ref_img
    if section.settings.image_mobile
      assign ref_img = section.settings.image_mobile
    endif
    assign padding_bottom_mobile = 1 | divided_by: ref_img.aspect_ratio | times: 100 | round: 2
  else
    if section.settings.height_mobile == 'adapt'
      assign aspect_ratio = '16/9' | split: '/'
    else
      assign aspect_ratio = section.settings.height_mobile | split: '/'
    endif
    assign temp = aspect_ratio[0] | append: '.0'
    assign ratio = aspect_ratio[1] | divided_by: temp | round: 2
    assign padding_bottom_mobile = ratio | times: 100 | round: 2
  endif
  assign width = 'calc(2 / 3 * 100%)'
%}
<div class="
  m6as
  text-start
  {{ section.settings.width }}
  align-top
  compact-img
  {% if section.settings.layout == 'right' %}inv{% endif %}
  "
  style="
    --d: 16px;
    --w_f: {{ width }};;
    --padding_bottom: {{ padding_bottom }};
    --padding_bottom_mobile: {{ padding_bottom_mobile }};
  "
 {% if section.settings.enable_animations %}data-sal="fade" data-sal-duration="500"{% endif %}
  >
    <figure>
      {%- if section.settings.image -%}
        {%- liquid
          if section.index > 1 and section.location != 'footer'
            assign lazyload = true
          endif
        -%}
        {% if section.settings.image_mobile %}
          <picture class="mobile-only">
            {% capture srcset %}
              {% render 'image-srcset', image: section.settings.image_mobile, max_width: 940 %}
            {% endcapture %}
            {% capture sizes %}
              (min-width: 768px) 0,
              100vw
            {% endcapture %}
            {% assign alt = section.settings.image_mobile.alt | default: section.settings.title | escape %}
            {%- if lazyload -%}
              {{ section.settings.image_mobile | image_url: width: 700, height: 530, crop: 'center' | image_tag: srcset: srcset, sizes: sizes, loading: 'lazy', alt: alt }}
            {%- else -%}
              {{ section.settings.image_mobile | image_url: width: 700, height: 530, crop: 'center' | image_tag: srcset: srcset, sizes: sizes, preload: true, alt: alt }}
            {%- endif -%}
          </picture>
        {% endif %}
        <picture {% if section.settings.image_mobile %}class="mobile-hide"{% endif %}>
          {% capture srcset %}
            {% render 'image-srcset', image: section.settings.image, max_width: 2900 %}
          {% endcapture %}
          {% capture sizes %}
            (min-width: 1000px){% if section.settings.width == 'boxed' or settings.width < 2000 %}calc({{ settings.width }}px / 2),{% else %}calc(100vw / 2),{% endif %}
            {% if section.settings.image_mobile %}0{% else %}100vw{% endif %}
          {% endcapture %}
          {% assign alt = section.settings.image.alt | default: section.settings.title | escape %}
          {%- if lazyload -%}
            {{ section.settings.image | image_url: width: 700, height: 530, crop: 'center' | image_tag: srcset: srcset, sizes: sizes, loading: 'lazy', alt: alt }}
          {%- else -%}
            {{ section.settings.image | image_url: width: 700, height: 530, crop: 'center' | image_tag: srcset: srcset, sizes: sizes, preload: true, alt: alt }}
          {%- endif -%}
        </picture>
      {% else %}
        <picture>
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </picture>
      {% endif %}
      <ul class="l4hs dots tabbed with-variants">
        {%- for block in section.blocks -%}
            <li style="
                --horizontal: {{ block.settings.position_left }}%;
                --vertical: {{ block.settings.position_top }}%;
                --horizontal_mobile: {{ block.settings.position_left_mobile }}%;
                --vertical_mobile: {{ block.settings.position_top_mobile }}%;
                "
                class="{% if forloop.index == 1 %}toggle{% endif %}"
            {{ block.shopify_attributes }}>
                <a class="toggle" data-hotspot-variants="hotspot-variants-{{ section.id }}-{{ block.id }}">{{ 'general.read_more.read_more' | t }}</a>
            </li>
        {%- endfor -%}
      </ul>
    </figure>
    <div>
      <link href="{{ 'async-product-variants.css' | asset_url }}" rel="preload" as="style" onload="this.rel='stylesheet'">
      <noscript>
        <link rel="stylesheet" href="{{ 'async-product-variants.css' | asset_url }}">
      </noscript>
      {%- for block in section.blocks -%}
        <div id="hotspot-variants-{{ section.id }}-{{ block.id }}" {% if forloop.index > 1 %}class="hidden"{% endif %}>
        {%- if block.settings.product != empty and block.settings.product != blank %}
          {% liquid
            assign form_class = 'l4ml-form list-only f8pr product-card s-bulk'
            if block.settings.product.variants.size == 1
              assign form_class = form_class | append: ' form-card'
            endif
            assign form_id = 'bulk-add-' | append: section.id | append: product.id
            assign current_variant = block.settings.product.selected_or_first_available_variant
            
            assign custom_height_ratio = settings.custom_product_image_ratio | divided_by: 100.0
            assign image_width = 430
            assign image_height = image_width | times: custom_height_ratio
            assign image_width_small = image_width | divided_by: 3
            assign image_height_small = image_height | divided_by: 3

            assign total_stock = 0
            assign preorder = false
            for variant in block.settings.product.variants
              if variant.matched and variant.inventory_quantity > 0
                assign total_stock = total_stock | plus: variant.inventory_quantity
              endif
            endfor
            if total_stock <= 0
              assign total_stock = current_variant.inventory_quantity
            endif
            if total_stock <= 0 and current_variant.inventory_management != nil and current_variant.inventory_policy == 'continue' and current_variant.available and current_variant.inventory_quantity <= 0 and settings.preorder
              assign preorder = true
            endif
            assign deliverytime_extra_class = 'size-' | append: settings.product_delivery_size | append: ' mobile-size-' | append: settings.product_delivery_size_mobile
          -%}
          {%- form 'product', block.settings.product, id: form_id, class: form_class, autocomplete: "off" -%}
            <fieldset>
              <legend>{{ section.settings.bulk_title }}</legend>
              <{{ section.settings.title_size }} class="mob-{{ section.settings.mobile_title_size }}"><a href="{{ current_variant.url }}">{{ block.settings.product.title }}</a></{{ section.settings.title_size }}>
              {%- if block.settings.product.variants.size == 1 -%}

                {%- render 'product-deliverytime',
                        product: product,
                        current_variant: current_variant,
                        container: "p",
                        origin: 'productitem',
                        no_margin: true,
                        extra_class: deliverytime_extra_class
                -%}

              {%- else -%}
                <p class="s1hd m15">{{ section.settings.bulk_title }}</p> 
                <ul class="l4ml">
                  {% assign limit_variants = 3 %}
                  {%- for variant in block.settings.product.variants -%}
                  <li class="{% unless show_price %}disabled {% endunless %}{% if forloop.index > limit_variants %}hidden{% endif %}">
                    {%- if variant.image and section.settings.bulk_show_variant_images -%}
                      <figure>
                        <picture><img src="{% if settings.fill_product_images %}{{ variant.image | image_url: width: image_width_small, height: image_height_small, crop: 'center' }}{% else %}{{ variant.image | image_url: height: image_height_small }}{% endif %}" alt="{{ variant.title }}" width="50" height="55" loading="lazy" {% if settings.fill_product_images %}class="filled"{% endif %}></picture>
                      </figure>
                    {%- endif -%}
                    <span>
                      <span {% if section.settings.bulk_shorten_title %}class="s1nw"{% endif %}><a href="{{ variant.url }}">{{ variant.title }}</a></span>
                      {%- liquid
                        if section.settings.show_deliverytime
                          assign hide_deliverytime = false
                        else
                          assign hide_deliverytime = true
                        endif
                      -%}
                      {%- render 'product-deliverytime',
                          product: variant,
                          current_variant: variant,
                          container: "span",
                          origin: 'productitem',
                          extra_class: deliverytime_extra_class,
                          extra_element: '<br>',
                          hide_deliverytime: hide_deliverytime
                      -%}
                      {% unless section.settings.bulk_shorten_title %}<br class="mobile-only">{% endunless %}
                      {% comment %} <span class="s1pr mobile-only">{% if variant.compare_at_price > variant.price and show_price %}<span class="old-price">{{ variant.compare_at_price | money }}</span> {% endif %}{% if show_price %}{{ variant.price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}</span> {% endcomment %}
                      {% render 'price', product: variant.product, variant: variant, price: variant.compare_at_price, origin: 'bulk', extraClass: 'mobile-only' %}

                    </span>
                    {% comment %} <span class="s1pr mobile-hide">{% if variant.compare_at_price > variant.price and show_price %}<span class="old-price">{{ variant.compare_at_price | money }}</span> {% endif %}{% if show_price %}{{ variant.price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}</span> {% endcomment %}
                    {% render 'price', product: variant.product, variant: variant, price: variant.compare_at_price, origin: 'bulk', break: true, extraClass: 'mobile-hide' %}
                    <span class="input-amount {% if settings.qty_input_controls == 'enable' %}strong{% else %}no-arrows{% endif %}">
                      <label for="ml-{{ section.id }}-{{ block.id }}-{{ variant.id }}" class="hidden">{{ 'product.form.quantity' | t }}</label>
                      <input type="number" id="ml-{{ section.id }}-{{ block.id }}-{{ variant.id }}" name="ml-{{ section.id }}-{{ block.id }}-{{ variant.id }}" placeholder="0"
                      min="{% if variant.quantity_rule.min > 1 %}{{ variant.quantity_rule.min }}{% elsif block.settings.product.variants.size == 1 %}1{% else %}0{% endif %}"
                      {% if variant.inventory_management == 'shopify' and variant.inventory_policy == 'deny' -%}
                         max="{{ variant.inventory_quantity }}"
                      {% elsif variant.quantity_rule.max %}
                         max="{{ variant.quantity_rule.max }}"
                      {% endif %}
                      step="{{ variant.quantity_rule.increment }}" required{% if variant.available == false %} disabled{% endif %} data-id="{{ variant.id }}" {% render 'price', product: variant.product, variant: variant, price: variant.price, origin: 'bulk-input' %} data-price="{{ variant.price }}">
                    </span>
                  </li>
                  {%- endfor -%}
                  {% if block.settings.product.variants.size > limit_variants %}
                    <li class="link-more"><a href="./" class="link-more strong inline"><span class="link-underline">{{ 'general.read_more.show' | t }} <span>{{ 'general.read_more.all' | t }}</span> <span class="hidden">{{ 'general.read_more.less' | t }}</span> {{ 'general.read_more.variants' | t }}</span></a></li>
                  {% endif %}
                </ul>
              {%- endif -%}
              {%- if show_price -%}
                  {%- if block.settings.product.variants.size == 1 -%}
                    <p class="submit margin-0 nowrap">
                      <span class="margin-10">
                        {% render 'price', product: current_variant.product, variant: current_variant, price: current_variant.compare_at_price, origin: 'bulk' %}
                      {% if settings.productcards_show_tax -%}<span data-syncer-vat-incl class="size-small font-regular">{{ 'product.including_tax' | t }}</span><span data-syncer-vat-excl class="size-12 font-regular">{{ 'product.excluding_tax' | t }}</span>{%- endif -%}
                      </span>
                    </p>
                  {%- endif -%}
                <div class="submit nowrap" style="--btn_dist: clamp(16px, 4vw, 40px);">
                  {%- if block.settings.product.variants.size == 1 -%}
                    <input name="id" value="{{ current_variant.id }}" type="hidden">
                    {% if block.settings.product.variants.size > 1 %}<span class="margin-0">{% render 'price', product: current_variant.product, variant: current_variant, price: current_variant.compare_at_price, origin: 'bulk' %}</span>{% endif %}
                    {%- if current_variant.available -%}
                      <span class="margin-0 input-amount {% if settings.qty_input_controls == 'enable' %}strong{% else %}no-arrows{% endif %}">
                          <label for="quantity-{{ form_id }}-id" class="hidden">{{ 'product.form.quantity' | t }}</label>
                          <input type="number" id="quantity-{{ form_id }}-id" name="quantity" value="{{ current_variant.quantity_rule.min }}"
                            min="{{ current_variant.quantity_rule.min }}"
                            {% if current_variant.inventory_management == 'shopify' and current_variant.inventory_policy == 'deny' -%}
                              max="{{ current_variant.inventory_quantity }}"
                            {% elsif current_variant.quantity_rule.max %}
                              max="{{ current_variant.quantity_rule.max }}"
                            {% endif %}
                            {% if current_variant.quantity_rule.increment %}step="{{ current_variant.quantity_rule.increment }}"{% endif %}
                            required
                          >
                      </span>
                    {%- endif -%}
                  {%- else -%}
                    <span class="margin-0">
                      {% render 'price', product: block.settings.product, origin: 'bulk-subtotal' %}
                      {% if settings.productcards_show_tax -%}<span data-syncer-vat-incl class="size-small font-regular">{{ 'product.including_tax' | t }}</span><span data-syncer-vat-excl class="size-12 font-regular">{{ 'product.excluding_tax' | t }}</span>{%- endif -%}
                    </span>
                  {%- endif -%}
                  {%- if current_variant.available -%}
                    <button type="submit" class="wide {% if preorder %}overlay-preorder{% else %}overlay-buy_button{% endif %}{% if settings.button_style == 'inv' %} inv{% endif %} {% if block.settings.product.variants.size > 1 %} disabled{% endif %} margin-0">{% if preorder %}{{ settings.preorder_button_text }}{% else %}{{ 'product.form.add_to_cart' | t }}{% endif %}</button>
                  {%- else -%}
                    <button type="submit" class="wide visible overlay-unavailable_buy_button{% if settings.button_style == 'inv' %} inv{% endif %} disabled margin-0">{{ 'product.form.not_in_stock' | t }}</button>
                  {%- endif -%}
                </div>
              {%- else -%}
                <p class="link-btn m10">
                  <a href="{{ routes.account_login_url }}" class="wide overlay-buy_button{% if settings.buy_button_style == 'inv' %} inv{% endif %}">{{ 'customer.login.login_for_prices_html' | t }}</a>
                </p>
              {%- endif -%}
            </fieldset>
          {%- endform -%}
        {%- else -%}
          <fieldset class="f8pr product-card">
            <legend>{{ 'product.form.multiple_variants' | t }}</legend>
            <{{ section.settings.title_size }} class="mob-{{ section.settings.mobile_title_size }}">Product title</{{ section.settings.title_size }}>
            {%- if show_price -%}
                {%- if block.settings.product.variants.size == 1 -%}
                  <p class="submit margin-0 mobile-only">
                    <span class="margin-5"><span class="s1pr strong bulk-price">{% if current_variant.compare_at_price > current_variant.price and show_price %}<span class="old-price">{{ current_variant.compare_at_price | money }}</span> {% endif %}{% if show_price %}{{ current_variant.price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}</span></span>
                </p>
                {%- endif -%}
              <p class="submit m5" style="--btn_dist: clamp(16px, 4vw, 40px);">
                {%- if block.settings.product.variants.size == 1 -%}
                  <input name="id" value="{{ current_variant.id }}" type="hidden">
                  <span {% if block.settings.product.variants.size == 1 %}class="mobile-hide"{% endif %}><span class="s1pr strong bulk-price">{% if current_variant.compare_at_price > current_variant.price and show_price %}<span class="old-price">{{ current_variant.compare_at_price | money }}</span> {% endif %}{% if show_price %}{{ current_variant.price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}</span></span>
                  <span class="margin-0 input-amount {% if settings.qty_input_controls == 'enable' %}strong{% else %}no-arrows{% endif %} in-popup">
                      <label for="quantity-{{ form_id }}-id" class="hidden">{{ 'product.form.quantity' | t }}</label>
                      <input type="number" id="quantity-{{ form_id }}-id" name="quantity" value="{{ current_variant.quantity_rule.min }}"
                        min="{{ current_variant.quantity_rule.min }}"
                        {% if current_variant.inventory_management == 'shopify' and current_variant.inventory_policy == 'deny' -%}
                          max="{{ current_variant.inventory_quantity }}"
                        {% elsif current_variant.quantity_rule.max %}
                          max="{{ current_variant.quantity_rule.max }}"
                        {% endif %}
                        {% if current_variant.quantity_rule.increment %}step="{{ current_variant.quantity_rule.increment }}"{% endif %}
                        required
                      >
                  </span>
                {%- else -%}
                  <span>{{ 'cart.subtotal' | t }} <span class="s1bx rounded inline font-regular bulk-qty">0</span><br> <span class="s1pr strong bulk-price">{{ '0' | money }}</span></span>
                {%- endif -%}
                  <button type="submit" class="wide visible overlay-unavailable_buy_button{% if settings.button_style == 'inv' %} inv{% endif %} disabled">{{ 'product.form.not_in_stock' | t }}</button>
              </p>
            {%- else -%}
              <p class="link-btn m10" {{ block.shopify_attributes }}>
                <a href="{{ routes.account_login_url }}" class="wide overlay-buy_button{% if settings.buy_button_style == 'inv' %} inv{% endif %}">{{ 'customer.login.login_for_prices_html' | t }}</a>
              </p>
            {%- endif -%}
          </fieldset>
        {% endif %}
      </div>
      {%- endfor -%}
    </div>
</div>

<style>
  #shopify-section-{{ section.id }} .l4hs { --bg: var(--{{ section.settings.hotspot_color_palette }}_bg_btn); --fg: var(--{{ section.settings.hotspot_color_palette }}_btn_text); --bg_active: var(--bg); --fg_active: var(--fg); --hs_size: {{ section.settings.hotspot_height }}px; }
  #shopify-section-{{ section.id }} .m6as { margin-bottom: {{ section.settings.spacing_desktop }}px  }
  #shopify-section-{{ section.id }} { z-index: {{ section.settings.fix_zindex }}!important; }
  {% comment %} #shopify-section-{{ section.id }} .l4hs > li.toggle { pointer-events: none; } {% endcomment %}
  @media only screen and (min-width: 47.5em) {
    {% if section.settings.enable_custom_height %}
      #shopify-section-{{ section.id }} .m6as { --mih: {{ section.settings.custom_height }}px; }
    {% endif %}
    #shopify-section-{{ section.id }} .m6as > figure {
      min-height: calc(var(--mih) + var(--main_mr));
    }
    {% if section.settings.enable_custom_height %}
      #shopify-section-{{ section.id }} .m6fr article {
        min-height: {{ section.settings.custom_height }}px;
      }
    {% endif %}
    {% if section.settings.spacing_desktop < 0 %}
      #shopify-section-{{ section.id }} + *.has-kinetic-text { pointer-events: none; }
    {% endif %}
  }
  @media only screen and (max-width: 47.5em) {
    #shopify-section-{{ section.id }} .m6as { margin-bottom: {{ section.settings.spacing_mobile }}px; }
    {% if section.settings.spacing_mobile < 0 %}
      #shopify-section-{{ section.id }} + *.has-kinetic-text { pointer-events: none; }
    {% endif %}
    #shopify-section-{{ section.id }} .m6as:not(.inv) > div > *[id*="hotspot-variants"]{
      padding: 0 0 0 var(--d);
    }
  }
  #shopify-section-{{ section.id }} .m6as:not(.inv) {
    margin-left: calc(0px - var(--d));
  }
  #shopify-section-{{ section.id }} .m6as:not(.inv) > figure {
    border-left: var(--d) solid transparent;
  }
</style>

{% schema %}
{
  "name": "t:sections.image_hotspots_variants.name",
  "max_blocks": 5,
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay"
    ]
  },
  "settings": [
    {
      "id": "image",
      "type": "image_picker",
      "label": "t:sections.image_hotspots_variants.settings.image.label"
    },
    {
      "type": "select",
      "id": "hotspot_color_palette",
      "label": "t:sections.image_hotspots.settings.hotspot_color_palette.label",
      "options": [
        {
          "value": "primary",
          "label": "t:global.button.button_style.primary.label"
        },
        {
          "value": "secondary",
          "label": "t:global.button.button_style.secondary.label"
        },
        {
          "value": "tertiary",
          "label": "t:global.button.button_style.tertiary.label"
        }
      ],
      "default": "primary"
    },
    {
      "type": "range",
      "id": "hotspot_height",
      "label": "t:sections.image_hotspots_variants.settings.hotspot_height.label",
      "min": 20,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 33
    },
    {
      "id": "layout",
      "type": "select",
      "label": "t:sections.image_hotspots_variants.settings.layout.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.image_hotspots_variants.settings.layout.options__1.label"
        },
        {
          "value": "right",
          "label": "t:sections.image_hotspots_variants.settings.layout.options__2.label"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:global.layout.width.label",
      "options": [
        {
          "value": "boxed",
          "label": "t:global.layout.width.options__1.label"
        },
        {
          "value": "wide",
          "label": "t:global.layout.width.options__2.label"
        }
      ],
      "default": "wide"
    },
    {
      "type": "select",
      "id": "height",
      "label": "t:global.layout.height.label_banner",
      "options": [
        {
          "value": "16/9",
          "label": "t:global.layout.height.16_9.label"
        },
        {
          "value": "4/3",
          "label": "t:global.layout.height.4_3.label"
        },
        {
          "value": "1/1",
          "label": "t:global.layout.height.1_1.label"
        },
        {
          "value": "adapt",
          "label": "t:global.layout.height.adapt.label"
        }
      ],
      "default": "16/9"
    },
    {
      "id": "enable_custom_height",
      "type": "checkbox",
      "label": "t:global.layout.enable_custom_height.label"
    },
    {
      "type": "range",
      "id": "custom_height",
      "label": "t:global.layout.custom_height.label",
      "info": "t:global.layout.custom_height.info",
      "min": 250,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "default": 300
    },
    {
      "type": "select",
      "id": "title_size",
      "label": "t:global.typography.title_size.label",
      "options": [
        {
          "value": "h1",
          "label": "t:global.typography.title_size.h1.label"
        },
        {
          "value": "h2",
          "label": "t:global.typography.title_size.h2.label"
        },
        {
          "value": "h3",
          "label": "t:global.typography.title_size.h3.label"
        },
        {
          "value": "h4",
          "label": "t:global.typography.title_size.h4.label"
        },
        {
          "value": "h5",
          "label": "t:global.typography.title_size.h5.label"
        }
      ],
      "default": "h3"
    },
    {
      "type": "header",
      "content": "t:global.variant_bulk.label",
      "info": "t:global.variant_bulk.info"
    },
    {
      "id": "bulk_title",
      "type": "text",
      "label": "t:main.collection.settings.variants.bulk_title.label",
      "default": "Select quantities",
      "placeholder": "Select quantities"
    },
    {
      "type": "checkbox",
