{%- render 'breadcrumbs', hide_desktop: section.settings.hide_desktop, text_alignment: section.settings.text_alignment, hide_mobile: section.settings.hide_mobile, enable_share_button: section.settings.enable_share_button %}

<style>
  #shopify-section-{{ section.id }} { position: initial !important; }
</style>

{% schema %}
{
  "name": "t:static_sections.breadcrumbs.name",
  "class": "shopify-section-breadcrumbs",
  "settings": [
    {
      "type": "checkbox",
      "id": "hide_desktop",
      "label": "t:static_sections.breadcrumbs.settings.hide_desktop.label",
      "default": false
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "t:global.typography.content_position.label",
      "options": [
        {
          "value": "start",
          "label": "t:global.alignment.left.label"
        },
        {
          "value": "center",
          "label": "t:global.alignment.center.label"
        }
      ],
      "default": "start"
    },
    {
      "type": "header",
      "content": "t:global.mobile.header"
    },
    {
      "type": "checkbox",
      "id": "hide_mobile",
      "label": "t:static_sections.breadcrumbs.settings.mobile.hide_mobile.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_share_button",
      "label": "t:static_sections.breadcrumbs.settings.mobile.enable_share_button.label",
      "info": "t:static_sections.breadcrumbs.settings.mobile.enable_share_button.info",
      "default": false
    }
  ]
}
{% endschema %}
