{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{%- liquid
  assign overlay = false
  if section.settings.color_palette.id != settings.default_color_scheme.id
    assign overlay = true
  endif
  assign alignments = section.settings.text_position | split: ' '
  if alignments.size == 2
    assign position = alignments[0]
  else
    assign position = alignments[1]
  endif 
  assign quickshop = true
  if section.settings.enable_bulk
    assign quickshop = false
  endif

  assign show_price = true
  if settings.login_for_prices and customer == nil
    assign show_price = false
  endif

  assign ref_img = section.settings.image
  if section.settings.enable_custom_height
    assign padding_bottom = 0
  else
    if section.settings.height == 'adapt' and ref_img
      assign padding_bottom = 1 | divided_by: ref_img.aspect_ratio | times: 100 | round: 2
      if section.settings.layout != 'background'
        assign padding_bottom = padding_bottom | divided_by: 2
      endif
    else
      assign aspect_ratio = section.settings.height | split: '/'
      assign temp = aspect_ratio[0] | append: '.0'
      assign ratio = aspect_ratio[1] | divided_by: temp | round: 2
      assign padding_bottom = ratio | times: 100 | round: 2
      assign padding_bottom = padding_bottom | divided_by: 2
    endif

  endif

  if section.settings.height_mobile == 'adapt' and ref_img
    if section.settings.image_mobile
      assign ref_img = section.settings.image_mobile
    endif
    assign padding_bottom_mobile = 1 | divided_by: ref_img.aspect_ratio | times: 100 | round: 2
  else
    assign aspect_ratio = section.settings.height_mobile | split: '/'
    assign temp = aspect_ratio[0] | append: '.0'
    assign ratio = aspect_ratio[1] | divided_by: temp | round: 2
    assign padding_bottom_mobile = ratio | times: 100 | round: 2
  endif

-%}
{% capture hotspot %}
<link href="{{ 'async-product-variants.css' | asset_url }}" rel="preload" as="style" onload="this.rel='stylesheet'">
<noscript>
  <link rel="stylesheet" href="{{ 'async-product-variants.css' | asset_url }}">
</noscript>
<ul class="l4hs dots">
  {%- for block in section.blocks -%}
    {%- if block.settings.product != blank or block.settings.title != empty or block.settings.text != empty -%}
      <li style="
          --horizontal: {{ block.settings.position_left }}%;
          --vertical: {{ block.settings.position_top }}%;
          --horizontal_mobile: {{ block.settings.position_left_mobile }}%;
          --vertical_mobile: {{ block.settings.position_top_mobile }}%;
          "
      {{ block.shopify_attributes }}>

        {%- if block.settings.product != blank -%}
          <a class="toggle" data-popup="hotspot-img-popup-{{ section.id }}-{{ block.id }}">{{ 'general.read_more.read_more' | t }}</a>
        {%- else -%}
          <a class="toggle desktop-only" href="./">{{ 'general.read_more.read_more' | t }}</a>
          <a class="toggle desktop-hide" href="./" data-panel="hotspot-{{ section.id }}-{{ forloop.index }}">{{ 'general.read_more.read_more' | t }}</a>
        {%- endif -%}
        <div class="palette-{{ settings.default_color_scheme }} module-color-palette {{ block.settings.text_position }}{% if block.settings.product != blank %} desktop-only{% endif %}">
            <h3 class="ff-{{ block.settings.title_font }}">{{ block.settings.title }}</h3>
            <div class="info">
              {{ block.settings.text }}
            </div>
        </div>

        {%- if block.settings.product != blank -%}
        <article class="popup-a {% if section.settings.enable_bulk %}w600{% else %}w380 l4cl-in-popup-wide{% endif %}" data-title="hotspot-img-popup-{{ section.id }}-{{ block.id }}" style="--ppd: 20px;">
          <ul class="l4cl{% if section.settings.enable_bulk %} list{% endif %}{% if settings.fill_product_images and section.settings.enable_bulk == false %} in-popup-wide{% else %} w100 mobile-scroll{% endif %}">
              {%- render 'product-item', product: block.settings.product, type: 'both', enable_quick_buy_desktop: quickshop, enable_quick_buy_mobile: quickshop, enable_quick_buy_qty_selector: quickshop, layout: 'hotspot', enable_bulk: true, popup: true -%}
          </ul>
          {%- if section.settings.enable_bulk -%}
            {% liquid

              assign form_class = 'l4ml-form list-only f8pr f8pr-buy-button m20 product-card s-bulk'
              if block.settings.product.variants.size == 1
                assign form_class = form_class | append: ' form-card'
              endif
              assign form_id = 'main-hotspot-product-form-' | append: section.id | append: '-' | append: block.id
              assign current_variant = block.settings.product.selected_or_first_available_variant

              assign custom_height_ratio = settings.custom_product_image_ratio | divided_by: 100.0
              assign image_width = 430
              assign image_height = image_width | times: custom_height_ratio
              assign image_width_small = image_width | divided_by: 3
              assign image_height_small = image_height | divided_by: 3

            -%}
            {%- form 'product', block.settings.product, id: form_id, class: form_class, autocomplete: "off" -%}
            {%- if block.settings.product.variants.size == 1 -%}

              {%- render 'product-deliverytime',
                      product: product,
                      current_variant: current_variant,
                      container: "p",
                      origin: 'productitem',
                      no_margin: true,
                      extra_class: 'size-12'
              -%}

            {%- else -%}
            <p class="s1hd m15">{{ section.settings.bulk_title }}</p>
            <ul class="l4ml">
              {% assign limitVariants = 4 %}
              {%- for variant in block.settings.product.variants -%}
                <li class="{% unless show_price %}disabled {% endunless %}{% if forloop.index > limitVariants %}hidden{% endif %}">
                  {%- if variant.image and section.settings.bulk_show_variant_images -%}
                    <figure>
                      <picture><img src="{% if settings.fill_product_images %}{{ variant.image | image_url: width: image_width_small, height: image_height_small, crop: 'center' }}{% else %}{{ variant.image | image_url: height: image_height_small }}{% endif %}" alt="{{ variant.title }}" width="50" height="55" loading="lazy" {% if settings.fill_product_images %}class="filled"{% endif %}></picture>
                    </figure>
                  {%- endif -%}
                  <span>
                    <span {% if section.settings.bulk_shorten_title %}class="s1nw"{% endif %}><a href="{{ variant.url }}">{{ variant.title }}</a></span>
                    {%- liquid
                      if section.settings.show_deliverytime
                        assign hide_deliverytime = false
                      else
                        assign hide_deliverytime = true
                      endif
                    -%}
                    {%- render 'product-deliverytime',
                        product: variant,
                        current_variant: variant,
                        container: "span",
                        origin: 'productitem',
                        extra_class: 'size-12',
                        extra_element: '<br>',
                        hide_deliverytime: hide_deliverytime
                    -%}
                    {% unless section.settings.bulk_shorten_title %}<br class="mobile-only">{% endunless %}
                    {% comment %} <span class="s1pr mobile-only">{% if variant.compare_at_price > current_variant.price and show_price %}<span class="old-price">{{ current_variant.compare_at_price | money }}</span> {% endif %}{% if show_price %}{{ variant.price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}</span> {% endcomment %}
                    {% render 'price', product: variant.product, variant: variant, price: variant.compare_at_price, origin: 'bulk', extraClass: 'mobile-only' %}
                    </span>
                      {% comment %} <span class="s1pr mobile-hide">{% if variant.compare_at_price > current_variant.price and show_price %}<span class="old-price">{{ current_variant.compare_at_price | money }}</span> {% endif %}{% if show_price %}{{ variant.price | money }}{% else %}{{ 0000 | money | money | replace: '0', '-' }}{% endif %}</span> {% endcomment %}
                      {% render 'price', product: variant.product, variant: variant, price: variant.compare_at_price, origin: 'bulk', extraClass: 'mobile-hide' %}
                      <span class="input-amount {% if settings.qty_input_controls == 'enable' %}strong{% else %}no-arrows{% endif %} in-popup">
                        <label for="ml-{{ section.id }}-{{ block.id }}-{{ variant.id }}" class="hidden">{{ 'product.form.quantity' | t }}</label>
                        <input type="number" id="ml-{{ section.id }}-{{ block.id }}-{{ variant.id }}" name="ml-{{ section.id }}-{{ block.id }}-{{ variant.id }}" placeholder="0"
                        min="{% if variant.quantity_rule.min > 1 %}{{ variant.quantity_rule.min }}{% elsif block.settings.product.variants.size == 1 %}1{% else %}0{% endif %}"
                        {% if variant.inventory_management == 'shopify' and variant.inventory_policy == 'deny' -%}
                           max="{{ variant.inventory_quantity }}"
                        {% elsif variant.quantity_rule.max %}
                           max="{{ variant.quantity_rule.max }}"
                        {% endif %}
                        step="{{ variant.quantity_rule.increment }}" required{% if variant.available == false %} disabled{% endif %} data-id="{{ variant.id }}" {% render 'price', product: variant.product, variant: variant, price: variant.price, origin: 'bulk-input' %} data-price="{{ variant.price }}">
                      </span>
                  </li>
              {%- endfor -%}
              {% if block.settings.product.variants.size > limitVariants %}
                <li class="link-more"><a href="./" class="link-more strong inline in-popup"><span class="link-underline">{{ 'general.read_more.show' | t }} <span>{{ 'general.read_more.all' | t }}</span> <span class="hidden">{{ 'general.read_more.less' | t }}</span> {{ 'general.read_more.variants' | t }}</span></a></li>
              {% endif %}
            </ul>
          {%- endif -%}
            {%- if show_price -%}
              {%- if block.settings.product.variants.size == 1 -%}
                <p class="submit margin-0 nowrap">
                  <span class="margin-10">
                    {% render 'price', product: current_variant.product, variant: current_variant, price: current_variant.compare_at_price, origin: 'bulk' %}
                  {% if settings.productcards_show_tax -%}&nbsp;<span data-syncer-vat-incl class="size-small font-regular">{{ 'product.including_tax' | t }}</span><span data-syncer-vat-excl class="size-12 font-regular">{{ 'product.excluding_tax' | t }}</span>{%- endif -%}
                  </span>
                </p>
              {%- endif -%}
              <div class="submit nowrap" style="--btn_dist: clamp(16px, 4vw, 40px);">
                {%- if block.settings.product.variants.size == 1 -%}
                  <input name="id" value="{{ current_variant.id }}" type="hidden">
                  {% if block.settings.product.variants.size > 1 %}<span class="margin-0">{% render 'price', product: current_variant.product, variant: current_variant, price: current_variant.compare_at_price, origin: 'bulk' %}</span>
                {% endif %}
                  {%- if current_variant.available -%}
                    <span class="margin-0 input-amount {% if settings.qty_input_controls == 'enable' %}strong{% else %}no-arrows{% endif %} in-popup">
                      <label for="ml-{{ section.id }}-{{ block.id }}-{{ variant.id }}" class="hidden">{{ 'product.form.quantity' | t }}</label>
                      <input type="number" id="ml-{{ section.id }}-{{ block.id }}-{{ variant.id }}" name="ml-{{ section.id }}-{{ block.id }}-{{ variant.id }}" placeholder="0"
                      min="{% if current_variant.quantity_rule.min > 1 %}{{ current_variant.quantity_rule.min }}{% elsif current_variant.variants.size == 1 %}1{% else %}0{% endif %}"
                      {% if current_variant.inventory_management == 'shopify' and current_variant.inventory_policy == 'deny' -%}
                         max="{{ current_variant.inventory_quantity }}"
                      {% elsif current_variant.quantity_rule.max %}
                         max="{{ current_variant.quantity_rule.max }}"
                      {% endif %}
                      step="{{ current_variant.quantity_rule.increment }}" required{% if current_variant.available == false %} disabled{% endif %} data-id="{{ current_variant.id }}" data-price="{{ current_variant.price }}">
                    </span>
                  {%- endif -%}
                {%- else -%}
                <span class="margin-0">
                  {% render 'price', product: block.settings.product, origin: 'bulk-subtotal' %}
                  {% if settings.productcards_show_tax -%}&nbsp;<span data-syncer-vat-incl class="size-small font-regular">{{ 'product.including_tax' | t }}</span><span data-syncer-vat-excl class="size-12 font-regular">{{ 'product.excluding_tax' | t }}</span>{%- endif -%}
                </span>
              {%- endif -%}
                {%- if current_variant.available -%}
                  <button type="submit" class="wide overlay-buy_button{% if settings.button_style == 'inv' %} inv{% endif %} {% if block.settings.product.variants.size > 1 %} disabled{% endif %} margin-0">{{ 'product.form.add_to_cart' | t }}</button>
                {%- else -%}
                  <button type="submit" class="wide visible overlay-unavailable_buy_button{% if settings.button_style == 'inv' %} inv{% endif %} disabled margin-0">{{ 'product.form.not_in_stock' | t }}</button>
                {%- endif -%}
              </div>
            {%- else -%}
              <p class="link-btn m10 margin-0" {{ block.shopify_attributes }}>
                <a href="{{ routes.account_login_url }}" class="wide overlay-buy_button{% if settings.buy_button_style == 'inv' %} inv{% endif %}">{{ 'customer.login.login_for_prices_html' | t }}</a>
              </p>
            {%- endif -%}
            {%- endform -%}
          {%- endif -%}
        </article>
        {%- endif -%}
      </li>
      {%- if block.settings.product == blank -%}
        <aside class="m6pn" id="hotspot-{{ section.id }}-{{ forloop.index }}" aria-hidden="true">
          <h2 class="ff-{{ block.settings.title_font }}">{{ block.settings.title }}</h2>
          {{ block.settings.text }}
        </aside>
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
</ul>

{% endcapture %}
<div class="
  m6fr
  mobile-text-center
  {{ section.settings.width }}
  size-{{ section.settings.height }}
  size-{{ section.settings.height_mobile }}-mobile
  {% if section.settings.width != 'wide' %}m6fr-boxed{% endif %}
  "
  >
  <article class="palette-{{ section.settings.color_palette }}
    {{ section.settings.text_position }}
    {% unless section.settings.layout == 'background' %}
      aside
      {% unless overlay %}
        has-border
      {% endunless %}
    {% endunless %}
    {% if section.settings.layout == 'left' %}inv{% endif %}
    module-color-palette
    "
     style="
       --align_text: {{ section.settings.text_position | split: ' ' | first }};
       --justify_text: {{ section.settings.text_position | split: ' ' | last }};
       --padding_bottom: {{ padding_bottom }};
       --padding_bottom_mobile: {{ padding_bottom_mobile }};
     "
  >
    <figure>
      <span class="img-overlay" style="opacity:{{ section.settings.overlay_opacity_img | divided_by: 100.0 }}"></span>
      {%- if section.settings.image -%}
        {%- liquid
          if section.index > 1 and section.location != 'footer'
            assign lazyload = true
          endif
        -%}
        {% if section.settings.image_mobile %}
          <picture class="mobile-only">
            {% capture srcset %}
              {% render 'image-srcset', image: section.settings.image_mobile, max_width: 940 %}
            {% endcapture %}
            {% capture sizes %}
              (min-width: 768px) 0,
              100vw
            {% endcapture %}
            {% assign alt = section.settings.image_mobile.alt | default: section.settings.title | escape %}
            {%- if lazyload -%}
              {{ section.settings.image_mobile | image_url: width: 700, height: 530, crop: 'center' | image_tag: srcset: srcset, sizes: sizes, loading: 'lazy', alt: alt }}
            {%- else -%}
              {{ section.settings.image_mobile | image_url: width: 700, height: 530, crop: 'center' | image_tag: srcset: srcset, sizes: sizes, preload: true, alt: alt }}
            {%- endif -%}
          </picture>
        {% endif %}
        <picture {% if section.settings.image_mobile %}class="mobile-hide"{% endif %}>
          {% capture srcset %}
            {% render 'image-srcset', image: section.settings.image, max_width: 2900 %}
          {% endcapture %}
          {% capture sizes %}
            (min-width: 1000px){% if section.settings.width == 'boxed' or settings.width < 2000 %}calc({{ settings.width }}px / 2),{% else %}calc(100vw / 2),{% endif %}
            {% if section.settings.image_mobile %}0{% else %}100vw{% endif %}
          {% endcapture %}
          {% assign alt = section.settings.image.alt | default: section.settings.title | escape %}
          {%- if lazyload -%}
            {{ section.settings.image | image_url: width: 700, height: 530, crop: 'center' | image_tag: srcset: srcset, sizes: sizes, loading: 'lazy', alt: alt }}
          {%- else -%}
            {{ section.settings.image | image_url: width: 700, height: 530, crop: 'center' | image_tag: srcset: srcset, sizes: sizes, preload: true, alt: alt }}
          {%- endif -%}
        </picture>
      {% else %}
        <picture>
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </picture>
      {% endif %}
      {% if section.settings.layout != 'background' %}
        {{ hotspot }}
      {% endif %}
    </figure>
    {% if section.settings.layout == 'background' %}
      {{ hotspot }}
    {% endif %}
      <div class="{{ position }}" {% unless section.settings.content_width == 1280 %}style="max-width:{{ section.settings.content_width }}px"{% endunless %}>
        {%- if section.settings.title != empty -%}
          <div class="
              heading
              {% if section.settings.title_underline_style != 'none' %}
                title-underline-none
                {% if section.settings.title_underline_style contains 'accent' %}
                  title-underline-accent
                {% elsif section.settings.title_underline_style contains 'gradient' %}
                  title-underline-gradient
                {% endif %}
                {% if section.settings.title_underline_style contains 'secondary_font' %}
                  title-underline-secondary-font
                {% endif %}
              {% endif %}
              ">
            {{ section.settings.title }}
          </div>
        {%- endif -%}
        {%- if section.settings.text -%}<div>{{ section.settings.text }}</div>{%- endif -%}
        {%- if section.settings.show_link and section.settings.link_text != empty and section.settings.link_url != blank -%}
          {%- liquid
            assign button_color = section.settings.button_style | split: ' ' | first
            assign button_style = section.settings.button_style | split: ' ' | last
            assign is_link = false
            if button_style == 'link'
              assign is_link = true
            endif
          -%}
          <p class="link{% unless is_link %}-btn{% endunless %}">
            <a href="{{ section.settings.link_url }}" class="overlay-{{ button_color }} {% if is_link %}strong inline{% elsif button_style == 'inv' %}inv{% endif %}">
              <span {% if is_link %}class="link-underline"{% endif %}>{{ section.settings.link_text }}</span>
            </a>
          </p>
        {%- endif -%}
      </div>
  </article>
</div>
<script>
  var hotspot_panels = document.querySelectorAll('#shopify-section-{{ section.id }} .m6pn');
  if (hotspot_panels.length) {
    Array.from(hotspot_panels).forEach(function (el) {
      document.querySelector('#root').appendChild(el);
    })
  }
</script>

<style>
  #shopify-section-{{ section.id }} .module-color-palette:before { opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}; }
  #shopify-section-{{ section.id }} .l4hs { --bg: var(--{{ section.settings.color_palette }}_{{ section.settings.hotspot_color_palette }}_btn_bg); --fg: var(--{{ section.settings.color_palette }}_{{ section.settings.hotspot_color_palette }}_btn_fg); --bg_active: var(--bg); --fg_active: var(--fg); --hs_size: {{ section.settings.hotspot_height }}px; }
  #shopify-section-{{ section.id }} .m6fr { margin-bottom: {{ section.settings.spacing_desktop }}px; }
  #shopify-section-{{ section.id }} { z-index: {{ section.settings.fix_zindex }}!important; }
  @media only screen and (min-width: 47.5em) {
    {% if section.settings.enable_custom_height %}
      #shopify-section-{{ section.id }} .m6fr article {
        min-height: {{ section.settings.custom_height }}px;
      }
    {% endif %}
    {% if section.settings.spacing_desktop < 0 %}
      #shopify-section-{{ section.id }} + *.has-kinetic-text { pointer-events: none; }
    {% endif %}

  }
  @media only screen and (max-width: 47.5em) {
    #shopify-section-{{ section.id }} .m6fr > article { margin-bottom: 0; }
    #shopify-section-{{ section.id }} .m6fr { margin-bottom: {{ section.settings.spacing_mobile }}px; }
    {% if section.settings.spacing_mobile < 0 %}
      #shopify-section-{{ section.id }} + *.has-kinetic-text { pointer-events: none; }
    {% endif %}
  }
  @media only screen and (max-width: 760px) {
    #shopify-section-{{ section.id }} .m6fr article.aside[style*="--padding_bottom"] > figure {
    {% if section.settings.width == 'wide' %}
      height: {{ padding_bottom_mobile }}vw;
    {% else %}
      height: calc({{ padding_bottom_mobile }}vw - (var(--rpp) * 2 ));
    {% endif%}
    }
  }
</style>

{% schema %}
{
  "name": "t:sections.image_hotspots.name",
  "max_blocks": 5,
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay"
    ]
  },
  "settings": [
    {
      "id": "image",
      "type": "image_picker",
      "label": "t:sections.image_hotspots.settings.image.label"
    },
    {
      "type": "range",
      "id": "overlay_opacity_img",
      "label": "t:sections.image_hotspots.settings.overlay_opacity_img.label",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_palette",
      "label": "t:global.color_palette.label",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.countdown.settings.overlay_opacity.label",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "hotspot_height",
      "label": "t:sections.image_hotspots.settings.hotspot_height.label",
      "min": 20,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 33
    },
    {
      "type": "select",
      "id": "hotspot_color_palette",
      "label": "t:sections.image_hotspots.settings.hotspot_color_palette.label",
      "options": [
        {
          "value": "primary",
          "label": "t:global.button.button_style.primary.label"
        },
        {
          "value": "secondary",
          "label": "t:global.button.button_style.secondary.label"
        },
        {
          "value": "tertiary",
          "label": "t:global.button.button_style.tertiary.label"
        }
      ],
      "default": "primary"
    },
    {
      "id": "layout",
      "type": "select",
      "label": "t:sections.image_hotspots.settings.layout.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.image_hotspots.settings.layout.options__1.label"
        },
        {
          "value": "right",
          "label": "t:sections.image_hotspots.settings.layout.options__2.label"
        },
        {
          "value": "background",
          "label": "t:sections.image_hotspots.settings.layout.options__3.label"
        }
      ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:global.layout.width.label",
      "options": [
        {
          "value": "boxed",
          "label": "t:global.layout.width.options__1.label"
        },
        {
          "value": "wide",
          "label": "t:global.layout.width.options__2.label"
        }
      ],
      "default": "wide"
    },
    {
      "type": "select",
      "id": "height",
      "label": "t:global.layout.height.label_banner",
      "options": [
        {
          "value": "16/9",
          "label": "t:global.layout.height.16_9.label"
        },
        {
          "value": "4/3",
          "label": "t:global.layout.height.4_3.label"
        },
        {
          "value": "1/1",
          "label": "t:global.layout.height.1_1.label"
        },
        {
          "value": "adapt",
          "label": "t:global.layout.height.adapt.label"
        }
      ],
      "default": "1/1"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_height",
      "label": "t:sections.image_hotspots.settings.enable_custom_height.label"
    },
    {
      "type": "range",
      "id": "custom_height",
      "label": "t:sections.image_hotspots.settings.custom_height.label",
      "info": "t:sections.image_hotspots.settings.custom_height.info",
      "min": 250,
